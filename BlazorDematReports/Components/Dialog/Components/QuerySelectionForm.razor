@using BlazorDematReports.Core.Application.Dto
@using BlazorDematReports.Core.DataReading.Dto

<MudGrid>
    @* Query associata *@
    <MudItem xs="12" sm="6">
        <MudSelect T="int?" 
                   Label="Query" 
                   @bind-Value="SelectedQueryId"
                   Required="@(!IsMailServiceSelected)"
                   Disabled="@IsMailServiceSelected"
                   Clearable="true"
                   HelperText="@GetQueryHelperText()">
            @if (!IsMailServiceSelected && HasIntegratedQuery)
            {
                <MudSelectItem T="int?" Value="0">-- Query integrata --</MudSelectItem>
            }
            @if (!IsMailServiceSelected && AvailableQueries != null)
            {
                @foreach (var item in AvailableQueries)
                {
                    <MudSelectItem T="int?" Value="item.IdQuery">@item.Titolo</MudSelectItem>
                }
            }
        </MudSelect>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public int? SelectedQueryId { get; set; }
    [Parameter] public EventCallback<int?> SelectedQueryIdChanged { get; set; }
    [Parameter] public bool IsMailServiceSelected { get; set; }
    [Parameter] public bool HasIntegratedQuery { get; set; }
    [Parameter] public List<QueryProcedureLavorazioniDto>? AvailableQueries { get; set; }

    private string GetQueryHelperText()
    {
        if (IsMailServiceSelected)
            return "Query disabilitata quando è selezionato un servizio mail";
        
        if (HasIntegratedQuery)
            return "Seleziona tra query integrata nel codice o query personalizzata";
        
        return "Seleziona una query personalizzata per l'elaborazione dati";
    }
}