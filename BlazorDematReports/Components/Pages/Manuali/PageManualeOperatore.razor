@page "/manuale-operatore"
@attribute [Authorize(Roles = "OWNER, ADMIN, SUPERVISOR,CAPOTURNO, USER")]
@inject IJSRuntime JSRuntime
@using System.Text.RegularExpressions

<MudText Typo="Typo.h4" Class="titolo ml-4">Manuale Operatore</MudText>
<MudDivider Class="border-solid border-1 mud-border-primary" />

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    @if (isLoading)
    {
        <MudProgressCircular Indeterminate="true" />
        <MudText>Caricamento manuale operatore...</MudText>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-4">
            <MudItem xs="12" md="9">
                <MudExpansionPanels>
                    <MudExpansionPanel Text="Indice Sezioni">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var s in manualSections)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="MudBlazor.Color.Primary"
                                           Size="Size.Small"
                                           Class="@GetSectionClass(s.Id)"
                                           OnClick="@(() => ScrollToSection(s.Id))">
                                    @s.Number @s.Title
                                </MudButton>
                            }
                        </div>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           StartIcon="@Icons.Material.Filled.Print"
                           OnClick="PrintAsync"
                           FullWidth="true">
                    Stampa / Salva PDF
                </MudButton>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4"
                  Elevation="2"
                  Style="max-height:80vh; overflow-y:auto; font-size:14px; scroll-behavior:smooth; position:relative;"
                  id="manuale-operatore-content">
            <div class="manuale-operatore-html">
                @((MarkupString)manualHtml)
            </div>
        </MudPaper>
    }
</MudContainer>

<style>
    /* --- Stili schermo --- */
    .manuale-sezione-titolo { margin-top:30px; margin-bottom:6px; font-weight:600; font-size:18px; }
    .manuale-sottotitolo    { margin-top:16px; font-weight:600; font-size:15px; }
    .manuale-paragrafo      { margin:2px 0 10px 0; line-height:1.55; }
    .indice-attivo          { border-color: var(--mud-palette-primary)!important; font-weight:600; }
    .section-selected       { outline:2px solid var(--mud-palette-primary); background:rgba(0,123,255,.08); border-radius:4px; }
    .anchor-offset          { position:relative; top:-70px; visibility:hidden; }
    .diagram-block          { font-family:monospace; white-space:pre; background:#f5f5f5; padding:12px; border-radius:4px; overflow-x:auto; font-size:12px; margin:8px 0; }

    /* --- Stili stampa / PDF --- */
    @@media print {
        /* Nasconde l'intera shell Blazor/MudBlazor tranne il manuale */
        .mud-appbar, .mud-drawer, .mud-drawer-overlay,
        .mud-expansion-panels, .mb-4,
        .mud-button-root, .mud-snackbar-container  { display: none !important; }

        /* Rimuove i limiti di altezza del pannello scorrevole */
        #manuale-operatore-content {
            max-height: none    !important;
            overflow:   visible !important;
            box-shadow: none    !important;
            border:     none    !important;
            padding:    0       !important;
        }

        /* Evita interruzioni di pagina dentro diagrammi e box colorati */
        .diagram-block,
        [style*="background:#fff3cd"],
        [style*="background:#e8f5e9"],
        [style*="background:#e3f2fd"] { page-break-inside: avoid; }

        /* Titoli di sezione sempre con il loro contenuto */
        .manuale-sezione-titolo { page-break-after: avoid; font-size:14pt; }
        .manuale-sottotitolo    { page-break-after: avoid; font-size:11pt; }
        .manuale-paragrafo      { font-size:10pt; line-height:1.4; }

        /* I diagrammi vanno a capo invece di scorrere orizzontalmente */
        .diagram-block { white-space: pre-wrap; overflow-x: visible; font-size:8pt; }

        /* Margini pagina */
        @@page { margin: 1.5cm 2cm; }
    }
</style>

@code {
    private sealed class ManualSection
    {
        public string Id     { get; init; } = Guid.NewGuid().ToString("N");
        public string Number { get; set; }  = string.Empty;
        public string Title  { get; set; }  = string.Empty;
        public List<string>           Paragraphs  { get; } = new();
        public List<ManualSubSection> Subsections { get; } = new();
    }

    private sealed class ManualSubSection(string title, List<string> lines, bool rawHtml = false)
    {
        public string       Title   { get; } = title;
        public List<string> Lines   { get; } = lines;
        public bool         RawHtml { get; } = rawHtml;
    }

    private string              errorMessage    = string.Empty;
    private bool                isLoading       = true;
    private string              activeSectionId = string.Empty;
    private List<ManualSection> manualSections  = new();
    private string              manualHtml      = string.Empty;

    protected override Task OnInitializedAsync()
    {
        try
        {
            manualSections = BuildOperatorManualSections();
            manualHtml     = BuildHtmlFromSections(manualSections);
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore durante il caricamento del manuale operatore: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
        return Task.CompletedTask;
    }

    private async Task ScrollToSection(string id)
    {
        activeSectionId = id;
        await JSRuntime.InvokeVoidAsync("scrollToManualSection", "manuale-operatore-content", id);
    }

    /// <summary>Restituisce la classe CSS del bottone indice per la sezione attiva.</summary>
    private string GetSectionClass(string id)
        => activeSectionId == id ? "indice-attivo" : string.Empty;

    /// <summary>Apre il dialogo di stampa del browser: l'utente sceglie 'Salva come PDF'.
    /// Il CSS @media print nasconde la UI e mostra solo il contenuto del manuale.</summary>
    private async Task PrintAsync()
        => await JSRuntime.InvokeVoidAsync("window.print");

    private static List<ManualSection> BuildOperatorManualSections()
    {
        var list = new List<ManualSection>();
        int n    = 0;

        ManualSection Add(string title, Action<ManualSection> build)
        {
            n++;
            var sec = new ManualSection { Number = n + ".", Title = title, Id = "sec-op-" + n };
            build(sec);
            list.Add(sec);
            return sec;
        }

        Add("INTRODUZIONE", s =>
        {
            s.Paragraphs.Add("DematReports consente agli operatori di inserire, controllare e analizzare la produzione documentale giornaliera.");
            s.Subsections.Add(new("Scopo", [
                "Guidare l'utente nell'utilizzo quotidiano della piattaforma.",
                "Descrivere flussi base e funzioni chiave."]));
            s.Subsections.Add(new("Ruoli", [
                "USER: inserimento e consultazione della propria produzione.",
                "CAPOTURNO: supervisione turno e accesso ai report.",
                "SUPERVISOR / ADMIN: configurazioni complete e gestione utenti.",
                "RESPONSABILE: governance e controllo qualità."]));
        });

        Add("ACCESSO E NAVIGAZIONE", s =>
        {
            s.Subsections.Add(new("Requisiti", [
                "Browser moderno (Edge / Chrome / Firefox).",
                "Credenziali fornite dall'amministratore.",
                "Connessione di rete stabile."]));
            s.Subsections.Add(new("Login", [
                "Aprire l'URL aziendale della piattaforma.",
                "Inserire username e password.",
                "Verificare il ruolo visualizzato nella barra superiore."]));
            s.Subsections.Add(new("Layout", [
                "Menu laterale: accesso a tutte le funzioni disponibili per il proprio ruolo.",
                "Barra superiore: informazioni utente e logout.",
                "Area centrale: pagine operative."]));
        });

        Add("FUNZIONALITA PER RUOLO", s =>
        {
            s.Subsections.Add(new("User", [
                "Carica Dati produzione.",
                "Visualizza e gestisce la propria produzione.",
                "Consulta manuali."]));
            s.Subsections.Add(new("Capoturno", [
                "Tutte le funzioni User.",
                "Report lavorazioni e scheda lavorazione.",
                "Gestione operatori e grafici produzione."]));
            s.Subsections.Add(new("Supervisor / Admin", [
                "Configurazioni avanzate e gestione fonti dati.",
                "Gestione ruoli e utenti.",
                "Task background e Data Manager."]));
        });

        Add("INSERIMENTO PRODUZIONE", s =>
        {
            s.Paragraphs.Add("La pagina Carica Dati è il punto di ingresso principale per la registrazione della produzione manuale. I campi sono a cascata: ogni selezione determina le opzioni successive.");
            s.Subsections.Add(new("Cosa vede l'operatore", [
                "Un form strutturato con campi a cascata: Centro, poi Lavorazione, poi Fase.",
                "I campi Documenti, Fogli, Pagine e Scarti accettano solo valori numerici interi non negativi.",
                "Il bottone Salva è abilitato solo quando tutti i campi obbligatori sono compilati.",
                "Una griglia in basso mostra i record gia inseriti per la data selezionata."]));
            s.Subsections.Add(new("Cosa deve fare l'operatore", [
                "1. Selezionare la Data di lavorazione (default: oggi).",
                "2. Scegliere il Centro di appartenenza.",
                "3. Scegliere la Lavorazione disponibile per quel centro.",
                "4. Scegliere la Fase (es. Scansione, Classificazione, Index).",
                "5. Inserire i valori: Documenti, Fogli, Pagine (e Scarti se previsti dalla fase).",
                "6. Premere Salva e verificare la riga nella griglia sottostante."]));
            s.Subsections.Add(new("Diagramma compilazione form", [
                "<div class='diagram-block'>Seleziona Data\n     |\n     v\nSeleziona Centro\n     |\n     v\nSeleziona Lavorazione   <-- lista dipende dal Centro scelto\n     |\n     v\nSeleziona Fase          <-- lista dipende dalla Lavorazione\n     |\n     v\nInserisci Documenti / Fogli / Pagine / Scarti\n     |\n     v\n[Salva]\n     |\n     +-- OK    --> Riga aggiunta in griglia + messaggio di successo\n     |\n     +-- Errore --> Messaggio dettagliato (duplicato / campo mancante)</div>"], true));
            s.Subsections.Add(new("Validazioni", [
                "Campi obbligatori: data, centro, lavorazione, fase.",
                "Nessun valore negativo.",
                "Almeno un totale > 0.",
                "Controllo univocita: stessa data + operatore + fase non può essere inserita due volte."]));
            s.Subsections.Add(new("Errori Comuni", [
                "Record duplicato: il record esiste gia per quella data, modificare quello esistente.",
                "Campi disabilitati: completare prima le selezioni obbligatorie precedenti.",
                "Valori respinti: controllare il formato numerico (solo interi positivi)."]));
        });

        Add("GESTIONE OPERATORI", s =>
        {
            s.Paragraphs.Add("Disponibile per Supervisori e ruoli superiori. Permette di analizzare la produttività per operatore, rilevare anomalie e confrontare i dati tra centri.");
            s.Subsections.Add(new("Cosa vede il supervisor", [
                "Una griglia con un record per operatore: nome, centro, totali aggregati (Documenti, Fogli, Pagine).",
                "Filtri in alto: intervallo date, centro, lavorazione.",
                "Righe evidenziate per operatori con codice non riconosciuto (Not_Found_Oper)."]));
            s.Subsections.Add(new("Cosa deve fare il supervisor", [
                "1. Impostare l'intervallo date desiderato.",
                "2. Selezionare il centro da analizzare (o lasciare 'Tutti').",
                "3. Applicare eventuali filtri per lavorazione.",
                "4. Leggere i totali e individuare valori anomali o operatori non censiti.",
                "5. Esportare il report se necessario."]));
            s.Subsections.Add(new("Diagramma navigazione", [
                "<div class='diagram-block'>Imposta Filtri (date, centro, lavorazione)\n     |\n     v\n[Griglia operatori]\n     |\n     +-- Totali nella norma  --> Nessuna azione\n     |\n     +-- Valore anomalo      --> Verificare con l'operatore\n     |\n     +-- Not_Found_Oper      --> Contattare admin per censimento in anagrafica</div>"], true));
            s.Subsections.Add(new("Regole inserimento in ProduzioneSistema", [
                "Per ogni operatore rilevato nei dati sorgente, il sistema applica una sequenza di controlli per decidere se inserirlo, escluderlo o registrarlo come non riconosciuto.",
                "La logica è gestita da ElaboraDatiLavorazione e si basa su tre registri: operatori del centro corrente, operatori di altri centri, registro globale (mondo)."]));
            s.Subsections.Add(new("Schema decisionale operatore", [
                "<div class='diagram-block'>[Operatore rilevato nei dati sorgente]\n              |\n              v\n  Censito nel centro corrente?\n       |              |\n      SI              NO\n       |              |\n       v              v\n   INSERITO   Censito in un altro centro?\n              (operatoreInAltriCentri)\n                   |              |\n                  SI              NO\n                   |              |\n                   v              v\n              ESCLUSO    Censito nel registro globale?\n                         (operatoreMondo)\n                              |              |\n                             SI              NO\n                              |              |\n                              v              v\n                          INSERITO    INSERITO come\n                          (esterno)   Not_Found_Oper\n\n Legenda:\n  INSERITO          = record salvato in ProduzioneSistema con dati aggregati\n  ESCLUSO           = record scartato, non compare nei report del centro\n  Not_Found_Oper    = inserito con codice speciale, visibile in Gestione Operatori</div>"], true));
            s.Subsections.Add(new("Note", [
                "Not_Found_Oper indica dati letti da fonti automatiche con codice operatore non censito in anagrafica.",
                "Contattare l'amministratore per censire i nuovi operatori.",
                "I totali dovrebbero essere isolati per centro: i dati Genova non dovrebbero includere mai quelli Verona,perchè ciò avvenga deve essere specificato in modo univoco il centro di appartenenza dell'operatore.",
                "Esiste quindi un eccezione all'isolamento del centro: se un operatore non è riconducibile a nessun centro (non censito nel centro corrente, non censito in altri centri, non presente nel registro globale), viene comunque inserito come Not_Found_Oper anzichè essere escluso. Questo evita la perdita silente di dati di produzione. La distinzione avviene automaticamente in ElaboraDatiLavorazione."]));
            s.Subsections.Add(new("Avviso - Rischio doppio conteggio Not_Found_Oper", [
                "<div style='background:#fff3cd;border:1px solid #ffc107;border-left:5px solid #e65100;border-radius:4px;padding:12px 16px;margin:6px 0;'>" +
                "<div style='font-weight:700;font-size:14px;margin-bottom:6px;'>ATTENZIONE: Rischio doppio conteggio per operatori sconosciuti</div>" +
                "<div style='margin-bottom:6px;'>Se piu task di <strong>centri diversi</strong> leggono la <strong>stessa tabella sorgente</strong> senza un filtro WHERE per centro, un operatore sconosciuto può essere inserito come <strong>Not_Found_Oper da ciascun task separatamente</strong>, causando un doppio conteggio dei suoi dati di produzione.</div>" +
                "<div style='margin-bottom:4px;'><strong>Perche avviene:</strong> il guard di esclusione (operatoreInAltriCentri) si attiva solo per operatori <em>noti</em> in altri centri. Un operatore sconosciuto non viene escluso da nessun task.</div>" +
                "<div style='margin-bottom:4px;'><strong>Mitigazione:</strong> le query devono sempre includere un filtro esplicito per centro nel WHERE:</div>" +
                "<div style='font-family:monospace;background:#f5f5f5;padding:6px 10px;border-radius:3px;font-size:11px;'>WHERE department = 'GENOVA' AND col &gt;= @startDate AND col &lt;= @endDate</div>" +
                "<div style='margin-top:6px;'>In alternativa la tabella sorgente deve contenere <strong>esclusivamente</strong> dati del centro di competenza.</div>" +
                "</div>"], true));
        });

        Add("REPORT E GRAFICI", s =>
        {
            s.Paragraphs.Add("Le sezioni Report consentono di consultare, filtrare ed esportare i dati di produzione in diversi formati e aggregazioni.");
            s.Subsections.Add(new("Report Totali - Cosa fare", [
                "1. Accedere a Report -> Totali.",
                "2. Impostare data inizio e data fine.",
                "3. Selezionare centro e/o lavorazione (opzionale).",
                "4. Cliccare Aggiorna per ricaricare la griglia.",
                "5. Usare il bottone Export per scaricare in Excel o PDF."]));
            s.Subsections.Add(new("Report Completo - Cosa fare", [
                "1. Accedere a Report -> Completo.",
                "2. Applicare i filtri: operatore, fase, intervallo date.",
                "3. Scorrere la griglia per l'analisi riga per riga.",
                "4. Ordinare le colonne cliccando sull'intestazione di colonna."]));
            s.Subsections.Add(new("Grafico Produzione - Cosa fare", [
                "1. Accedere a Report -> Grafico.",
                "2. Scegliere la tipologia di visualizzazione (linee, barre).",
                "3. Impostare l'intervallo temporale.",
                "4. Usare i filtri dinamici per isolare centri o lavorazioni specifici."]));
            s.Subsections.Add(new("Diagramma utilizzo report", [
                "<div class='diagram-block'>Apri sezione Report\n     |\n     v\nImposta filtri (date, centro, lavorazione)\n     |\n     v\n[Clicca Aggiorna]\n     |\n     v\nGriglia / Grafico aggiornati\n     |\n     +-- Analisi completata  --> Fine\n     |\n     +-- Dato anomalo        --> Torna a Carica Dati per correzione\n     |\n     +-- Export              --> Salva in Excel / PDF</div>"], true));
        });

        Add("CONFIGURAZIONI", s =>
        {
            s.Subsections.Add(new("Anagrafiche", [
                "Centri, Clienti, Operatori.",
                "Gestibili da Supervisor e Admin."]));
            s.Subsections.Add(new("Lavorazioni", [
                "Procedure e Fasi.",
                "Mapping fasi-totali."]));
            s.Subsections.Add(new("Normalizzazione Operatori", [
                "Mappatura alias verso identita operatore.",
                "Garantisce coerenza dei nomi nelle elaborazioni."]));
        });

        Add("LETTORE DATI", s =>
        {
            s.Paragraphs.Add("Servizio applicativo responsabile dell'acquisizione, normalizzazione ed inserimento automatico dei dati di produzione tramite pipeline Hangfire.");
            s.Subsections.Add(new("Scopo", [
                "Recuperare dati grezzi da query parametrizzate o handler integrati.",
                "Applicare normalizzazioni operatori e regole di business.",
                "Persistere su ProduzioneSistema evitando duplicati e preservando inserimenti manuali.",
                "Tracciare l'esito delle operazioni su TaskDataReadingAggiornamento."]));
            s.Subsections.Add(new("Caratteristiche", [
                "Doppio flusso: manuale (utente) e schedulato (Hangfire).",
                "Validazione sintattica e semantica query.",
                "Normalizzazione nomi operatori prima del salvataggio.",
                "Rimozione selettiva dei dati auto-generati nel range, senza toccare quelli manuali.",
                "Isolamento per centro: un task Genova non tocca i dati Verona.",
                "Logging strutturato con misurazione dei tempi."]));
            s.Subsections.Add(new("Flusso Principale", [
                "1. Recupero configurazione Task.",
                "2. Determinazione intervallo date (manuale o da GiorniPrecedenti).",
                "3. Acquisizione dati: handler integrato o query SQL parametrica.",
                "4. Normalizzazione e Elaborazione (ElaboraDatiLavorazioneAsync).",
                "5. Pulizia record auto nel periodo e inserimento nuovi (per centro).",
                "6. Salvataggio esito su TaskDataReadingAggiornamento."]));
            s.Subsections.Add(new("Come vengono calcolate le date di lettura", [
                "GiorniPrecedenti indica quanti giorni a ritroso rispetto a oggi vengono letti (es. 10 = ultimi 10 giorni).",
                "E' possibile sovrascrivere le date manualmente in modalita esecuzione manuale del Task.",
                "Le date sono normalizzate a giornata intera: @startDate = inizio giornata, @endDate = fine giornata."]));
            s.Subsections.Add(new("Scrittura query - parametri data disponibili", [
                "Il sistema inietta automaticamente quattro parametri data nella query a ogni esecuzione. L'autore della query sceglie quali usare in base al tipo della colonna nella fonte dati.",
                "Parametro @startDate (DateTime2): inizio giornata (es. 2024-01-15 00:00:00). Usare per colonne date / datetime / datetime2.",
                "Parametro @endDate (DateTime2): fine giornata (es. 2024-01-25 23:59:59.999). Usare per colonne date / datetime / datetime2.",
                "Parametro @startDateStr (VarChar 10): data inizio in formato 'yyyy-MM-dd'. Usare per colonne varchar che contengono date testuali.",
                "Parametro @endDateStr (VarChar 10): data fine in formato 'yyyy-MM-dd'. Usare per colonne varchar che contengono date testuali.",
                "IMPORTANTE: tutti e quattro i parametri vengono sempre iniettati. SQL Server ignora quelli non referenziati nel testo della query. Non e necessario dichiarare quelli inutilizzati."]));
            s.Subsections.Add(new("Esempi WHERE per tipo colonna", [
                "<div style='margin:4px 0 8px 0;'>" +
                "<div style='font-weight:600;margin-bottom:4px;'>Caso 1 - Colonna datetime / date / datetime2 (piu comune)</div>" +
                "<div class='diagram-block'>SELECT\n    OP_INDEX        AS Operatore,\n    DATA_INDEX      AS DataLavorazione,\n    COUNT(*)        AS Documenti,\n    SUM(NUM_FOGLI)  AS Fogli,\n    SUM(NUM_PAGINE) AS Pagine\nFROM dbo.TABELLA_PRODUZIONE\nWHERE DATA_INDEX >= @startDate\n  AND DATA_INDEX &lt;= @endDate\nGROUP BY OP_INDEX, DATA_INDEX</div>" +
                "<div style='font-weight:600;margin:8px 0 4px 0;'>Caso 2 - Colonna varchar con formato 'yyyy-MM-dd' (fonte legacy)</div>" +
                "<div class='diagram-block'>SELECT\n    OPERATORE          AS Operatore,\n    DATA_LAVORAZIONE   AS DataLavorazione,\n    COUNT(*)           AS Documenti,\n    SUM(NUM_FOGLI)     AS Fogli,\n    SUM(NUM_PAGINE)    AS Pagine\nFROM dbo.TABELLA_LEGACY\nWHERE DATA_LAVORAZIONE >= @startDateStr\n  AND DATA_LAVORAZIONE &lt;= @endDateStr\nGROUP BY OPERATORE, DATA_LAVORAZIONE</div>" +
                "<div style='background:#e3f2fd;border-left:4px solid #1565c0;padding:8px 12px;border-radius:3px;margin-top:8px;font-size:12px;'>" +
                "<strong>Come scegliere:</strong> verificare il tipo della colonna data nella tabella sorgente.<br/>" +
                "Se il tipo e <strong>date / datetime / datetime2 / smalldatetime</strong> → usare <strong>@startDate / @endDate</strong>.<br/>" +
                "Se il tipo e <strong>varchar / nvarchar</strong> con valori come '2024-01-15' → usare <strong>@startDateStr / @endDateStr</strong>." +
                "</div></div>"], true));
            s.Subsections.Add(new("Diagramma reperimento dati", [
                "<div class='diagram-block'>  [GiorniPrecedenti = 10]    [Date manuali utente]\n           |                          |\n           v                          v\n    oggi - 10 giorni             data scelta\n           |__________________________|                        \n                        |\n                        v\n             [Calcolo intervallo date]\n             @startDate = inizio giornata\n             @endDate   = fine giornata\n                        |\n            ____________|____________\n           |                        |\n           v                        v\n      [Query SQL]           [Handler Integrato]\n      col >= @startDate     Legge tabella dati\n      col <= @endDate       Filtra per date\n           |____________________|                              \n                        |\n                        v\n              [Dati grezzi acquisiti]\n                        |\n                        v\n         [Normalizzazione Operatori]\n         Operatore nel centro    --> incluso\n         Operatore altro centro  --> escluso\n         Operatore sconosciuto   --> Not_Found_Oper\n                        |\n                        v\n           [ProduzioneSistema aggiornata]</div>"], true));
            s.Subsections.Add(new("Diagramma Pipeline Completa", [
                "<div class='diagram-block'>Start\n  |\n  v\n[Recupero Task]\n  |\n  v\n[Calcolo date effettive]\n  |\n  +--> [Handler Integrato] ---+\n  |                           |\n  +--> [Query SQL]  ----------+\n                              |\n                              v\n               [ElaboraDatiLavorazioneAsync]\n                  |-- Operatore nel centro   --> Inserito\n                  |-- Operatore altro centro --> Escluso\n                  |-- Operatore sconosciuto  --> Not_Found_Oper\n                              |\n                              v\n               [PersistProduzioneSistema]\n                              |\n                              v\n               [Salvataggio esito su DB]\n                              |\n                              v\n                            Fine</div>"], true));
