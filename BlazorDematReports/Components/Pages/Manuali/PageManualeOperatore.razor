@page "/manuale-operatore"
@attribute [Authorize(Roles = "OWNER, ADMIN, SUPERVISOR,CAPOTURNO, USER")]
@inject IJSRuntime JSRuntime
@inject BlazorDematReports.Services.IPdfExportService PdfExportService
@using System.Text.RegularExpressions

<MudText Typo="Typo.h4" Class="titolo ml-4">Manuale Operatore</MudText>
<MudDivider Class="border-solid border-1 mud-border-primary" />

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    @if (isLoading)
    {
        <MudProgressCircular Indeterminate="true" />
        <MudText>Caricamento manuale operatore...</MudText>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-4" AlignItems="AlignItems.Center">
            <MudItem xs="12" md="9">
                <MudExpansionPanels>
                    <MudExpansionPanel Text="Indice Sezioni">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var s in manualSections)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="MudBlazor.Color.Primary"
                                           Size="Size.Small"
                                           Class="@(activeSectionId == s.Id ? "indice-attivo" : "")"
                                           OnClick="@(() => ScrollToSection(s.Id))">
                                    @s.Number @s.Title
                                </MudButton>
                            }
                        </div>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           OnClick="ExportToPdf"
                           FullWidth="true"
                           Disabled="@isExportingPdf">
                    @if (isExportingPdf)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <span class="ml-2">Esportando...</span>
                    }
                    else
                    {
                        <span>Esporta PDF</span>
                    }
                </MudButton>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4"
                  Elevation="2"
                  Style="max-height:80vh; overflow-y:auto; font-size:14px; scroll-behavior:smooth; position:relative;"
                  id="manuale-operatore-content">
            <div class="manuale-operatore-html">
                @((MarkupString)manualHtml)
            </div>
        </MudPaper>
    }
</MudContainer>

<style>
    .manuale-sezione-titolo { margin-top:30px; margin-bottom:6px; font-weight:600; font-size:18px; }
    .manuale-sottotitolo    { margin-top:16px; font-weight:600; font-size:15px; }
    .manuale-paragrafo      { margin:2px 0 10px 0; line-height:1.55; }
    .indice-attivo          { border-color: var(--mud-palette-primary)!important; font-weight:600; }
    .section-selected       { outline:2px solid var(--mud-palette-primary); background:rgba(0,123,255,.08); border-radius:4px; }
    .anchor-offset          { position:relative; top:-70px; visibility:hidden; }
    .diagram-block          { font-family:monospace; white-space:pre; background:#f5f5f5; padding:12px; border-radius:4px; overflow-x:auto; font-size:12px; margin:8px 0; }
</style>

@code {
    private sealed class ManualSection
    {
        public string Id     { get; init; } = Guid.NewGuid().ToString("N");
        public string Number { get; set; }  = string.Empty;
        public string Title  { get; set; }  = string.Empty;
        public List<string>           Paragraphs  { get; } = new();
        public List<ManualSubSection> Subsections { get; } = new();
    }

    private sealed class ManualSubSection(string title, List<string> lines, bool rawHtml = false)
    {
        public string       Title   { get; } = title;
        public List<string> Lines   { get; } = lines;
        public bool         RawHtml { get; } = rawHtml;
    }

    private string              errorMessage    = string.Empty;
    private bool                isLoading       = true;
    private bool                isExportingPdf  = false;
    private string              activeSectionId = string.Empty;
    private List<ManualSection> manualSections  = new();
    private string              manualHtml      = string.Empty;

    protected override Task OnInitializedAsync()
    {
        try
        {
            manualSections = BuildOperatorManualSections();
            manualHtml     = BuildHtmlFromSections(manualSections);
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore durante il caricamento del manuale operatore: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
        return Task.CompletedTask;
    }

    private async Task ScrollToSection(string id)
    {
        activeSectionId = id;
        await JSRuntime.InvokeVoidAsync("scrollToManualSection", "manuale-operatore-content", id);
    }

    private async Task ExportToPdf()
    {
        isExportingPdf = true;
        StateHasChanged();
        try
        {
            var plain    = Regex.Replace(manualHtml, "<[^>]+>", string.Empty);
            var fileName = $"Manuale_Operatore_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";
            var pdfBytes = await PdfExportService.GeneratePdfFromTextAsync(plain, "MANUALE OPERATORE");
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(pdfBytes), "application/pdf");
            await JSRuntime.InvokeVoidAsync("showNotification", "Manuale operatore esportato con successo!", "success");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("showNotification", $"Errore esportazione PDF: {ex.Message}", "error");
        }
        finally
        {
            isExportingPdf = false;
            StateHasChanged();
        }
    }

    private static List<ManualSection> BuildOperatorManualSections()
    {
        var list = new List<ManualSection>();
        int n    = 0;

        ManualSection Add(string title, Action<ManualSection> build)
        {
            n++;
            var sec = new ManualSection { Number = n + ".", Title = title, Id = "sec-op-" + n };
            build(sec);
            list.Add(sec);
            return sec;
        }

        Add("INTRODUZIONE", s =>
        {
            s.Paragraphs.Add("DeaggiornamatReports consente agli operatori di inserire, controllare e analizzare la produzione documentale giornaliera.");
            s.Subsections.Add(new("Scopo", [
                "Guidare l'utente nell'utilizzo quotidiano della piattaforma.",
                "Descrivere flussi base e funzioni chiave."]));
            s.Subsections.Add(new("Ruoli", [
                "USER: inserimento e consultazione della propria produzione.",
                "CAPOTURNO: supervisione turno e accesso ai report.",
                "SUPERVISOR / ADMIN: configurazioni complete e gestione utenti.",
                "RESPONSABILE: governance e controllo qualità."]));
        });

        Add("ACCESSO E NAVIGAZIONE", s =>
        {
            s.Subsections.Add(new("Requisiti", [
                "Browser moderno (Edge / Chrome / Firefox).",
                "Credenziali fornite dall'amministratore.",
                "Connessione di rete stabile."]));
            s.Subsections.Add(new("Login", [
                "Aprire l'URL aziendale della piattaforma.",
                "Inserire username e password.",
                "Verificare il ruolo visualizzato nella barra superiore."]));
            s.Subsections.Add(new("Layout", [
                "Menu laterale: accesso a tutte le funzioni disponibili per il proprio ruolo.",
                "Barra superiore: informazioni utente e logout.",
                "Area centrale: pagine operative."]));
        });

        Add("FUNZIONALITA PER RUOLO", s =>
        {
            s.Subsections.Add(new("User", [
                "Carica Dati produzione.",
                "Visualizza e gestisce la propria produzione.",
                "Consulta manuali."]));
            s.Subsections.Add(new("Capoturno", [
                "Tutte le funzioni User.",
                "Report lavorazioni e scheda lavorazione.",
                "Gestione operatori e grafici produzione."]));
            s.Subsections.Add(new("Supervisor / Admin", [
                "Configurazioni avanzate e gestione fonti dati.",
                "Gestione ruoli e utenti.",
                "Task background e Data Manager."]));
        });

        Add("INSERIMENTO PRODUZIONE", s =>
        {
            s.Subsections.Add(new("Carica Dati - Procedura", [
                "1. Aprire Produzione -> Carica Dati.",
                "2. Selezionare la data di lavorazione e l'operatore.",
                "3. Scegliere la lavorazione e la fase.",
                "4. Inserire i valori (Documenti / Fogli / Pagine / Scarti).",
                "5. Salvare — il sistema verifica duplicati e campi obbligatori."]));
            s.Subsections.Add(new("Validazioni", [
                "Campi obbligatori richiesti.",
                "Nessun valore negativo.",
                "Almeno un totale > 0.",
                "Controllo univocita (data + operatore + fase)."]));
            s.Subsections.Add(new("Errori Comuni", [
                "Record duplicato -> verificare se gia inserito per quella data.",
                "Campi disabilitati -> completare i dati richiesti precedenti.",
                "Valori respinti -> controllare il formato numerico."]));
        });

        Add("GESTIONE OPERATORI", s =>
        {
            s.Paragraphs.Add("Disponibile per Supervisori e ruoli superiori. Consente l'analisi della produttivita e il rilevamento di anomalie.");
            s.Subsections.Add(new("Passi", [
                "Accedere a Produzione -> Gestione Operatori.",
                "Impostare l'intervallo date.",
                "Filtrare per centro.",
                "Analizzare gli indicatori aggregati."]));
            s.Subsections.Add(new("Output", [
                "Totali per operatore.",
                "Anomalie evidenziate.",
                "Aggregati per centro."]));
        });

        Add("REPORT E GRAFICI", s =>
        {
            s.Subsections.Add(new("Report Totali", [
                "Selezionare intervallo date e filtri.",
                "Export in Excel o PDF.",
                "Visualizzazione aggregati per lavorazione."]));
            s.Subsections.Add(new("Report Completo", [
                "Dettaglio riga per riga della produzione.",
                "Analisi performance per operatore."]));
            s.Subsections.Add(new("Grafico Produzione", [
                "Distribuzione e trend temporali.",
                "Filtri dinamici interattivi.",
                "Supporto decisionale rapido."]));
        });

        Add("CONFIGURAZIONI", s =>
        {
            s.Subsections.Add(new("Anagrafiche", [
                "Centri, Clienti, Operatori.",
                "Gestibili da Supervisor e Admin."]));
            s.Subsections.Add(new("Lavorazioni", [
                "Procedure e Fasi.",
                "Mapping fasi-totali."]));
            s.Subsections.Add(new("Normalizzazione Operatori", [
                "Mappatura alias verso identita operatore.",
                "Garantisce coerenza dei nomi nelle elaborazioni."]));
        });

        Add("LETTORE DATI", s =>
        {
            s.Paragraphs.Add("Servizio applicativo responsabile dell'acquisizione, normalizzazione ed inserimento automatico dei dati di produzione tramite pipeline Hangfire.");
            s.Subsections.Add(new("Scopo", [
                "Recuperare dati grezzi da query parametrizzate o handler integrati.",
                "Applicare normalizzazioni operatori e regole di business.",
                "Persistere su ProduzioneSistema evitando duplicati e preservando inserimenti manuali.",
                "Tracciare l'esito delle operazioni su TaskDataReadingAggiornamento."]));
            s.Subsections.Add(new("Caratteristiche", [
                "Doppio flusso: manuale (utente) e schedulato (Hangfire).",
                "Validazione sintattica e semantica query.",
                "Normalizzazione nomi operatori prima del salvataggio.",
                "Rimozione selettiva dei dati auto-generati nel range, senza toccare quelli manuali.",
                "Isolamento per centro: un task Genova non tocca i dati Verona.",
                "Logging strutturato con misurazione dei tempi."]));
            s.Subsections.Add(new("Flusso Principale", [
                "1. Recupero configurazione Task.",
                "2. Determinazione intervallo date (manuale o da GiorniPrecedenti).",
                "3. Acquisizione dati: handler integrato o query SQL parametrica.",
                "4. Normalizzazione e Elaborazione (ElaboraDatiLavorazioneAsync).",
                "5. Pulizia record auto nel periodo e inserimento nuovi (per centro).",
                "6. Aggiornamento campo elaborato_demat_reports_il sulla tabella sorgente.",
                "7. Salvataggio esito su TaskDataReadingAggiornamento."]));
            s.Subsections.Add(new("Diagramma Flusso", [
                "<div class='diagram-block'>Start\n  |\n  v\n[Recupero Task]\n  |\n  v\n[Calcolo date effettive]\n  |\n  +--> [Handler Integrato] ---+\n  |                           |\n  +--> [Query SQL]  ----------+\n                              |\n                              v\n               [ElaboraDatiLavorazioneAsync]\n                  |-- Operatore nel centro   --> Inserito\n                  |-- Operatore altro centro --> Escluso\n                  |-- Operatore sconosciuto  --> Not_Found_Oper\n                              |\n                              v\n               [PersistProduzioneSistema]\n                              |\n                              v\n               [Marca elaborato_demat_reports_il]\n                              |\n                              v\n                            Fine</div>"], true));
            s.Subsections.Add(new("Note Operative", [
                "I record inseriti manualmente non vengono mai sovrascritti dal servizio automatico.",
                "Intervalli di lettura ampi aumentano il tempo di elaborazione: usare range mirati.",
                "In caso di errori ripetuti verificare la query e i parametri CRON del task.",
                "Dopo ogni elaborazione il campo elaborato_demat_reports_il viene aggiornato sulla tabella sorgente (HERA16, ADER4)."]));
        });

        Add("RISOLUZIONE PROBLEMI", s =>
        {
            s.Subsections.Add(new("Accesso", [
                "Impossibile eseguire il login -> verificare credenziali e connessione di rete.",
                "Menu ridotto -> controllare il ruolo assegnato al proprio account."]));
            s.Subsections.Add(new("Inserimento", [
                "Duplicato -> il record esiste gia per quella data, modificare quello esistente.",
                "Validazione fallita -> verificare tutti i campi obbligatori."]));
            s.Subsections.Add(new("Performance", [
                "Report lento -> ridurre l'intervallo date o applicare filtri piu selettivi.",
                "UI lenta -> chiudere le schede non necessarie del browser."]));
        });

        Add("BEST PRACTICES", s =>
        {
            s.Subsections.Add(new("Inserimento Dati", [
                "Registrare la produzione giornalmente.",
                "Verificare i valori prima del salvataggio.",
                "Evitare l'accumulo di arretrato."]));
            s.Subsections.Add(new("Utilizzo Report", [
                "Applicare filtri mirati per ridurre i tempi di caricamento.",
                "Esportare periodicamente i report rilevanti.",
                "Condividere solo le informazioni strettamente necessarie."]));
        });

        Add("WORKFLOW TIPICI", s =>
        {
            s.Subsections.Add(new("Operatore", [
                "Login.",
                "Apertura Carica Dati.",
                "Inserimento produzione giornaliera.",
                "Verifica dati salvati.",
                "Logout."]));
            s.Subsections.Add(new("Capoturno", [
                "Login.",
                "Analisi produzione del team.",
                "Generazione report turno.",
                "Correzioni e validazioni.",
                "Logout."]));
            s.Subsections.Add(new("Amministratore", [
                "Verifica stato job schedulati.",
                "Gestione utenti e ruoli.",
                "Aggiornamento configurazioni e fonti dati."]));
        });

        Add("GLOSSARIO", s =>
        {
            s.Subsections.Add(new("Termini", [
                "Centro: unita organizzativa (es. Genova, Verona).",
                "Fase: singolo step di una lavorazione.",
                "Lavorazione: tipologia di processo documentale.",
                "Normalizzazione: standardizzazione dei nomi operatore.",
                "Totali: KPI aggregati (Documenti, Fogli, Pagine).",
                "Turno: finestra temporale operativa.",
                "Not_Found_Oper: operatore presente nei dati ma non censito in anagrafica."]));
        });

        Add("SUPPORTO", s =>
        {
            s.Subsections.Add(new("Contatti", [
                "Email supporto: <inserire>",
                "Telefono: <inserire>",
                "Orari di disponibilita: <inserire>"]));
            s.Subsections.Add(new("In caso di emergenza", [
                "Documentare il problema con screenshot.",
                "Contattare il supporto tecnico.",
                "Non modificare configurazioni critiche senza autorizzazione."]));
        });

        return list;
    }

    private static string BuildHtmlFromSections(List<ManualSection> sections)
    {
        var sb = new System.Text.StringBuilder();
        foreach (var s in sections)
        {
            sb.AppendLine($"<div class='manuale-sezione' id='{s.Id}'>");
            sb.AppendLine($"<a class='anchor-offset' id='{s.Id}-anchor'></a>");
            sb.AppendLine($"<div class='manuale-sezione-titolo'>{s.Number} {Encode(s.Title)}</div>");
            foreach (var p in s.Paragraphs)
                sb.AppendLine($"<div class='manuale-paragrafo'>{Encode(p)}</div>");
            foreach (var sub in s.Subsections)
            {
                var subId = $"{s.Id}-{Slug(sub.Title)}";
                sb.AppendLine($"<div class='manuale-sottotitolo' id='{subId}'>{Encode(sub.Title)}</div>");
                foreach (var line in sub.Lines)
                    sb.AppendLine(sub.RawHtml ? line : $"<div class='manuale-paragrafo'>{Encode(line)}</div>");
            }
            sb.AppendLine("</div>");
        }
        sb.AppendLine("<div class='manuale-paragrafo' style='margin-top:35px;font-style:italic;'>Fine manuale operatore.</div>");
        return sb.ToString();
    }

    private static string Encode(string s) => System.Web.HttpUtility.HtmlEncode(s);
    private static string Slug(string s)   => Regex.Replace(s.ToLowerInvariant(), "[^a-z0-9]+", "-").Trim('-');
}

<script>
    window.scrollToManualSection = (containerId, sectionId) => {
        const container = document.getElementById(containerId);
        const element   = document.getElementById(sectionId);
        if (container && element) {
            container.scrollTo({ top: element.offsetTop - 10, behavior: 'smooth' });
            element.classList.add('section-selected');
            setTimeout(() => element.classList.remove('section-selected'), 2000);
        }
    };
    window.downloadFile = (fileName, base64Data, contentType) => {
        const a    = document.createElement('a');
        a.href     = `data:${contentType};base64,${base64Data}`;
        a.download = fileName;
        a.click();
    };
    window.showNotification = (m, t) => { t === 'success' ? console.log(m) : console.error(m); };
</script>
