        Add("INSTALLAZIONE E CONFIGURAZIONE", s =>
        {
            s.Paragraphs.Add("Istruzioni per predisporre l'ambiente di sviluppo e produzione.");
            s.Subsections.Add(new ManualSubSection("Prerequisiti", new List<string>{
                ".NET 10 SDK + Runtime.",
                "SQL Server 2019+ (database applicativo + database Hangfire).",
                "Visual Studio 2022/2026 o dotnet CLI.",
                "Accesso SMTP o Exchange (EWS) per ingestion mail (opzionale in Development)."}));
            s.Subsections.Add(new ManualSubSection("Configurazione appsettings", new List<string>{
                "ConnectionStrings:DematReportsContext — SQL Server applicativo.",
                "ConnectionStrings:HangfireConnection — SQL Server per Hangfire (può coincidere con il principale).",
                "LoginSettings:DefaultTestUser / DefaultTestPassword — utente mock per Development.",
                "LoginSettings:AllowAutoLogin — true in Development per login automatico.",
                "ActiveDirectory:Domain/SearchBase/ServiceAccount — solo in produzione.",
                "MailServices:ADER4:UseMockService / HERA16:UseMockService — true = CSV locale, false = EWS reale."}));
            s.Subsections.Add(new ManualSubSection("Variabili Ambiente (Produzione)", new List<string>{
                "ASPNETCORE_ENVIRONMENT = Production",
                "ConnectionStrings__DematReportsContext = <conn_string>",
                "ConnectionStrings__HangfireConnection = <conn_string>",
                "Le variabili ambiente sovrascrivono appsettings.json (caricamento in AddEnvironmentVariables)."}));
            s.Subsections.Add(new ManualSubSection("Avvio e Diagnostica Startup", new List<string>{
                "All'avvio, RunStartupDiagnosticsAsync verifica connettività DB e stato Hangfire.",
                "SyncRecurringJobsAsync sincronizza i job Hangfire con i TaskDaEseguire attivi nel DB.",
                "ScheduleSystemJobs registra job di sistema (es. pulizia, aggiornamenti).",
                "ScheduleMailIngestion registra job di ingestion mail ADER4 e HERA16.",
                "In caso di errore fatale all'avvio, NLog registra l'eccezione prima dello shutdown."}));
            s.Subsections.Add(new ManualSubSection("Autorizzazioni IIS - Cartella Log", new List<string>{
                "NLog scrive, ruota e rimuove automaticamente i file di log. " +
                "Per garantire il corretto funzionamento del rolling e dell'eliminazione dei file scaduti, " +
                "l'account del pool applicativo IIS deve avere il permesso <strong>Modifica (Modify)</strong> " +
                "sulla cartella radice dei log e su tutte le sottocartelle.",
                "Cartella radice log (come configurata in nlog.config): <code>C:\\LogWebApp\\DematReports\\</code>",
                "<table class='manual-table'>" +
                "<thead><tr><th>Account</th><th>Permesso richiesto</th><th>Applicare su</th><th>Motivo</th></tr></thead><tbody>" +
                "<tr><td>IIS AppPool\\&lt;NomePool&gt;</td><td><strong>Modifica (Modify)</strong></td>" +
                "<td>Cartella radice + sottocartelle + file (ereditato)</td>" +
                "<td>Crea file .log, scrittura in tempo reale, rolling archivio, eliminazione file oltre maxArchiveFiles</td></tr>" +
                "<tr><td>SYSTEM</td><td>Controllo completo</td><td>Cartella radice + ereditato</td>" +
                "<td>Operazioni di sistema, backup automatizzato, raccolta log schedulata</td></tr>" +
                "<tr><td>Administrators</td><td>Controllo completo</td><td>Cartella radice + ereditato</td>" +
                "<td>Raccolta manuale, ispezione, eliminazione batch log scaduti</td></tr>" +
                "</tbody></table>",
                "<strong>Attenzione:</strong> il permesso Modifica include gia Lettura + Scrittura + Eliminazione. " +
                "NON usare solo Scrittura (Write): NLog non riuscirebbe a eliminare i file in fase di rolling " +
                "(parametro <code>maxArchiveFiles</code> in nlog.config).",
                "<strong>Struttura sottocartelle — i permessi si ereditano automaticamente dalla radice:</strong>",
                "<div class='diagram-block'>C:\\LogWebApp\\DematReports\\\n" +
                "  blazor-demat-{shortdate}.log       log principale applicativo\n" +
                "  internal\\                          log interno NLog diagnostics\n" +
                "  errors\\\n" +
                "    sql\\                             SqlException, timeout, DbUpdateException\n" +
                "    validation\\                      errori validazione / business logic\n" +
                "    background-tasks\\                Hangfire, job falliti\n" +
                "    critical\\                        Fatal, eccezioni non gestite\n" +
                "  hangfire\\                          log operativo Hangfire\n" +
                "  database\\                          query SQL tracciate\n" +
                "  data-reading\\                      ingestion CSV e mail\n" +
                "  archives\\                          file ruotati dal rolling NLog\n" +
                "    errors\\  hangfire\\  database\\  data-reading\\</div>"
            }, true));
            s.Subsections.Add(new ManualSubSection("Flusso Deploy Produzione", new List<string>{
                "<div class='diagram-block'>[dotnet publish]\n   v\n[Copia artefatti su server IIS]\n   v\n[Variabili ambiente impostate su server]\n   v\n[Permessi Modify su C:\\LogWebApp\\DematReports (vedi sezione precedente)]\n   v\n[iisreset / recycle app pool]\n   v\n[Startup diagnostics verifica DB + Hangfire]\n   v\n[SyncRecurringJobs: allinea job con DB]\n   v\n[App operativa]</div>"}, true));
        });

        // 10 RISOLUZIONE DEI PROBLEMI
        Add("RISOLUZIONE DEI PROBLEMI", s =>
        {
            s.Paragraphs.Add("Problemi comuni con cause e soluzioni. Controllare sempre prima i log NLog e Hangfire Dashboard.");
            var tableHtml =
                "<table class='manual-table'><thead><tr><th>Problema</th><th>Causa Probabile</th><th>Soluzione</th></tr></thead><tbody>" +
                "<tr><td>Job non esegue</td><td>Task disabilitato o Hangfire fermo</td><td>Verificare Enabled=true in TaskDaEseguire; controllare /hangfire</td></tr>" +
                "<tr><td>Not_Found_Oper nei dati</td><td>Alias operatore non censito</td><td>Aggiungere mapping in Normalizzazione Operatori, poi rieseguire job</td></tr>" +
                "<tr><td>Duplicati produzione</td><td>Job rieseguito sullo stesso range</td><td>Normale: il sistema fa upsert, non duplica. Verificare vincolo UNIQUE</td></tr>" +
                "<tr><td>Connessione DB fallita</td><td>Connection string errata o firewall</td><td>Verificare ConnectionStrings in appsettings / variabili ambiente</td></tr>" +
                "<tr><td>Query SQL rifiutata</td><td>Validazione sicurezza / colonne mancanti</td><td>Aggiungere @startDate/@endDate e colonne obbligatorie; no SELECT *</td></tr>" +
                "<tr><td>Handler non trovato</td><td>Codice non registrato in DI</td><td>Aggiungere AddSingleton in Program.cs; verificare Code univoco</td></tr>" +
                "<tr><td>Login fallisce in dev</td><td>AllowAutoLogin=false o credenziali errate</td><td>Verificare DefaultTestUser/Password in appsettings.Development.json</td></tr>" +
                "<tr><td>Grafico clienti vuoto</td><td>Nessun dato nel periodo / config mancante</td><td>Verificare ConfigReportDocumenti e ProcedureCliente attivi</td></tr>" +
                "<tr><td>Email non elaborata</td><td>EWS non raggiungibile o mock disattivo</td><td>In dev: UseMockService=true; in prod: verificare credenziali EWS</td></tr>" +
                "<tr><td>Wizard non salva</td><td>Validazione step non superata</td><td>Verificare IsStepValid per ogni step: tipo, connessione, procedura, mappings</td></tr>" +
                "</tbody></table>";
            s.Subsections.Add(new ManualSubSection("Tabella Problemi", new List<string>{ tableHtml }, true));
        });

