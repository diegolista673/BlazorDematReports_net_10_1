@page "/manuale-tecnico"

@attribute [Authorize(Roles = "OWNER, ADMIN, SUPERVISOR,CAPOTURNO, USER")]
@inject IWebHostEnvironment WebHostEnvironment
@inject IJSRuntime JSRuntime
@using System.IO
@using System.Text.RegularExpressions
@using System.Text
@using DocumentFormat.OpenXml.Packaging
@using DocumentFormat.OpenXml.Wordprocessing

<MudText Typo="Typo.h4" Class="titolo ml-4">Manuale Tecnico</MudText>
<MudDivider Class="border-solid border-1 mud-border-primary "></MudDivider>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    @if (isLoading)
    {
        <MudProgressCircular Indeterminate="true" />
        <MudText>Caricamento manuale tecnico...</MudText>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-4">
            <MudItem xs="12" md="9">
                <MudExpansionPanels>
                    <MudExpansionPanel Text="Indice Sezioni">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var s in manualSections)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="MudBlazor.Color.Primary"
                                           Size="Size.Small"
                                           Class="@GetSectionClass(s.Id)"
                                           OnClick="@(() => ScrollToSection(s.Id))">
                                    @s.Number @s.Title
                                </MudButton>
                            }
                        </div>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           StartIcon="@Icons.Material.Filled.Print"
                           OnClick="PrintAsync"
                           FullWidth="true">
                    Stampa / Salva PDF
                </MudButton>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4" Elevation="2" Style="max-height: 80vh; overflow-y: auto; font-size:14px; scroll-behavior:smooth; position:relative;" id="manuale-tecnico-content">
@*             <div class="print-header">
                <h1>DematReports &mdash; Manuale Tecnico</h1>
            </div> *@
            <div class="manuale-tecnico-html">
                @((MarkupString)manualHtml)
            </div>
        </MudPaper>
    }
</MudContainer>

<style>
    /* --- Stili schermo --- */
    .manuale-sezione-titolo { margin-top:34px; margin-bottom:8px; font-weight:600; font-size:18px; }
    .manuale-sottotitolo    { margin-top:18px; font-weight:600; font-size:15px; }
    .manuale-paragrafo      { margin:2px 0 10px 0; line-height:1.55; }
    .section-selected       { outline:2px solid var(--mud-palette-primary); background:rgba(0,123,255,.06); border-radius:4px; transition:background .6s; }
    .indice-attivo          { border-color: var(--mud-palette-primary)!important; font-weight:600; }
    .anchor-offset          { position:relative; top:-70px; visibility:hidden; }
    .manual-table           { border-collapse:collapse; width:100%; margin:10px 0 18px 0; font-size:13px; }
    .manual-table th,
    .manual-table td        { border:1px solid #ccc; padding:6px 8px; vertical-align:top; }
    .manual-table th        { background:#f5f5f5; text-align:left; }
    .diagram-block          { font-family:Consolas,monospace; background:#fafafa; border:1px solid #e0e0e0; padding:8px; border-radius:4px; font-size:12px; white-space:pre; overflow:auto; margin:6px 0 14px 0; }
    .print-header           { display:none; }

    /* --- Stili stampa / PDF (window.print) --- */
    @@media print {
        .mud-appbar, .mud-drawer, .mud-drawer-overlay,
        .mud-expansion-panels, .mb-4,
        .mud-button-root, .mud-snackbar-container { display: none !important; }

        .print-header { display:block !important; text-align:center; margin-bottom:24px; border-bottom:2px solid #333; padding-bottom:10px; }
        .print-header h1 { font-size:18pt; font-weight:700; margin:0 0 4px 0; }
        .print-header p  { font-size:9pt;  color:#555;  margin:0; }

        #manuale-tecnico-content {
            max-height: none    !important;
            overflow:   visible !important;
            box-shadow: none    !important;
            border:     none    !important;
            padding:    0       !important;
        }

        .diagram-block,
        .manual-table            { page-break-inside: avoid; }
        .manuale-sezione-titolo  { page-break-after: avoid; font-size:14pt; }
        .manuale-sottotitolo     { page-break-after: avoid; font-size:11pt; }
        .manuale-paragrafo       { font-size:10pt; line-height:1.4; }
        .diagram-block           { white-space:pre-wrap; overflow-x:visible; font-size:8pt; }

        @@page { margin: 1.5cm 2cm; }
    }
</style>

@code {
    private class ManualSection
    {
        public string Id { get; set; } = Guid.NewGuid().ToString("N");
        public string Number { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public List<string> Paragraphs { get; set; } = new();
        public List<ManualSubSection> Subsections { get; set; } = new();
    }
    private class ManualSubSection
    {
        public ManualSubSection(string title, List<string> lines, bool rawHtml = false){ Title = title; Lines = lines; RawHtml = rawHtml; }
        public string Title { get; set; }
        public List<string> Lines { get; set; }
        public bool RawHtml { get; set; }
    }

    private string              errorMessage    = string.Empty;
    private bool                isLoading       = true;
    private string              activeSectionId = string.Empty;
    private List<ManualSection> manualSections  = new();
    private string              manualHtml      = string.Empty;

    private readonly string[] docFiles = new[] { "Documentazione/Scopo del programma.docx", "Documentazione/LettoreDati.docx" };

    protected override async Task OnInitializedAsync() => await LoadManualeContent();

    private async Task LoadManualeContent()
    {
        try
        {
            isLoading      = true;
            manualSections = GenerateSectionsDetailed();
            await IntegrateExternalDocumentsAsync();
            manualHtml     = BuildHtmlFromSections(manualSections);
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore durante il caricamento del manuale tecnico: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task IntegrateExternalDocumentsAsync()
    {
        var allegati = new ManualSection { Number = (manualSections.Count + 1) + ".", Title = "ALLEGATI DOCUMENTAZIONE", Id = "sec-allegati" };
        foreach (var relative in docFiles)
        {
            try
            {
                var abs = Path.Combine(WebHostEnvironment.ContentRootPath, "BlazorDematReports", relative.Replace('/', Path.DirectorySeparatorChar));
                if (!File.Exists(abs))
                {
                    allegati.Subsections.Add(new ManualSubSection(Path.GetFileName(relative), new List<string>{ "File non trovato: " + relative }));
                    continue;
                }
                var text = await Task.Run(() => ReadDocxPlainText(abs));
                var cleaned = NormalizeDocText(text);
                var preview = cleaned.Length > 2000 ? cleaned.Substring(0, 2000) + "..." : cleaned;
                var lines = preview.Split('\n', StringSplitOptions.RemoveEmptyEntries).Take(12).ToList();
                lines.Insert(0, "Estratto del documento (max 2000 caratteri / 12 paragrafi):");
                allegati.Subsections.Add(new ManualSubSection(Path.GetFileNameWithoutExtension(relative), lines));
            }
            catch (Exception ex)
            { allegati.Subsections.Add(new ManualSubSection(Path.GetFileName(relative) + " (errore)", new List<string>{ ex.Message })); }
        }
        manualSections.Add(allegati);
    }

    private string ReadDocxPlainText(string path)
    {
        var sb = new StringBuilder();
        using var doc = WordprocessingDocument.Open(path, false);
        var body = doc.MainDocumentPart?.Document?.Body;
        if (body == null) return string.Empty;
        foreach (var para in body.Elements<Paragraph>())
        {
            var text = string.Concat(para.Descendants<Text>().Select(t => t.Text));
            if (!string.IsNullOrWhiteSpace(text)) sb.AppendLine(text.Trim());
        }
        return sb.ToString();
    }

    private string NormalizeDocText(string input)
    { var norm = Regex.Replace(input, "[\r\t]", ""); norm = Regex.Replace(norm, " +", " "); return norm.Trim(); }

    private List<ManualSection> GenerateSectionsDetailed()
    {
        var list = new List<ManualSection>();
        int n = 0;
        ManualSection Add(string title, Action<ManualSection> build)
        { n++; var sec = new ManualSection { Number = n + ".", Title = title, Id = "sec-" + n }; build(sec); list.Add(sec); return sec; }

        // 1 INTRODUZIONE
        Add("INTRODUZIONE", s =>
        {
            s.Paragraphs.Add("DematReports (BlazorDematReports) è una piattaforma Blazor Server .NET 10 per la gestione, normalizzazione e analisi della produzione documentale multicentro.");
            s.Paragraphs.Add("Il sistema integra: inserimento manuale operatori, acquisizione automatica da sorgenti SQL Server / Oracle / CSV email (ADER4, HERA16), job pianificati Hangfire, wizard di configurazione fonti dati, report PDF/Excel e normalizzazione operatori.");
            s.Paragraphs.Add("Questo manuale è il riferimento tecnico per sviluppatori, DevOps e amministratori: architettura, configurazione, estensione handler, pipeline dati e troubleshooting.");
            s.Subsections.Add(new ManualSubSection("Destinatari", new List<string>{
                "Sviluppatori: estensione handler, debug pipeline, aggiunta servizi e configurazioni.",
                "DevOps / SysAdmin: deploy IIS, variabili ambiente, monitoraggio Hangfire.",
                "Supervisori / Capoturno: monitoraggio produzione, normalizzazione operatori.",
                "Auditor: tracciabilità inserimenti, log NLog, audit ResultTask."}));
            s.Subsections.Add(new ManualSubSection("Documenti Correlati", new List<string>{
                "Manuale Operatore — guida UI per operatori (pagina /manuale-operatore).",
                "appsettings.json / nlog.config — configurazioni runtime."}));
            s.Subsections.Add(new ManualSubSection("Stack Tecnologico", new List<string>{
                "<table class='manual-table'><thead><tr><th>Layer</th><th>Tecnologia</th><th>Note</th></tr></thead><tbody>" +
                "<tr><td>UI</td><td>Blazor Server + MudBlazor v8</td><td>.NET 10, C# 14</td></tr>" +
                "<tr><td>Autenticazione</td><td>Cookie Auth + Active Directory</td><td>MockAD in Development</td></tr>" +
                "<tr><td>ORM</td><td>Entity Framework Core (IDbContextFactory)</td><td>SQL Server 2019+</td></tr>" +
                "<tr><td>Mapping</td><td>Mapperly (compile-time, zero reflection)</td><td>Singleton</td></tr>" +
                "<tr><td>Scheduler</td><td>Hangfire 1.8+ su SQL Server</td><td>Schema HangFire, 3 retry</td></tr>" +
                "<tr><td>Logging</td><td>NLog + NLog.Web.AspNetCore</td><td>Strutturato, senza emoji</td></tr>" +
                "<tr><td>Email</td><td>EWS (Exchange) + FluentEmail SMTP</td><td>Mock CSV in Development</td></tr>" +
                "<tr><td>Export PDF</td><td>PdfExportService (iText custom)</td><td>Scoped</td></tr>" +
                "<tr><td>Export Excel</td><td>ClosedXML / OpenXML</td><td>--</td></tr>" +
                "<tr><td>Test E2E</td><td>Playwright + xUnit</td><td>v1.49, Chromium</td></tr>" +
                "</tbody></table>"}, true));
        });

        // 2 ARCHITETTURA E LAYER
        Add("ARCHITETTURA E LAYER", s =>
        {
            s.Paragraphs.Add("Il progetto è composto da 4 assembly con responsabilità distinte: BlazorDematReports (UI), BlazorDematReports.Core (business logic), Entities (modello dati EF Core), BlazorDematReports.Tests.E2E (test Playwright).");
            s.Subsections.Add(new ManualSubSection("Struttura Assembly", new List<string>{
                "<table class='manual-table'><thead><tr><th>Assembly</th><th>Responsabilità</th><th>Pattern chiave</th></tr></thead><tbody>" +
                "<tr><td>BlazorDematReports</td><td>UI Blazor, Program.cs, Login, BaseComponentPage</td><td>Blazor Server, DI root</td></tr>" +
                "<tr><td>BlazorDematReports.Core</td><td>Services, Handlers, DataReading, Wizard, Validation</td><td>DI Scoped/Singleton, Registry pattern</td></tr>" +
                "<tr><td>Entities</td><td>EF Core entities, DbContext, Enum TipoFonteData</td><td>EF Core, Scaffolding con patch</td></tr>" +
                "<tr><td>Tests.E2E</td><td>Test Playwright xUnit, Page Object Model</td><td>POM, IClassFixture</td></tr>" +
                "</tbody></table>"}, true));
            s.Subsections.Add(new ManualSubSection("Flusso Dati Principale", new List<string>{
                "<div class='diagram-block'>[Browser]\n   | WebSocket SignalR\n   v\n[Blazor Server Components]\n   | solo Services (mai DbContext diretto)\n   v\n[Service Layer] (IServiceXxx)\n   | IDbContextFactory\n   v\n[EF Core DbContext]\n   | SQL Server\n   v\n[DematReportsContext]</div>"}, true));
            s.Subsections.Add(new ManualSubSection("Pipeline Job Automatici", new List<string>{
                "<div class='diagram-block'>[Hangfire Scheduler] (CRON expression)\n   | ogni JobRunner ha il proprio DI scope\n   v\n[ProductionJobRunner.RunAsync]\n   |\n   +--[TipoFonte == SQL]\n   |    v\n   |   [QueryService.ExecuteQueryAsync]\n   |    | DataTable\n   |    v\n   |   [ElaboratoreDatiLavorazione]\n   |    | DatiElaborati\n   |    v\n   |   [ServiceProduzioneSistema.UpsertAsync]\n   |\n   +--[TipoFonte == HandlerIntegrato]\n        v\n       [UnifiedHandlerRegistry.ExecuteAsync(code)]\n        | IProductionDataHandler.ExecuteAsync\n        v\n       [ProduzioneSistema / DatiMailCsv]</div>"}, true));
            s.Subsections.Add(new ManualSubSection("Regola CRITICA — Accesso Dati da Componenti", new List<string>{
                "I componenti Blazor NON devono mai iniettare IDbContextFactory o DbContext direttamente.",
                "Tutto l'accesso dati passa esclusivamente attraverso il Service Layer (IServiceXxx).",
                "Il BaseComponentPage fornisce i metodi comuni (HandleValidSubmitAsync, LoadDataAsync, ecc.).",
                "Le pagine wizard usano i servizi dedicati della DI - regola uniforme per tutte le pagine."}));
        });

        // 3 CONFIGURAZIONE FONTI DATI — WIZARD
        Add("CONFIGURAZIONE FONTI DATI", s =>
        {
            s.Paragraphs.Add("Il sistema utilizza un wizard a 4 step (ConfigurationWizardState, record immutabile) per la configurazione di nuove sorgenti dati. Ogni configurazione genera automaticamente TaskDaEseguire schedulati su Hangfire.");
            s.Subsections.Add(new ManualSubSection("Tipi di Fonte (TipoFonteData enum)", new List<string>{
                "<table class='manual-table'><thead><tr><th>Valore</th><th>Descrizione</th><th>Parametri richiesti</th></tr></thead><tbody>" +
                "<tr><td>SQL (0)</td><td>Query parametrizzata su DB configurato</td><td>ConnectionStringName, TestoQueryTask per fase</td></tr>" +
                "<tr><td>HandlerIntegrato (1)</td><td>Handler C# custom (inclusi mail HERA16/ADER4)</td><td>HandlerClassName (codice nel registry)</td></tr>" +
                "</tbody></table>"}, true));
            s.Subsections.Add(new ManualSubSection("Step Wizard", new List<string>{
                "Step 1 — Tipo Fonte: seleziona SQL o HandlerIntegrato.",
                "Step 2 — Configurazione Specifica: ConnectionString (SQL, con test connessione) o codice interno (Handler).",
                "Step 3 — Procedura: seleziona ProceduraLavorazione → auto-carica fasi disponibili e IdCentro.",
                "Step 4 — Mapping Fasi/Centri: configura una o più coppie (Fase, CRON, GiorniPrecedenti, QuerySQL opzionale)."}));
            s.Subsections.Add(new ManualSubSection("Flusso Salvataggio Configurazione", new List<string>{
                "<div class='diagram-block'>[Wizard Step 4: Salva]\n   v\n[ServiceConfigurazioneFontiDati.SalvaAsync]\n   |\n   +-- Crea/aggiorna ConfigurazioneFontiDati\n   +-- Crea/aggiorna ConfigurazioneFaseCentro (1 per mapping)\n   v\n[TaskGenerationService.GenerateTasksForConfigurationAsync]\n   |\n   +-- Crea TaskDaEseguire per ogni mapping\n   v\n[ProductionJobScheduler.ScheduleRecurringJobAsync]\n   |\n   +-- RecurringJob.AddOrUpdate(CRON)\n   +-- Hangfire registra il job</div>"}, true));
            s.Subsections.Add(new ManualSubSection("Validazione Query SQL", new List<string>{
                "SqlValidationService.ValidateQuery: sicurezza (SQL injection, keyword vietate), solo SELECT/WITH, parametri @startDate/@endDate obbligatori.",
                "SqlValidationService.ValidateColumnNames: colonne obbligatorie Operatore, DataLavorazione, Documenti, Fogli, Pagine. No SELECT *.",
                "Parametri data iniettati automaticamente: @startDate/@endDate (DateTime2) e @startDateStr/@endDateStr (VarChar yyyy-MM-dd).",
                "La query viene validata PRIMA del salvataggio — il pulsante 'Aggiungi Mapping' rimane disabilitato finché non supera entrambe le validazioni."}));
        });

        // 4 HANDLER SYSTEM
        Add("HANDLER SYSTEM", s =>
        {
            s.Paragraphs.Add("Il sistema handler è basato sul pattern Registry. Ogni handler implementa IProductionDataHandler, viene registrato in DI come Singleton e auto-scoperto da UnifiedHandlerRegistry al bootstrap.");
            s.Subsections.Add(new ManualSubSection("Handler Registrati", new List<string>{
                "<table class='manual-table'><thead><tr><th>Codice</th><th>Classe</th><th>Tipo</th><th>Descrizione</th></tr></thead><tbody>" +
                "<tr><td>Z0072370_28AUT</td><td>Z0072370_28AutHandler</td><td>SQL/Oracle</td><td>Elaborazione produzione specifica</td></tr>" +
                "<tr><td>Z0082041_SOFTLINE</td><td>Z0082041_SoftlineHandler</td><td>SQL</td><td>Produzione Softline</td></tr>" +
                "<tr><td>ANT_ADER4_SORTER_1_2</td><td>Ant_Ader4_Sorter_1_2Handler</td><td>Custom</td><td>Handler sorter ADER4</td></tr>" +
                "<tr><td>PRATICHE_SUCCESSIONE</td><td>PraticheSuccessioneHandler</td><td>Oracle</td><td>Pratiche successione da Oracle</td></tr>" +
                "<tr><td>RDMKT_RSP</td><td>Rdmkt_RSPHandler</td><td>SQL</td><td>Produzione RDMKT</td></tr>" +
                "<tr><td>MAIL_INGESTION</td><td>GenericMailIngestionHandler</td><td>Email</td><td>Orchestratore ingestion mail (ADER4+HERA16)</td></tr>" +
                "</tbody></table>"}, true));
            s.Subsections.Add(new ManualSubSection("Aggiungere un Nuovo Handler (step by step)", new List<string>{
                "1. Creare classe in BlazorDematReports.Core/Handlers/LavorazioniHandlers/ che implementa IProductionDataHandler.",
                "2. Implementare le proprietà Code (stringa univoca) e ExecuteAsync(context, ct).",
                "3. Registrare in Program.cs: builder.Services.AddSingleton<IProductionDataHandler, MioNuovoHandler>();",
                "4. Il codice appare automaticamente nel wizard (Step 4) tramite UnifiedHandlerRegistry.GetAllCodes().",
                "5. Creare una configurazione dal wizard e assegnare il codice handler al mapping desiderato.",
                "6. Testare con esecuzione manuale dalla pagina Impostazioni > Fonti Dati > Esegui ora."}));
            s.Subsections.Add(new ManualSubSection("Handler Email — ADER4 e HERA16", new List<string>{
                "GenericMailIngestionHandler orchestra Ader4IngestionProcessor e Hera16IngestionProcessor.",
                "In Development: UseMockService=true in appsettings → legge CSV da cartella locale invece di EWS.",
                "ADER4: legge CSV allegati email Exchange, li parsa e li persiste in DatiMailCsvAder4.",
                "HERA16: legge CSV allegati email Exchange, bulk insert in DatiMailCsvHera16 tramite IHera16DataService."}));
        });

        // 5 PIPELINE ELABORAZIONE OPERATORI
        Add("PIPELINE ELABORAZIONE OPERATORI", s =>
        {
            s.Paragraphs.Add("La pipeline di elaborazione converte dati raw (DataTable da SQL / DatiElaborati da handler) in record ProduzioneSistema normalizzati e persistiti. Normalizzazione operatori, gestione Not_Found_Oper e aggregazione KPI avvengono in ElaboratoreDatiLavorazione.");
            s.Subsections.Add(new ManualSubSection("Flusso Normalizzazione Operatori", new List<string>{
                "<div class='diagram-block'>[Raw: OP_INDEX = 'mario.rossi_alias']\n   v\n[NormalizzatoreOperatori.NormalizzaAsync]\n   |\n   +-- Cerca in OperatoriNormalizzati (alias → Operatori)\n   |\n   +-- Trovato: usa Operatori.Nominativo\n   +-- Non trovato: usa 'Not_Found_Oper'\n   v\n[GestoreOperatoriDatiLavorazione]\n   |\n   +-- Verifica appartenenza operatore al centro\n   +-- Verifica operatore attivo\n   v\n[DatiElaborati pronti per persistenza]</div>"}, true));
            s.Subsections.Add(new ManualSubSection("Not_Found_Oper", new List<string>{
                "Quando un codice operatore non é censito in OperatoriNormalizzati, viene marcato come Not_Found_Oper.",
                "I record Not_Found_Oper vengono comunque persistiti in ProduzioneSistema per visibilità.",
                "Per risolvere: aggiungere il mapping alias verso operatore reale nella pagina Normalizzazione Operatori.",
                "Dopo il censimento, rieseguire il job per il periodo di interesse per aggiornare i dati."}));
            s.Subsections.Add(new ManualSubSection("Parametri Query Automatici", new List<string>{
                "<table class='manual-table'><thead><tr><th>Parametro</th><th>Tipo SQL</th><th>Formato</th><th>Uso</th></tr></thead><tbody>" +
                "<tr><td>@startDate</td><td>DateTime2</td><td>DateTime .NET</td><td>Colonne date/datetime/datetime2</td></tr>" +
                "<tr><td>@endDate</td><td>DateTime2</td><td>DateTime .NET</td><td>Colonne date/datetime/datetime2</td></tr>" +
                "<tr><td>@startDateStr</td><td>VarChar(10)</td><td>yyyy-MM-dd</td><td>Colonne varchar data (legacy)</td></tr>" +
                "<tr><td>@endDateStr</td><td>VarChar(10)</td><td>yyyy-MM-dd</td><td>Colonne varchar data (legacy)</td></tr>" +
                "</tbody></table>"}, true));
            s.Subsections.Add(new ManualSubSection("GiorniPrecedenti", new List<string>{
                "Ogni TaskDaEseguire ha un campo GiorniPrecedenti (default: configurabile in TaskConfigurationDefaults).",
                "Il range date del job è: startDate = oggi - GiorniPrecedenti, endDate = oggi.",
                "Per esecuzioni manuali con range custom, usare ProductionJobRunner.RunAsync(id, startDate, endDate)."}));
        });

        // 6 AUTENTICAZIONE E SICUREZZA
        Add("AUTENTICAZIONE E SICUREZZA", s =>
        {
            s.Paragraphs.Add("L'autenticazione usa Cookie Auth ASP.NET Core con Active Directory in produzione e MockActiveDirectoryService in Development (nessuna dipendenza AD in sviluppo).");
            s.Subsections.Add(new ManualSubSection("Ruoli e Autorizzazione", new List<string>{
                "<table class='manual-table'><thead><tr><th>Ruolo</th><th>Accesso</th></tr></thead><tbody>" +
                "<tr><td>OWNER</td><td>Accesso completo a tutte le pagine</td></tr>" +
                "<tr><td>ADMIN</td><td>Impostazioni, configurazioni, utenti</td></tr>" +
                "<tr><td>SUPERVISOR</td><td>Report, gestione operatori, monitoraggio</td></tr>" +
                "<tr><td>CAPOTURNO</td><td>Carica dati, gestione operatori, report</td></tr>" +
                "<tr><td>USER</td><td>Solo carica dati produzione</td></tr>" +
                "</tbody></table>"}, true));
            s.Subsections.Add(new ManualSubSection("Configurazione Cookie", new List<string>{
                "HttpOnly: true — prevenzione XSS.",
                "SecurePolicy: Always — solo HTTPS.",
                "SameSite: Strict — prevenzione CSRF.",
                "ExpireTimeSpan: 30 minuti con SlidingExpiration.",
                "LoginPath / AccessDeniedPath: /Account/Login."}));
            s.Subsections.Add(new ManualSubSection("Active Directory — Ambienti", new List<string>{
                "Development: MockActiveDirectoryService — login con utente da appsettings.Development.json (DefaultTestUser/Password).",
                "Produzione: ActiveDirectoryService — autenticazione reale tramite LDAP/AD.",
                "Configurazione in appsettings: sezione 'ActiveDirectory' con Domain, SearchBase, ServiceAccount."}));
            s.Subsections.Add(new ManualSubSection("SQL Injection Protection", new List<string>{
                "SqlValidationService blocca: pattern DROP/DELETE/TRUNCATE/ALTER/CREATE/UPDATE/INSERT, EXEC, xp_cmdshell, sp_executesql, UNION SELECT, commenti SQL (-- e /* */).",
                "Tutte le query salvate vengono validate PRIMA della persistenza.",
                "QueryService usa esclusivamente parametri tipizzati (no concatenazione stringhe)."}));
        });

        // 7 LOGGING
        Add("LOGGING", s =>
        {
