    private string BuildHtmlFromSections(List<ManualSection> sections)
    {
        var sb = new StringBuilder();
        foreach (var s in sections)
        {
            sb.AppendLine($"<div class='manuale-sezione' id='{s.Id}'>");
            sb.AppendLine($"<a class='anchor-offset' id='{s.Id}-anchor'></a>");
            sb.AppendLine($"<div class='manuale-sezione-titolo'>{s.Number} {System.Web.HttpUtility.HtmlEncode(s.Title)}</div>");
            foreach (var p in s.Paragraphs)
                sb.AppendLine($"<div class='manuale-paragrafo'>{System.Web.HttpUtility.HtmlEncode(p)}</div>");
            foreach (var sub in s.Subsections)
            {
                var subId = s.Id + "-" + Slug(sub.Title);
                sb.AppendLine($"<div class='manuale-sottotitolo' id='{subId}'>{System.Web.HttpUtility.HtmlEncode(sub.Title)}</div>");
                foreach (var line in sub.Lines)
                {
                    if (sub.RawHtml)
                        sb.AppendLine(line); // già markup
                    else
                        sb.AppendLine($"<div class='manuale-paragrafo'>{System.Web.HttpUtility.HtmlEncode(line)}</div>");
                }
            }
            sb.AppendLine("</div>");
        }
        sb.AppendLine("<div class='manuale-paragrafo' style='margin-top:40px;font-style:italic;'>Fine documento – versione conforme linee guida.</div>");
        return sb.ToString();
    }

    private string Slug(string input) => Regex.Replace(input.ToLowerInvariant(), "[^a-z0-9]+", "-").Trim('-');
    private void PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm)) { ClearSearch(); return; }
        var pattern = Regex.Escape(searchTerm);
        var regex = new Regex(pattern, RegexOptions.IgnoreCase | RegexOptions.Compiled);
        searchResults = regex.Matches(System.Web.HttpUtility.HtmlDecode(manualHtmlOriginal)).Count;
        displayedHtml = searchResults == 0 ? manualHtmlOriginal : regex.Replace(manualHtmlOriginal, m => $"<mark class='highlight-search'>{System.Web.HttpUtility.HtmlEncode(m.Value)}</mark>");
        StateHasChanged();
    }

    private void ClearSearch()
    { searchTerm = string.Empty; searchResults = 0; displayedHtml = manualHtmlOriginal; StateHasChanged(); }

    private async Task ScrollToSection(string id)
    { activeSectionId = id; await JSRuntime.InvokeVoidAsync("scrollToManualSection", "manuale-tecnico-content", id); }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    { if (e.Key == "Enter") PerformSearch(); }

    private void ManualClickCapture(MouseEventArgs e) { }

    private async Task ExportToPdf()
    {
        try
        {
            isExportingPdf = true; StateHasChanged();
            var plain = Regex.Replace(manualHtmlOriginal, "<[^>]+>", string.Empty);
            var fileName = $"Manuale_Tecnico_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";
            var pdfBytes = await PdfExportService.GeneratePdfFromTextAsync(plain, "MANUALE TECNICO");
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(pdfBytes), "application/pdf");
            await JSRuntime.InvokeVoidAsync("showNotification", "Manuale tecnico esportato in PDF con successo!", "success");
        }
        catch (Exception ex)
        { await JSRuntime.InvokeVoidAsync("showNotification", $"Errore durante l'esportazione PDF: {ex.Message}", "error"); }
        finally { isExportingPdf = false; StateHasChanged(); }
    }
}

<script>
    window.scrollToManualSection = (containerId, sectionId) => {
        const container = document.getElementById(containerId);
        const element = document.getElementById(sectionId);
        if (container && element) {
            const top = element.offsetTop - 10;
            container.scrollTo({ top: top, behavior: 'smooth' });
            element.classList.add('section-selected');
            setTimeout(()=> element.classList.remove('section-selected'), 2500);
        }
    };
    window.downloadFile = (fileName, base64Data, contentType) => {
        const linkSource = `data:${contentType};base64,${base64Data}`;
        const a = document.createElement('a');
        a.href = linkSource;
        a.download = fileName;
        a.click();
    };
    window.showNotification = (m,t) => { if(t==='success') console.log(''+m); else console.error(' '+m); };
</script>





