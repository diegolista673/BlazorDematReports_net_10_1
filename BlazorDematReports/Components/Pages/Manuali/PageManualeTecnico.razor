                "<table class='manual-table'><thead><tr><th>Lifetime</th><th>Servizi</th></tr></thead><tbody>" +
                "<tr><td>Singleton</td><td>ILavorazioniConfigManager, IProductionJobScheduler, IRecurringJobManagerAdapter, IQueryService, IHera16DataService, UnifiedHandlerRegistry, tutti IProductionDataHandler, tutti i Mapper Mapperly</td></tr>" +
                "<tr><td>Scoped</td><td>Tutti IServiceXxx (dati), ElaboratoreDatiLavorazione, NormalizzatoreOperatori, ConfigUser, UiStateService, SqlValidationService, ConfigurationWizardStateService, ProcedureEditStateService</td></tr>" +
                "<tr><td>Transient</td><td>Nessuno (non usato)</td></tr>" +
                "</tbody></table>"}, true));
            s.Subsections.Add(new ManualSubSection("BaseComponentPage", new List<string>{
                "Classe base Blazor per tutti i componenti pagina (BaseComponentPage.cs + partial classes).",
