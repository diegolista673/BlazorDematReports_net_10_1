@using BlazorDematReports.Core.Application.Dto
@using MudBlazor
@using Newtonsoft.Json
@using System.Globalization

<MudCard Elevation="4" Class="mud-height-full page-totali-fasi-card responsive-card">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex flex-column" style="width: 100%;">
                <div class="d-flex align-center justify-space-between">
                    <MudText Typo="Typo.h6">@Phase!.FaseNome</MudText>
                    @if (Phase?.ReportData?.Any() == true)
                    {
                        <MudIconButton Class="mr-2" Size="Size.Medium" Color="Color.Success" Icon="@Icons.Material.Filled.Download" OnClick="DownloadExcel" Title="Esporta Excel" />
                    }
                </div>
                <div style="min-height: 20px;">
                    @if (Phase?.FlagDataReading == true)
                    {
                        <MudText Color="Color.Secondary" Typo="Typo.body2">Data Reading</MudText>
                    }
                </div>
                <div class="d-flex align-center justify-space-between mt-4">
                    @if (HasSignificantData(Phase?.ReportData))
                    {
                        <div class="phase-mini-chart-wrapper">
                            <div id="phase-chart-@Phase?.IdFaseLavorazione" class="phase-chart-container"></div>
                        </div>
                    }
                    else
                    {
                        <div class="phase-mini-chart-placeholder">
                            <MudPaper elevation=0>
                                <MudText Typo="Typo.caption" Color="Color.Default">Nessun dato @Anno</MudText>
                            </MudPaper>
                        </div>

                    }
                    @if (Phase?.ReportDataLast5Years?.Any() == true)
                    {
                        <div class="phase-last5years-chart-wrapper mt-2">
                            <div id="phase-5years-@Phase.IdFaseLavorazione" class="phase-chart-container"></div>
                        </div>
                    }
                    else
                    {
                        <div class="phase-mini-chart-placeholder">
                            <MudPaper  elevation =0 >
                                <MudText Typo="Typo.caption" Color="Color.Default">Nessun dato storico</MudText>
                            </MudPaper>
                        </div>
                    }
                </div>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (Phase?.ReportData?.Any() == true)
        {
            <MudGrid Spacing="1" Class="mb-3">
                <MudItem xs="4">
                    <MudPaper Class="pa-2 page-totali-fasi-paper responsive-paper ma-1" Outlined="true">
                        <MudText Typo="Typo.caption" Style="color: #546e7a; font-weight: 600;">Anno</MudText>
                        <MudText Typo="Typo.h6" Style="color: #1a202c; font-weight: 700;">@Anno</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4">
                    <MudPaper Class="pa-2 page-totali-fasi-paper responsive-paper ma-1" Outlined="true">
                        <MudText Typo="Typo.caption" Style="color: #546e7a; font-weight: 600;">Ore</MudText>
                        <MudText Typo="Typo.h6" Style="color: #1a202c; font-weight: 700;">@Phase.TotaleOre.ToString("N0")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4">
                    <MudPaper Class="pa-2 page-totali-fasi-paper responsive-paper ma-1" Outlined="true">
                        <MudText Typo="Typo.caption" Style="color: #546e7a; font-weight: 600;">FTE</MudText>
                        <MudText Typo="Typo.h6" Style="color: #1a202c; font-weight: 700;">@Phase.TotaleFteMese.ToString("0.0")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4">
                    <MudPaper Class="pa-2 page-totali-fasi-paper responsive-paper ma-1" Outlined="true">
                        <MudText Typo="Typo.caption" Style="color: #546e7a; font-weight: 600;">Documenti</MudText>
                        <MudText Typo="Typo.h6" Style="color: #1a202c; font-weight: 700;">@Phase.TotaleDocumenti.ToString("N0")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4">
                    <MudPaper Class="pa-2 page-totali-fasi-paper responsive-paper ma-1" Outlined="true">
                        <MudText Typo="Typo.caption" Style="color: #546e7a; font-weight: 600;">Fogli</MudText>
                        <MudText Typo="Typo.h6" Style="color: #1a202c; font-weight: 700;">@Phase.TotaleFogli.ToString("N0")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4">
                    <MudPaper Class="pa-2 page-totali-fasi-paper responsive-paper ma-1" Outlined="true">
                        <MudText Typo="Typo.caption" Style="color: #546e7a; font-weight: 600;">Pagine</MudText>
                        <MudText Typo="Typo.h6" Style="color: #1a202c; font-weight: 700;">@Phase.TotalePagine.ToString("N0")</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>


        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true">Nessun dato disponibile per questa fase nell'anno selezionato</MudAlert>
        }
    </MudCardContent>
</MudCard>

@code {

    [Parameter] public FaseReportData? Phase { get; set; }
    [Parameter] public int Anno { get; set; }
    [Parameter] public EventCallback<FaseReportData?> OnExcel { get; set; }

    private void DownloadExcel() => OnExcel.InvokeAsync(Phase);

    private bool HasSignificantData(List<ReportOreDocumenti>? reportData)
    {
        if (reportData == null || !reportData.Any()) return false;
        return reportData.Any(r => (r.Documenti ?? 0) > 0 || (r.Fogli ?? 0) > 0 || (r.Pagine ?? 0) > 0);
    }
}