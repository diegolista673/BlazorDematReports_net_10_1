@page "/totali-lavorazione-fasi"
@attribute [Authorize(Roles = "OWNER, ADMIN, SUPERVISOR,CAPOTURNO")]
@using BlazorDematReports.Components.Pages.ReportsLavorazioni.Components
@using BlazorDematReports.Core.DataReading.Dto
@using BlazorDematReports.Core.Application.Dto
@using System.Globalization
@using Newtonsoft.Json
@inject BlazorDematReports.Core.Services.Interfaces.IDataService.IServiceProcedureLavorazioni ServiceProcedureLavorazioni
@inject BlazorDematReports.Core.Services.Interfaces.IDataService.IServiceProduzioneOperatori ServiceProduzioneOperatori
@inject BlazorDematReports.Core.Services.Interfaces.IDataService.IServiceProduzioneSistema ServiceProduzioneSistema
@inject BlazorDematReports.Core.Services.Interfaces.IDataService.IServiceTaskDataReadingAggiornamento ServiceTaskDataReadingAggiornamento
@inherits BaseComponentPage<PageTotaliLavorazioneFasi,ReportAnnualeDto,ReportAnnualeDto>
@inject NavigationManager NavManager
@inject IJSRuntime JSInterop

<MudText Typo="Typo.h4" Class="titolo ml-4">Totali Lavorazione per Fasi</MudText>
<MudDivider Class="border-solid border-1 mud-border-primary"></MudDivider>
<MudContainer MaxWidth="MaxWidth.False">
    <MudGrid Class="mt-2">
        <MudItem xs="12">
            <MudCard Elevation="3">
                <MudCardContent>
                    <EditForm EditContext="@EditContext" OnValidSubmit="HandleValidSubmitAsync">
                        <DataAnnotationsValidator />
                        <MudGrid Class="align-center d-flex justify-start">
                            <MudItem xs="12" sm="3" md="2" lg="1" xl="1" Class="d-flex flex-grow-0">
                                <MudDatePicker Required Label="Anno" @bind-Date="Model!.Year" OpenTo="OpenTo.Year" FixMonth="@DateTime.Today.Month" FixDay="@DateTime.Today.Day" DateFormat="yyyy" />
                            </MudItem>
                            <MudItem xs="12" sm="9" md="10" lg="5" xl="5" Class="d-flex flex-grow-0">
                                <MudAutocomplete T="string"
                                                 Label="Lavorazione"
                                                 SearchFunc="@((string arg, CancellationToken ct) => SearchFromSelect(base.SelectLavorazione, arg))"
                                                 MaxItems=null Clearable Dense ResetValueOnEmptyText SelectOnActivation Required
                                                 Value="@Model!.Lavorazione"
                                                 Text="@Model.Lavorazione"
                                                 ValueChanged="@((string arg) => OnValueChangedLavorazioneAsync(arg))"
                                                 For="(() => Model.Lavorazione)" />
                            </MudItem>
                            <MudItem xs="12" sm="12" md="2" lg="2" xl="2" Class="d-flex flex-grow-0">
                                <MudButton StartIcon="@Icons.Material.Filled.TableView" ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth Disabled="@(_isButtonDisabled)">
                                    Visualizza Report
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                        {
                            <MudAlert Severity="Severity.Error" Class="mt-3">@ErrorMessage</MudAlert>
                        }
                    </EditForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
        @if (_submitForm && _proceduraDto != null)
        {
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <div class="d-flex align-center gap-4">
                        @if (!string.IsNullOrEmpty(_proceduraDto.LogoBase64))
                        {
                            <MudAvatar Size="Size.Large" Square Style="width:200px;height:100px;">
                                <MudImage Src="@_proceduraDto.LogoBase64" Alt="Logo" Style="object-fit:contain;width:100%;height:100%;" />
                            </MudAvatar>
                        }
                        else
                        {
                            <MudAvatar Size="Size.Large" Color="Color.Primary" Style="width:100px;height:100px;">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Style="width:60px;height:60px;" />
                            </MudAvatar>
                        }
                        <div class="flex-grow-1">
                            <MudText Typo="Typo.h4" Class="mb-2">@_proceduraDto.NomeProcedura</MudText>
                            <div class="d-flex flex-wrap gap-2">
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Business">@_proceduraDto.Centro</MudChip>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Icon="@Icons.Material.Filled.Category">@_proceduraDto.Reparto</MudChip>
                            </div>

                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            @if (_fasiReportData?.Any() == true)
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.h5" Class="mb-3">Riepilogo Fasi di Lavorazione (@Model!.Anno)</MudText>
                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" /> Prima data inserita: <b>@PrimaDataInserita</b></MudText>
                        <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" /> Ultima data inserita: <b>@UltimaDataInserita</b></MudText>
                        <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" /> Aggiornato al: <b>@AggiornatoAl</b></MudText>
                        <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" /> Stato: <b>@(_proceduraDto.Attiva == true ? "Attiva" : "Non Attiva")</b></MudText>
                        <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Small" /> Totale Ore (tutte le fasi): <b>@TotaleOre</b></MudText>
                        <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Small" /> Totale FTE (tutte le fasi): <b>@TotaleFTE</b></MudText>
                    </div>
                </MudItem>
                @foreach (var faseData in _fasiReportData.OrderBy(f => f.FlagDataReading == false))
                {
                    <MudItem xs="12" sm="6" md="6" lg="3" xl="3">
                        <PhaseCard Phase="faseData" Anno="@Model!.Anno" OnToggle="ToggleFaseDetailsAsync" OnExcel="DownloadExcelAsync" />
                    </MudItem>
                }
            }
            else
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Class="mt-3">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" /> Nessuna fase configurata per questa lavorazione o nessun dato disponibile per l'anno selezionato.
                    </MudAlert>
                </MudItem>
            }
        }
    </MudGrid>
</MudContainer>

@code {
    private bool _submitForm;
    private ProcedureLavorazioniDto? _proceduraDto;
    private List<FaseReportData>? _fasiReportData;
    private string? PrimaDataInserita { get; set; }
    private string? UltimaDataInserita { get; set; }
    private string? AggiornatoAl { get; set; }
    private List<ReportAnniSistema> _lstAnniPrecedenti = new();
    private bool _isButtonDisabled => string.IsNullOrEmpty(Model?.Lavorazione) || Model?.Year == null;

    private int TotaleOre = 0;
    private double TotaleFTE = 0;


    protected override async Task OnInitializedAsync()
    {
        await RunWithOverlay(async () =>
        {
            SetEditContext();
            Model!.Year = DateTime.Today;
            Model!.Anno = DateTime.Today.Year;
            ListProcedureLavorazioni = await ServiceProcedureLavorazioni.GetTableProcedureLavorazioniByUserAsync();
            if (ListProcedureLavorazioni != null)
                SetSelectLavorazione();
        }, "Caricamento dati...");
    }

    private void OnYearChanged(DateTime? year)
    {
        Model!.Year = year;
        Model!.Anno = year?.Year ?? 0;
        _submitForm = false;
    }

    private async Task OnValueChangedLavorazioneAsync(string? lavorazione)
    {
        _submitForm = false;
        _proceduraDto = null;
        _fasiReportData = null;
        Model!.Lavorazione = string.IsNullOrEmpty(lavorazione) ? null : lavorazione.ToUpper();
        Model!.IdProceduraLavorazione = string.IsNullOrEmpty(lavorazione) ? null : Model.IdProceduraLavorazione;
        EditContext?.NotifyFieldChanged(EditContext.Field(nameof(Model.Lavorazione)));
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleFaseDetailsAsync(FaseReportData faseData)
    {
        faseData.IsExpanded = !faseData.IsExpanded;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DownloadExcelAsync(FaseReportData faseData)
    {
        try
        {
            var excelStream = ServiceProduzioneOperatori.CreateExcelProduzioneAnnua(
                faseData.ReportData ?? new List<ReportOreDocumenti>(),
                faseData.ReportTotaliDedicati ?? new List<ReportAnnualeTotaliDedicati>());
            var fileName = $"ProduzioneAnnua_{faseData.FaseNome}_{Model!.Anno}.xlsx";
            await JSInterop!.InvokeVoidAsync("saveAsFile", fileName, Convert.ToBase64String(excelStream.ToArray()));
            UiState?.ShowSnackbar($"File {fileName} scaricato con successo", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Errore export Excel fase {Fase}", faseData.FaseNome);
            ErrorMessage = $"Errore durante la creazione del file Excel: {ex.Message}";
            UiState?.ShowSnackbar("Errore durante l'export Excel", Severity.Error);
        }
    }

    private async Task HandleValidSubmitAsync()
    {
        if (!ValidateFormInput()) return;
        try
        {
            InitializeLoadingState();
            _proceduraDto = await LoadProceduraAsync();

            if (_proceduraDto == null) return;
            ConfigureModelFromProcedura();

            await LoadAllFasiDataAsync();
            await LoadDateInformazioniAsync();
            await FinalizeSuccessfulLoadAsync();
        }
        catch (Exception ex)
        {
            await HandleLoadErrorAsync(ex);
        }
        finally
        {
            FinalizeLoadingState();
        }
    }

    private async Task RenderPhaseMiniChartsAsync()
    {
        try
        {
            if (_fasiReportData == null || !_fasiReportData.Any()) return;
            var batchCurrent = _fasiReportData.Where(f => f.ReportData?.Any() == true && HasSignificantData(f.ReportData))
                .Select(f => new
                {
                    elementId = $"phase-chart-{f.IdFaseLavorazione}",
                    data = f.ReportData!.OrderBy(r => r.Mese).Select(r => new
                    {
                        Mese = r.Mese,
                        Documenti = r.Documenti ?? 0,
                        Fogli = r.Fogli ?? 0,
                        Pagine = r.Pagine ?? 0,
                        Ore = r.TotaleOreUomo ?? 0,
                        Fte = r.FteMese ?? 0
                    })
                });
            if (batchCurrent.Any())
            {
                var jsonBatch = JsonConvert.SerializeObject(batchCurrent);
                await JSInterop.InvokeVoidAsync("CreateEChartPhaseMiniBarBatch", jsonBatch);
            }
            var batchLast5Years = _fasiReportData.Where(f => f.ReportDataLast5Years?.Any() == true)
                .Select(f => new
                {
                    elementId = $"phase-5years-{f.IdFaseLavorazione}",
                    data = f.ReportDataLast5Years!.Select(r => new
                    {
                        Anno = r.Anno,
                        Documenti = r.Documenti ?? 0,
                        Fogli = r.Fogli ?? 0,
                        Pagine = r.Pagine ?? 0
                    })
                });
            if (batchLast5Years.Any())
            {
                var jsonBatch5Years = JsonConvert.SerializeObject(batchLast5Years);
                await JSInterop.InvokeVoidAsync("CreateEChartPhaseLast5YearsBatch", jsonBatch5Years);
            }
        }
        catch (Exception ex)
        {
            Logger?.LogWarning(ex, "Errore rendering mini charts");
        }
    }

    private async Task FinalizeSuccessfulLoadAsync()
    {
        _submitForm = true;
        await InvokeAsync(StateHasChanged);
        await RenderPhaseMiniChartsAsync();
    }

    private async Task LoadDateInformazioniAsync()
    {
        try
        {
            if (_fasiReportData == null || !_fasiReportData.Any() || Model?.IdProceduraLavorazione == null)
            { PrimaDataInserita = UltimaDataInserita = AggiornatoAl = "N/A"; return; }

            var primaFase = _fasiReportData.FirstOrDefault(f => f.ReportData?.Any() == true);
            if (primaFase?.IdFaseLavorazione > 0)
            {
                var primaDataTask = ServiceProduzioneSistema.GetPrimaDataInseritaAsync((int)Model.IdProceduraLavorazione, primaFase.IdFaseLavorazione);
                var ultimaDataTask = ServiceProduzioneSistema.GetUltimaDataInseritaAsync((int)Model.IdProceduraLavorazione, primaFase.IdFaseLavorazione);
                var aggiornatoTask = ServiceTaskDataReadingAggiornamento.GetUltimoAggiornamentoAsync((int)Model.IdProceduraLavorazione, primaFase.IdFaseLavorazione);

                await Task.WhenAll(primaDataTask, ultimaDataTask, aggiornatoTask);

                PrimaDataInserita = await primaDataTask ?? "N/A";
                UltimaDataInserita = await ultimaDataTask ?? "N/A";
                AggiornatoAl = await aggiornatoTask ?? "N/A";
            }
            else
            { PrimaDataInserita = UltimaDataInserita = AggiornatoAl = "N/A"; }
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Errore caricamento date");
            PrimaDataInserita = UltimaDataInserita = AggiornatoAl = "Errore";
        }
    }

    private bool ValidateFormInput()
    {
        if (Model == null || string.IsNullOrEmpty(Model.Lavorazione))
        { ErrorMessage = "Seleziona una lavorazione"; return false; }
        return true;
    }

    private void InitializeLoadingState()
    {
        UiState?.SetMenuDisabled(true);
        UiState?.ShowOverlay("Caricamento report in corso...");
        ErrorMessage = string.Empty;
    }

    private void FinalizeLoadingState()
    {
        UiState?.HideOverlay();
        UiState?.SetMenuDisabled(false);
        InvokeAsync(StateHasChanged);
    }

    private async Task<ProcedureLavorazioniDto?> LoadProceduraAsync()
    {
        var procedura = await ServiceProcedureLavorazioni.GetSingleProceduraLavorazioneDtoAsync(Model!.Lavorazione!);
        if (procedura == null)
        { ErrorMessage = "Lavorazione non trovata"; return null; }
        return procedura;
    }

    private void ConfigureModelFromProcedura()
    {
        Model!.IdProceduraLavorazione = _proceduraDto!.IdproceduraLavorazione;
        Model.IdCentro = _proceduraDto.Idcentro;
    }

    private async Task LoadAllFasiDataAsync()
    {
        _fasiReportData = new List<FaseReportData>();
        TotaleOre = 0; // reset aggregati
        TotaleFTE = 0;
        var fasi = GetValidFasiFromProcedura();
        if (!fasi.Any()) return;

        var allMonthlyTask = ServiceProduzioneOperatori.GetReportProduzioneOreDocumentiAsync(Model!.Anno, (int)Model.IdProceduraLavorazione!, (int)Model.IdCentro!);
        var last5YearsTask = ServiceProduzioneOperatori.GetReportLast5YearsAsync((int)Model.IdProceduraLavorazione!, (int)Model.IdCentro!);
        var totaliDedicatiTask = ServiceProduzioneOperatori.GetReportTotaliDedicatiAsync((int)Model.IdProceduraLavorazione!, (int)Model.Anno!, (int)Model.IdCentro!);

        await Task.WhenAll(allMonthlyTask, last5YearsTask, totaliDedicatiTask);
        var allMonthly = await allMonthlyTask;
        var last5Years = await last5YearsTask;
        var totaliDedicati = await totaliDedicatiTask; 

        var phaseTasks = fasi.Select(async fase =>
        {
            var monthly = new List<ReportOreDocumenti>();
            var rawMonthly = allMonthly?.Where(x => x.IdFaseLavorazione == fase.IdFaseLavorazione).ToList() ?? new List<ReportOreDocumenti>();
            for (int m = 1; m <= 12; m++)
            {
                monthly.Add(rawMonthly.FirstOrDefault(d => d.Mese == m) ?? new ReportOreDocumenti
                {
                    Anno = Model.Anno,
                    Mese = m,
                    MeseString = CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m),
                    IdFaseLavorazione = fase.IdFaseLavorazione,
                    TotaleOreUomo = 0,
                    FteMese = 0,
                    Documenti = 0,
                    Fogli = 0,
                    Pagine = 0,
                    Scarti = 0,
                    PagineSenzaBianco = 0
                });
            }

            var last5YearsForPhase = last5Years?.Where(x => x.IdFaseLavorazione == fase.IdFaseLavorazione).ToList();

            var faseReport = new FaseReportData
            {
                IdFaseLavorazione = fase.IdFaseLavorazione,
                FaseNome = fase.FaseLavorazione ?? "N/A",
                FlagDataReading = fase.FlagDataReading,
                ReportData = monthly,
                ReportTotaliDedicati = totaliDedicati?.Where(t => t.IdFaseLavorazione == fase.IdFaseLavorazione).ToList(),
                ReportDataLast5Years = last5YearsForPhase
            };

            CalculateFaseTotals(faseReport);
            return faseReport;
        });
        _fasiReportData.AddRange(await Task.WhenAll(phaseTasks));

        // Calcolo aggregati su tutte le fasi
        TotaleOre = _fasiReportData.Sum(f => f.TotaleOre);
        TotaleFTE = Math.Round(_fasiReportData.Sum(f => f.TotaleFteMese), 2);
    }

    private void CalculateFaseTotals(FaseReportData faseReportData)
    {
        if (faseReportData.ReportData?.Any() != true) return;
        faseReportData.TotaleDocumenti = faseReportData.ReportData.Sum(r => r.Documenti ?? 0);
        faseReportData.TotaleFogli = faseReportData.ReportData.Sum(r => r.Fogli ?? 0);
        faseReportData.TotalePagine = faseReportData.ReportData.Sum(r => r.Pagine ?? 0);
        faseReportData.TotaleOre = (int)Math.Round(faseReportData.ReportData.Sum(r => r.TotaleOreUomo ?? 0));
        faseReportData.TotaleFteMese = Math.Round(faseReportData.ReportData.Sum(r => r.FteMese ?? 0d), 2);
    }

    private List<LavorazioniFasiDataReadingDto> GetValidFasiFromProcedura() =>
        _proceduraDto!.LavorazioniFasiDataReadingsDto?
            .Where(f => f.IdFaseLavorazione != 0)
            .OrderBy(f => f.FaseLavorazione)
            .ToList() ?? new List<LavorazioniFasiDataReadingDto>();

    private bool HasSignificantData(List<ReportOreDocumenti>? reportData) =>
        reportData != null && reportData.Any(r => (r.Documenti ?? 0) > 0 || (r.Fogli ?? 0) > 0 || (r.Pagine ?? 0) > 0);

    private async Task HandleLoadErrorAsync(Exception ex)
    {
        Logger?.LogError(ex, "Errore caricamento report lavorazione");
        ErrorMessage = $"Errore durante il caricamento: {ex.Message}";
        await HandleExceptionFormAsync(ex);
        _submitForm = false;
        _fasiReportData = null;
        TotaleOre = 0;
        TotaleFTE = 0;
    }
}

































































































































