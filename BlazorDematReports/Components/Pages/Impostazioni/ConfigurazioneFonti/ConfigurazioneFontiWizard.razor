@page "/configura-fonte-dati-wizard"
@page "/configura-fonte-dati-wizard/{IdConfigurazione:int}"
@using BlazorDematReports.Core.Services.Interfaces.IDataService
@using BlazorDematReports.Core.Services.DataService
@using BlazorDematReports.Core.Services.Validation
@using BlazorDematReports.Core.Services.Wizard

@inherits BaseComponentPage<ConfigurazioneFontiWizard>

@inject ConfigurationWizardStateService WizardState
@inject ConfigurationStepValidator StepValidator
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IConfiguration Configuration
@inject ITaskGenerationService TaskGenerationService
@inject IProductionJobScheduler JobScheduler
@inject IServiceProcedureLavorazioni serviceProcedureLavorazioni
@inject IServiceConfigurazioneFontiDati serviceConfigurazioneFontiDati

@attribute [Authorize(Roles = "ADMIN,SUPERVISOR")]

<PageTitle>@(_wizardState.IsEditMode ? "Modifica" : "Nuova") Configurazione Fonte Dati</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    
    @* Header *@
    <MudText Typo="Typo.h4" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
        @(_wizardState.IsEditMode ? "Modifica" : "Nuova") Configurazione Fonte Dati
    </MudText>
    
    @* Progress Stepper *@
    <MudPaper Class="pa-4 mb-4">
        <MudStepper @ref="_stepper" 
                    ActiveIndex="@(_wizardState.CurrentStep - 1)"
                    ActiveIndexChanged="OnStepperIndexChanged">
            
            <ChildContent>
                <MudStep Title="Tipo Fonte">
                    <ChildContent>
                        <Step1_TipoFonte State="@_wizardState" StateService="@WizardState" />
                    </ChildContent>
                </MudStep>
                
                <MudStep Title="Configurazione">
                    <ChildContent>
                        <Step2_ConfigurazioneSpecifica State="@_wizardState" 
                                                       StateService="@WizardState"
                                                       Configuration="@Configuration" />
                    </ChildContent>
                </MudStep>
                
                <MudStep Title="Procedura">
                    <ChildContent>
                        <Step3_SelezioneProcedura State="@_wizardState" 
                                                  StateService="@WizardState" />
                    </ChildContent>
                </MudStep>
                
                <MudStep Title="Mapping">
                    <ChildContent>
                        <Step4_Mapping State="@_wizardState" 
                                       StateService="@WizardState" />
                    </ChildContent>
                </MudStep>
            </ChildContent>
            
            <ActionContent>
                <MudStack Row Justify="Justify.SpaceBetween" Class="mt-4">
                    <MudButton OnClick="@(() => Navigation.NavigateTo("/fonti-dati"))"
                               Variant="Variant.Text">
                        Annulla
                    </MudButton>
                    
                    <MudStack Row Spacing="2">
                        <MudButton OnClick="@ResetWizard"
                                   Variant="Variant.Text"
                                   Disabled="@(_wizardState.CurrentStep == 1)">
                            <MudIcon Icon="@Icons.Material.Filled.Replay" Class="mr-1" />
                            Reset
                        </MudButton>
                        
                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Outlined"
                                   Disabled="@(!_wizardState.CanMovePrevious)"
                                   OnClick="@GoToPreviousStep">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateBefore" />
                            Indietro
                        </MudButton>
                        
                        @if (_wizardState.CurrentStep < _wizardState.TotalSteps)
                        {
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@(!_wizardState.CanMoveNext)"
                                       OnClick="@GoToNextStep">
                                Avanti
                                <MudIcon Icon="@Icons.Material.Filled.NavigateNext" />
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Color="Color.Success"
                                       Variant="Variant.Filled"
                                       Disabled="@(!_wizardState.CanFinish || _saving)"
                                       OnClick="@HandleFinishAsync">
                                @if (_saving)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" />
                                }
                                <MudIcon Icon="@Icons.Material.Filled.Check" Class="mr-1" />
                                @(_wizardState.IsEditMode ? "Aggiorna" : "Crea") Configurazione
                            </MudButton>
                        }
                    </MudStack>
                </MudStack>
            </ActionContent>
        </MudStepper>
    </MudPaper>
    
    @* Validation Summary (se ci sono errori) *@
    @if (!string.IsNullOrWhiteSpace(_wizardState.ValidationMessage))
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            @_wizardState.ValidationMessage
        </MudAlert>
    }
    
</MudContainer>

@code {
    [Parameter] public int? IdConfigurazione { get; set; }
    [Inject] private IConfigurazioneDataReaderService DataReaderService { get; set; } = default!;
    
    private MudStepper? _stepper;
    private ConfigurationWizardState _wizardState = new();
    private bool _saving = false;
    private bool _initialized = false;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            UiState?.ShowOverlay("Caricamento...");
        
            // Sottoscrivi a cambiamenti di stato
            WizardState.OnStateChanged += OnWizardStateChanged;

            // Inizializza ConfigUser
            await ConfigUser!.InitializeAsync();
        
            // Se č edit mode, carica la configurazione
            if (IdConfigurazione.HasValue)
            {
                var config = await DataReaderService.GetConfigurazioneFontiDatiAsync(IdConfigurazione.Value);
                if (config != null)
                {
                    var mappings = config.ConfigurazioneFaseCentros
                        .Where(m => m.FlagAttiva)
                        .ToList();
                
                    // Carica anche i dati di procedura e fasi per edit mode
                    if (mappings.Any())
                    {
                        var firstMapping = mappings.First();
                        var idProcedura = firstMapping.IdProceduraLavorazione;
                        var idCentro = firstMapping.IdCentro;
                    
                        // Carica procedura
                        var procedura = await serviceProcedureLavorazioni.GetProceduraLavorazioneByIdAsync(idProcedura);
                        var nomeProcedura = procedura?.NomeProcedura ?? $"Procedura {idProcedura}";
                    
                        // Carica fasi disponibili
                        var fasi = await DataReaderService.GetFasiByProceduraAsync(idProcedura);
                    
                        WizardState.LoadEditState(config, mappings, idProcedura, idCentro, nomeProcedura, fasi);
                    }
                    else
                    {
                        WizardState.LoadEditState(config, mappings);
                    }
                
                    Snackbar.Add($"Configurazione '{config.CodiceConfigurazione}' caricata in modalitŕ modifica", Severity.Info);
                }
                else
                {
                    Snackbar.Add($"Configurazione {IdConfigurazione} non trovata", Severity.Error);
                    Navigation.NavigateTo("/fonti-dati");
                }
            }
            else
            {
                // Se NON č edit mode, resetta lo state per evitare residui di sessioni precedenti
                WizardState.Reset();
            }
        
            _wizardState = WizardState.State;
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Errore inizializzazione wizard");
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally
        {
            _initialized = true;
            UiState?.HideOverlay();
        }
    }
    
    private void ResetWizard()
    {
        WizardState.Reset();
        // _wizardState will be updated by OnWizardStateChanged
    }

    private void GoToPreviousStep()
    {
        WizardState.UpdateState(s => s.PreviousStep());
        // _wizardState will be updated by OnWizardStateChanged
    }

    private void GoToNextStep()
    {
        // Validazione prima di procedere
        var validation = StepValidator.ValidateStep(_wizardState.CurrentStep, _wizardState);
        if (!validation.IsValid)
        {
            Snackbar.Add(validation.Message, validation.Severity switch
            {
                ValidationSeverity.Error => Severity.Error,
                ValidationSeverity.Warning => Severity.Warning,
                _ => Severity.Info
            });
            return;
        }
    
        WizardState.UpdateState(s => s.NextStep());
        // _wizardState will be updated by OnWizardStateChanged
    }

    private void OnStepperIndexChanged(int newIndex)
    {
        // Ignora eventi durante l'inizializzazione
        if (!_initialized)
            return;
        
        // Gestisce il cambio di step tramite click sui pallini del stepper
        var targetStep = newIndex + 1;
    
        // Validazione range: step deve essere tra 1 e TotalSteps
        if (targetStep < 1 || targetStep > _wizardState.TotalSteps)
        {
            Logger?.LogWarning("Tentativo di navigare a step invalido: {TargetStep}", targetStep);
            return;
        }
    
        if (targetStep > _wizardState.CurrentStep)
        {
            // Movimento in avanti: valida tutti gli step intermedi
            for (int step = _wizardState.CurrentStep; step < targetStep; step++)
            {
                // Salta la validazione se step č fuori range
                if (step < 1 || step > _wizardState.TotalSteps)
                    continue;
                
                var validation = StepValidator.ValidateStep(step, _wizardState);
                if (!validation.IsValid)
                {
                    Snackbar.Add($"Completa lo step {step} prima di procedere: {validation.Message}", Severity.Warning);
                    return;
                }
            }
        }
    
        // Aggiorna lo state con il nuovo step
        WizardState.UpdateState(s => s with { CurrentStep = targetStep });
    }
    
    private async Task HandleFinishAsync()
    {
        _saving = true;
        
        try
        {
            // Validazione finale
            var validation = StepValidator.ValidateAll(_wizardState);
            if (!validation.IsValid)
            {
                Snackbar.Add(validation.Message, Severity.Error);
                return;
            }
            
            UiState?.ShowOverlay("Salvataggio in corso...");
            
            // Crea l'entitŕ configurazione dal state
            var config = _wizardState.ToConfigurationEntity();
            var mappings = _wizardState.Mappings.ToList();
            
            if (_wizardState.IsEditMode)
            {
                // UPDATE
                await serviceConfigurazioneFontiDati.UpdateConfigurazioneFontiDatiAsync(
                    config, mappings, ConfigUser!.Utente);
                
                // Genera task per nuovi mapping
                var taskResult = await TaskGenerationService!.GenerateTasksForConfigurationAsync(config.IdConfigurazione);
                
                // Cleanup orphans
                var cleanupCount = await JobScheduler.CleanupOrphansAsync();
                
                Logger?.LogInformation(
                    "? Configurazione {ConfigId} aggiornata: {CreatedTasks} task creati, {ExistingTasks} esistenti, {Cleanup} cleanup",
                    config.IdConfigurazione, taskResult.CreatedTasks, taskResult.ExistingTasks, cleanupCount);
                
                Snackbar.Add("Configurazione aggiornata con successo!", Severity.Success);
            }
            else
            {
                // CREATE
                await serviceConfigurazioneFontiDati.AddConfigurazioneFontiDatiAsync(
                    config, mappings, ConfigUser!.Utente);
                
                // Genera task
                var taskResult = await TaskGenerationService!.GenerateTasksForConfigurationAsync(config.IdConfigurazione);
                
                Logger?.LogInformation(
                    "? Configurazione {ConfigId} creata con {TaskCount} task",
                    config.IdConfigurazione, taskResult.CreatedTasks);
                
                Snackbar.Add($"Configurazione creata con successo! {taskResult.CreatedTasks} task schedulati.", Severity.Success);
            }
            
            // Reset wizard e naviga alla lista
            WizardState.Reset();
            Navigation.NavigateTo("/fonti-dati");
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Errore salvataggio configurazione");
            Snackbar.Add($"? Errore: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            UiState?.HideOverlay();
        }
    }
    
    private void OnWizardStateChanged()
    {
        _wizardState = WizardState.State;
        Logger?.LogInformation("Wizard state changed: Step={Step}, TipoFonte={TipoFonte}, CanMoveNext={CanMoveNext}", 
            _wizardState.CurrentStep, _wizardState.TipoFonte, _wizardState.CanMoveNext);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        WizardState.OnStateChanged -= OnWizardStateChanged;
    }
}
