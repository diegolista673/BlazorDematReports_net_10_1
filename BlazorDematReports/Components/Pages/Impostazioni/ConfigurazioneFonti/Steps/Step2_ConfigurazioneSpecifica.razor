@using Entities.Enums
@using BlazorDematReports.Helpers
@inject SqlValidationService SqlValidator
@inject IUnifiedHandlerRegistry HandlerRegistry

<MudText Typo="Typo.h6" Class="mb-4">Configurazione specifica per @State.TipoFonte?.GetDescription()</MudText>

@if (State.TipoFonte == TipoFonteData.SQL)
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudSelect @bind-Value="@_connectionString" 
                       Label="Connection String" 
                       Variant="Variant.Outlined"
                       Required
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Storage">
                @foreach (var connString in _connectionStrings)
                {
                    <MudSelectItem Value="@connString">@connString</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        
        <MudItem xs="12" md="4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth
                       Disabled="@(string.IsNullOrWhiteSpace(_connectionString) || _testingConnection)"
                       OnClick="@TestConnectionAsync">
                @if (_testingConnection)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" />
                }
                Testa Connessione
            </MudButton>
        </MudItem>
        
        @if (!string.IsNullOrWhiteSpace(State.ValidationMessage))
        {
            <MudItem xs="12">
                <MudAlert Severity="@(State.ConnectionTestPassed ? Severity.Success : Severity.Warning)">
                    @State.ValidationMessage
                </MudAlert>
            </MudItem>
        }
    </MudGrid>
}
else if (State.TipoFonte == TipoFonteData.HandlerIntegrato)
{
    <MudGrid>
        <MudItem xs="12">
            <MudSelect @bind-Value="@_handler"
                       Label="Handler C#"
                       Variant="Variant.Outlined"
                       Required
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Code">
                @foreach (var handler in _availableHandlers)
                {
                    <MudSelectItem Value="@handler.ClassName">
                        <div class="d-flex align-items-center gap-2">
                            @if (handler.RequiresEmailService)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Color="Color.Secondary" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Color="Color.Default" />
                            }
                            <div>
                                <MudText Typo="Typo.body1">
                                    @handler.Code
                                    @if (!string.IsNullOrWhiteSpace(handler.ServiceCode))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-2">@handler.ServiceCode</MudChip>
                                    }
                                </MudText>
                                <MudText Typo="Typo.body2" Class="text-muted">@handler.Description</MudText>
                            </div>
                        </div>
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>

    @if (!string.IsNullOrWhiteSpace(_handler))
    {
        var handlerInfo = _availableHandlers.FirstOrDefault(h => h.ClassName == _handler);
        if (handlerInfo != null)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                <div class="d-flex align-items-start gap-2">
                    @if (handlerInfo.RequiresEmailService)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Info" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Code" Color="Color.Info" />
                    }
                    <div>
                        <MudText><strong>@handlerInfo.Code</strong></MudText>
                        <MudText Typo="Typo.body2">@handlerInfo.Description</MudText>
                        @if (handlerInfo.RequiresEmailService)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                Handler per servizi mail. Il codice servizio (@handlerInfo.ServiceCode) viene configurato automaticamente.
                            </MudText>
                        }
                        @if (!string.IsNullOrWhiteSpace(handlerInfo.Category))
                        {
                            <MudChip T="string" Size="Size.Small" Class="mt-2">@handlerInfo.Category</MudChip>
                        }
                    </div>
                </div>
            </MudAlert>
        }
    }
}

@code {
[Parameter] public ConfigurationWizardState State { get; set; } = default!;
[Parameter] public ConfigurationWizardStateService StateService { get; set; } = default!;
[Parameter] public IConfiguration Configuration { get; set; } = default!;
    
private List<string> _connectionStrings = new();
private List<HandlerDisplayInfo> _availableHandlers = new();
private bool _testingConnection = false;
    
private string? _connectionString
{
    get => State.ConnectionStringName;
    set => StateService.UpdateState(s => s.WithConnectionString(value));
}
    
private string? _mailService
{
    get => State.MailServiceCode;
    set => StateService.UpdateState(s => s.WithMailService(value));
}
    
private string? _handler
{
    get => State.HandlerClassName;
    set
    {
        StateService.UpdateState(s => s.WithHandler(value));
            
        // Auto-popola MailServiceCode se l'handler ha un ServiceCode (handler mail)
        var handlerInfo = _availableHandlers.FirstOrDefault(h => h.ClassName == value);
        if (handlerInfo?.ServiceCode != null)
        {
            StateService.UpdateState(s => s.WithMailService(handlerInfo.ServiceCode));
        }
    }
}
    
protected override void OnInitialized()
{
    // Carica connection strings
    var section = Configuration.GetSection("ConnectionStrings");
    _connectionStrings = section.GetChildren().Select(c => c.Key).ToList();
        
    // Carica handlers disponibili dal registry
    var handlers = HandlerRegistry.GetHandlersByType(HandlerType.Lavorazione);
    _availableHandlers = handlers.Select(h => new HandlerDisplayInfo
    {
        ClassName = h.Code ?? "Unknown",
        Code = h.Code,
        Description = h.Description ?? h.Code,
        Category = DetermineCategory(h.Code),
        ServiceCode = h.Code == "HERA16" || h.Code == "ADER4" ? h.Code : null,
        RequiresEmailService = h.Code == "HERA16" || h.Code == "ADER4"
    }).ToList();
}
    
private string? DetermineCategory(string? code)
{
    if (code == "HERA16" || code == "ADER4")
        return "Mail Import";
    return "SQL Handler";
}
    
private class HandlerDisplayInfo
{
    public string ClassName { get; set; } = "";
    public string? Code { get; set; }
    public string? Description { get; set; }
    public string? Category { get; set; }
    public string? ServiceCode { get; set; }
    public bool RequiresEmailService { get; set; }
}
    
    private async Task TestConnectionAsync()
    {
        if (string.IsNullOrWhiteSpace(_connectionString)) return;
        
        _testingConnection = true;
        
        try
        {
            var result = await SqlValidator.TestConnectionAsync(_connectionString);
            
            StateService.UpdateState(s => s
                .WithConnectionString(_connectionString, result.IsValid)
                .WithValidationMessage(result.Message));
        }
        finally
        {
            _testingConnection = false;
        }
    }
}
