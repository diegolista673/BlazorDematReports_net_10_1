@using BlazorDematReports.Services.Wizard
@using BlazorDematReports.Services.Validation
@using Entities.Models.DbApplication
@inject SqlValidationService SqlValidator

<MudText Typo="Typo.h6" Class="mb-4">Configura i mapping Fase/Centro</MudText>

<MudTextField @bind-Value="@_descrizione"
              Label="Descrizione Configurazione"
              Variant="Variant.Outlined"
              Margin="Margin.Dense"
              Class="mb-4" />

<MudText Typo="Typo.body1" Class="mb-2"><strong>Mapping Configurati:</strong> @State.Mappings.Count</MudText>

@if (!State.Mappings.Any())
{
    <MudAlert Severity="Severity.Info">
        <MudText>Nessun mapping configurato. Aggiungi almeno un mapping per continuare.</MudText>
    </MudAlert>
}
else
{
    <MudSimpleTable Dense Bordered Striped>
        <thead>
            <tr>
                <th>Fase</th>
                <th>Cron</th>
                <th>Giorni Prec.</th>
                @if (State.TipoFonte == "SQL")
                {
                    <th>Query</th>
                }
                <th>Azioni</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < State.Mappings.Count; i++)
            {
                var mapping = State.Mappings[i];
                var fase = State.FasiDisponibili.FirstOrDefault(f => f.IdFaseLavorazione == mapping.IdFaseLavorazione);
                int index = i;
                
                <tr>
                    <td>@fase?.FaseLavorazione</td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                            @GetCronDescription(mapping.CronExpression)
                        </MudChip>
                    </td>
                    <td>@mapping.GiorniPrecedenti</td>
                    @if (State.TipoFonte == "SQL")
                    {
                        <td>
                            @if (!string.IsNullOrWhiteSpace(mapping.TestoQueryTask))
                            {
                                <MudTooltip Text="@mapping.TestoQueryTask">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Code">
                                        Query configurata
                                    </MudChip>
                                </MudTooltip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">Nessuna query</MudChip>
                            }
                        </td>
                    }
                    <td>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => RimuoviMapping(index))" />
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

<MudDivider Class="my-4" />

<MudText Typo="Typo.subtitle1" Class="mb-3"><strong>Aggiungi Nuovo Mapping</strong></MudText>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudSelect @bind-Value="@_selectedFaseId"
                   Label="Fase"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense">
            @foreach (var fase in State.FasiDisponibili)
            {
                <MudSelectItem Value="@fase.IdFaseLavorazione">@fase.FaseLavorazione</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    
    <MudItem xs="12" md="4">
        <MudSelect @bind-Value="@_selectedCron"
                   Label="Schedulazione"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense">
            @foreach (var cron in _presetCrons)
            {
                <MudSelectItem Value="@cron.Value">@cron.Label</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    
    <MudItem xs="12" md="2">
        <MudNumericField @bind-Value="@_giorniPrecedenti"
                         Label="Giorni Prec."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Min="1"
                         Max="365" />
    </MudItem>
    
    @if (State.TipoFonte == "SQL")
    {
        <MudItem xs="12">
            <MudPaper Elevation="3" Class="pa-3 mb-2">
                <MudText Typo="Typo.body2" Class="mb-2"><b>Linee guida per le query SQL:</b></MudText>
                
                <MudText Typo="Typo.body2" Class="mb-1">1. <b>Formato dei risultati:</b></MudText>
                <ul style="margin-left: 20px; margin-bottom: 8px;">
                    <li><MudText Typo="Typo.caption">L'intestazione deve corrispondere a: <b>Operatore, DataLavorazione, Documenti, Fogli, Pagine</b></MudText></li>
                </ul>

                <MudText Typo="Typo.body2" Class="mb-1">2. <b>Parametrizzazione delle date:</b></MudText>
                <ul style="margin-left: 20px; margin-bottom: 8px;">
                    <li><MudText Typo="Typo.caption">Usa i parametri <code>@@StartDate</code> e <code>@@EndDate</code></MudText></li>
                </ul>

                <MudDivider Class="my-2" />
                <MudText Typo="Typo.caption"><b>Esempio:</b></MudText>
                <MudText Typo="Typo.caption" Style="font-family: monospace; white-space: pre-wrap;">
SELECT op AS Operatore, CONVERT(DATE, data) AS DataLavorazione,
       COUNT(*) AS Documenti, SUM(num_pag)/2 AS Fogli, SUM(num_pag) AS Pagine
FROM tabella WHERE data >= @@StartDate AND data &lt;= @@EndDate
GROUP BY op, CONVERT(DATE, data)
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudTextField @bind-Value="@_queryText"
                          Label="Query SQL"
                          Variant="Variant.Outlined"
                          Lines="12"
                          Style="font-family: monospace;"
                          spellcheck="false"
                          Placeholder="SELECT ..." />
            <MudText Typo="Typo.caption" Class="mt-1">
                Parametri obbligatori: @@StartDate, @@EndDate | Colonne: Operatore, DataLavorazione, Documenti, Fogli, Pagine
            </MudText>
        </MudItem>

        <MudItem xs="12" Class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.VerifiedUser"
                       OnClick="ValidateQueryAsync"
                       Disabled="_validatingQuery || string.IsNullOrWhiteSpace(_queryText)">
                @if (_validatingQuery) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                Valida Query
            </MudButton>
        </MudItem>

        @if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            <MudItem xs="12">
                <MudAlert Severity="@_validationSeverity" Dense Elevation="1" Class="mb-2">
                    @_validationMessage
                </MudAlert>
            </MudItem>
        }
    }
    
    <MudItem xs="12">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth
                   Disabled="@(!CanAddMapping())"
                   OnClick="@AggiungiMapping">
            Aggiungi Mapping
        </MudButton>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public ConfigurationWizardState State { get; set; } = default!;
    [Parameter] public ConfigurationWizardStateService StateService { get; set; } = default!;
    
    private int _selectedFaseId = 0;
    private string _selectedCron = "0 5 * * *";
    private int _giorniPrecedenti = 10;
    private string? _queryText;
    private bool _validatingQuery = false;
    private string? _validationMessage;
    private MudBlazor.Severity _validationSeverity = MudBlazor.Severity.Info;
    private bool _queryValidated = false;
    
    private List<(string Value, string Label)> _presetCrons = new()
    {
        ("0 5 * * *", "Giornaliero 05:00"),
        ("0 2 * * *", "Giornaliero 02:00"),
        ("0 */4 * * *", "Ogni 4 ore"),
        ("0 * * * *", "Ogni ora"),
        ("0 0 1 * *", "Mensile (1° giorno)"),
        ("0 0 * * 0", "Settimanale (Domenica)"),
        ("0 0 * * 1", "Settimanale (Lunedì)")
    };
    
    private string? _descrizione
    {
        get => State.DescrizioneConfigurazione;
        set => StateService.UpdateState(s => s.WithDescrizione(value));
    }
    
    protected override void OnParametersSet()
    {
        if (State.FasiDisponibili.Any() && _selectedFaseId == 0)
        {
            _selectedFaseId = State.FasiDisponibili.First().IdFaseLavorazione;
        }
        
        // Inizializza query di default per SQL
        if (State.TipoFonte == "SQL" && string.IsNullOrWhiteSpace(_queryText))
        {
_queryText = @"SELECT
    OP_INDEX AS operatore,
    CAST(DATA_INDEX AS DATE) AS DataLavorazione,
    COUNT(*) AS Documenti,
    SUM(CAST(NUM_PAG AS INT)) / 2 AS Fogli,
    SUM(CAST(NUM_PAG AS INT)) AS Pagine
FROM Z0072370_RDMKT_28AUT_GE_UDA_DETTAGLIO
WHERE DATA_INDEX >= @startDataDe
  AND DATA_INDEX < DATEADD(DAY, 1, @endDataDe)
GROUP BY OP_INDEX, CAST(DATA_INDEX AS DATE)";
        }
    }
    
    private async Task ValidateQueryAsync()
    {
        if (string.IsNullOrWhiteSpace(_queryText))
        {
            _validationMessage = "Inserisci prima una query SQL";
            _validationSeverity = MudBlazor.Severity.Warning;
            return;
        }

        _validatingQuery = true;
        _validationMessage = null;
        
        try
        {
            var result = SqlValidator.ValidateQuery(_queryText);
            
            _validationMessage = result.Message;
            _validationSeverity = result.Severity switch
            {
                ValidationSeverity.Success => MudBlazor.Severity.Success,
                ValidationSeverity.Warning => MudBlazor.Severity.Warning,
                _ => MudBlazor.Severity.Error
            };
            
            _queryValidated = result.IsValid;
        }
        finally
        {
            _validatingQuery = false;
        }
        
        await Task.CompletedTask;
    }
    
    private bool CanAddMapping()
    {
        // Verifica base
        if (_selectedFaseId == 0 || !State.IdProcedura.HasValue || !State.IdCentro.HasValue)
            return false;
        
        // Se SQL, richiedi query validata
        if (State.TipoFonte == "SQL")
        {
            return !string.IsNullOrWhiteSpace(_queryText) && _queryValidated;
        }
        
        return true;
    }
    
    private void AggiungiMapping()
    {
        if (!CanAddMapping())
            return;
        
        var newMapping = new ConfigurazioneFaseCentro
        {
            IdProceduraLavorazione = State.IdProcedura.Value,
            IdCentro = State.IdCentro.Value,
            IdFaseLavorazione = _selectedFaseId,
            FlagAttiva = true,
            TipoTask = State.TipoFonte,
            CronExpression = _selectedCron,
            EnabledTask = true,
            UltimaModificaTask = DateTime.Now,
            GiorniPrecedenti = _giorniPrecedenti,
            TestoQueryTask = State.TipoFonte == "SQL" ? _queryText : null,
            MailServiceCode = State.TipoFonte == "EmailCSV" ? State.MailServiceCode : null,
            HandlerClassName = State.TipoFonte == "HandlerIntegrato" ? State.HandlerClassName : null
        };
        
        StateService.UpdateState(s => s.WithMapping(newMapping));
        
        // Reset form dopo l'aggiunta
        _queryText = State.TipoFonte == "SQL" 
            ? @"SELECT
    OP_INDEX AS operatore,
    CAST(DATA_INDEX AS DATE) AS DataLavorazione,
    COUNT(*) AS Documenti,
    SUM(CAST(NUM_PAG AS INT)) / 2 AS Fogli,
    SUM(CAST(NUM_PAG AS INT)) AS Pagine
FROM Z0072370_RDMKT_28AUT_GE_UDA_DETTAGLIO
WHERE DATA_INDEX >= @startDataDe
  AND DATA_INDEX<DATEADD(DAY, 1, @endDataDe)
GROUP BY OP_INDEX, CAST(DATA_INDEX AS DATE)"
            : null;
        _validationMessage = null;
        _queryValidated = false;
        _giorniPrecedenti = 10;
        
        // Seleziona la prossima fase disponibile (se esiste)
        var currentIndex = State.FasiDisponibili.FindIndex(f => f.IdFaseLavorazione == _selectedFaseId);
        if (currentIndex >= 0 && currentIndex < State.FasiDisponibili.Count - 1)
        {
            _selectedFaseId = State.FasiDisponibili[currentIndex + 1].IdFaseLavorazione;
        }
    }
    
    private void RimuoviMapping(int index)
    {
        StateService.UpdateState(s => s.WithoutMapping(index));
    }
    
    private string GetCronDescription(string? cron) => cron switch
    {
        "0 5 * * *" => "⏰ Giornaliero 05:00",
        "0 2 * * *" => "⏰ Giornaliero 02:00",
        "0 */4 * * *" => "⏰ Ogni 4 ore",
        "0 * * * *" => "⏰ Ogni ora",
        "0 0 1 * *" => "📅 Mensile",
        "0 0 * * 0" => "📅 Domenica",
        "0 0 * * 1" => "📅 Lunedì",
        _ => cron ?? "N/A"
    };
}
