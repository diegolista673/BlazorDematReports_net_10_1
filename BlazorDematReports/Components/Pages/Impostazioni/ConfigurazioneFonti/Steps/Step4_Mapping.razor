@using BlazorDematReports.Core.Services.Validation
@using BlazorDematReports.Core.Services.Wizard
@using BlazorDematReports.Core.Lavorazioni.Interfaces
@using Entities.Enums
@inject SqlValidationService SqlValidator
@inject IUnifiedHandlerRegistry HandlerRegistry

<MudText Typo="Typo.h6" Class="mb-4">Configura i mapping Fase/Centro</MudText>

<MudTextField @bind-Value="@_descrizione"
              Label="Descrizione Configurazione"
              Variant="Variant.Outlined"
              Margin="Margin.Dense"
              Class="mb-4" />

<MudPaper Elevation="3" Class="mb-4 pa-0" Style="border: 2px solid var(--mud-palette-primary); border-radius: 8px; overflow: hidden;">
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="px-3 py-2"
              Style="background-color: var(--mud-palette-primary-hover); border-bottom: 1px solid var(--mud-palette-primary);">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.subtitle1" Style="color: var(--mud-palette-primary); font-weight: 700; letter-spacing: 0.03em;">
                Mapping Configurati
            </MudText>
        </MudStack>
        <MudBadge Content="@State.Mappings.Count" Color="@(State.Mappings.Any() ? Color.Success : Color.Warning)" Overlap Bordered>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                     Color="@(State.Mappings.Any() ? Color.Success : Color.Warning)"
                     Icon="@(State.Mappings.Any() ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Warning)">
                @(State.Mappings.Any() ? $"{State.Mappings.Count} mapping" : "Nessuno")
            </MudChip>
        </MudBadge>
    </MudStack>

    <div class="pa-3">

@if (!State.Mappings.Any())
{
    <MudAlert Severity="Severity.Warning" Dense Elevation="0" Class="mb-0">
        <MudText>Nessun mapping configurato. Aggiungi almeno un mapping per continuare.</MudText>
    </MudAlert>
}
else
{
    @* Desktop View: Table (nascosta su mobile) *@
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudSimpleTable Dense Bordered>
            <thead>
                <tr style="background-color: var(--mud-palette-primary-hover); color: var(--mud-palette-primary);">
                    <th style="font-weight: 700; padding: 10px 12px;">Fase</th>
                    <th style="font-weight: 700; padding: 10px 12px;">Schedulazione</th>
                    <th style="font-weight: 700; padding: 10px 12px;">Giorni Prec.</th>
                    @if (State.TipoFonte == TipoFonteData.SQL)
                    {
                        <th style="font-weight: 700; padding: 10px 12px;">Query</th>
                    }
                    <th style="font-weight: 700; padding: 10px 12px;">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < State.Mappings.Count; i++)
                {
                    var mapping = State.Mappings[i];
                    var fase = State.FasiDisponibili.FirstOrDefault(f => f.IdFaseLavorazione == mapping.IdFaseLavorazione);
                    int index = i;
                    
                    <tr>
                        <td>@fase?.FaseLavorazione</td>
                        <td>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                @GetCronDescription(mapping.CronExpression)
                            </MudChip>
                        </td>
                        <td>@mapping.GiorniPrecedenti</td>
                        @if (State.TipoFonte == TipoFonteData.SQL)
                        {
                            <td>
                                @if (!string.IsNullOrWhiteSpace(mapping.TestoQueryTask))
                                {
                                    <MudTooltip Text="@mapping.TestoQueryTask">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Code">
                                            Query configurata
                                        </MudChip>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Nessuna query</MudChip>
                                }
                            </td>
                        }
                        <td>
                            @if (State.TipoFonte == TipoFonteData.SQL)
                            {
                                <MudTooltip Text="Modifica mapping">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="@(() => CaricaMappingInForm(index))" />
                                </MudTooltip>
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => RimuoviMapping(index))" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudHidden>
    
    @* Mobile View: Card List (visibile solo su mobile) *@
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudStack Spacing="2">
            @for (int i = 0; i < State.Mappings.Count; i++)
            {
                var mapping = State.Mappings[i];
                var fase = State.FasiDisponibili.FirstOrDefault(f => f.IdFaseLavorazione == mapping.IdFaseLavorazione);
                int index = i;
                
                <MudCard Outlined>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1"><strong>@fase?.FaseLavorazione</strong></MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @if (State.TipoFonte == TipoFonteData.SQL)
                            {
                                <MudTooltip Text="Modifica mapping">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="@(() => CaricaMappingInForm(index))" />
                                </MudTooltip>
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => RimuoviMapping(index))" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="1">
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Primary"><strong>Schedulazione:</strong></MudText>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="mt-1">
                                    @GetCronDescription(mapping.CronExpression)
                                </MudChip>
                            </div>
                            
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Primary"><strong>Giorni Precedenti:</strong></MudText>
                                <MudText Typo="Typo.body2">@mapping.GiorniPrecedenti</MudText>
                            </div>

                            @if (State.TipoFonte == TipoFonteData.SQL)
                            {
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Primary"><strong>Query:</strong></MudText>
                                    @if (!string.IsNullOrWhiteSpace(mapping.TestoQueryTask))
                                    {
                                        <MudExpansionPanels Dense Class="mt-1">
                                            <MudExpansionPanel Text="Visualizza Query" Dense>
                                                <MudText Typo="Typo.caption" Style="font-family: monospace; white-space: pre-wrap; word-break: break-all;">
                                                    @mapping.TestoQueryTask
                                                </MudText>
                                            </MudExpansionPanel>
                                        </MudExpansionPanels>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Default">Nessuna query</MudText>
                                    }
                                </div>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            }
        </MudStack>
    </MudHidden>
}

    </div>
</MudPaper>

<MudDivider Class="my-4" />

<MudText Typo="Typo.subtitle1" Class="mb-3"><strong>Aggiungi Nuovo Mapping</strong></MudText>

<MudGrid>
<MudItem xs="12" sm="6" md="4">
    <MudSelect @bind-Value="@_selectedFaseId"
               Label="Fase"
               Variant="Variant.Outlined"
               Margin="Margin.Dense">
        @foreach (var fase in State.FasiDisponibili)
        {
            <MudSelectItem Value="@fase.IdFaseLavorazione">@fase.FaseLavorazione</MudSelectItem>
        }
    </MudSelect>
</MudItem>
    
<MudItem xs="12" sm="6" md="5">
    <MudSelect @bind-Value="@_selectedCron"
               Label="Schedulazione"
               Variant="Variant.Outlined"
               Margin="Margin.Dense">
        @foreach (var cron in _presetCrons)
        {
            <MudSelectItem Value="@cron.Value">@cron.Label</MudSelectItem>
        }
    </MudSelect>
</MudItem>
    
<MudItem xs="12" sm="6" md="3">
    <MudNumericField @bind-Value="@_giorniPrecedenti"
                     Label="Giorni Precedenti"
                     Variant="Variant.Outlined"
                     Margin="Margin.Dense"
                     Min="1"
                     Max="365" />
</MudItem>

@if (State.TipoFonte == TipoFonteData.HandlerIntegrato)
{
    <MudItem xs="12" sm="6" md="5">
        <MudSelect @bind-Value="@_selectedHandlerCode"
                   Label="Handler per questa fase"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Required
                   Adornment="Adornment.Start"
                   AdornmentIcon="@Icons.Material.Filled.Code">
            @foreach (var handler in _availableHandlers)
            {
                <MudSelectItem Value="@handler">@handler</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
}

    @if (State.TipoFonte == TipoFonteData.SQL)
    {
        <MudItem xs="12">
            <MudPaper Elevation="2" Class="pa-2 pa-sm-3 mb-2">
                <MudText Typo="Typo.body2" Class="mb-2"><strong>Linee guida per le query SQL:</strong></MudText>

                <MudStack Spacing="1">
                    <div>
                        <MudText Typo="Typo.body2" Class="mb-1">1. <strong>Colonne obbligatorie nel SELECT:</strong></MudText>
                        <MudText Typo="Typo.caption" Class="ml-2"><strong>Operatore, DataLavorazione, Documenti, Fogli, Pagine</strong></MudText>
                    </div>

                    <div>
                        <MudText Typo="Typo.body2" Class="mb-1">2. <strong>Parametri data disponibili (tutti iniettati automaticamente):</strong></MudText>
                        <MudStack Spacing="0" Class="ml-2">
                            <MudText Typo="Typo.caption"><code>@@startDate</code> / <code>@@endDate</code> — <strong>DateTime2</strong>: per colonne <em>date / datetime / datetime2</em></MudText>
                            <MudText Typo="Typo.caption"><code>@@startDateStr</code> / <code>@@endDateStr</code> — <strong>VarChar(10)</strong> formato <em>yyyy-MM-dd</em>: per colonne <em>varchar</em></MudText>
                        </MudStack>
                    </div>
                </MudStack>

                <MudDivider Class="my-2" />

                <MudExpansionPanels Dense>
                    <MudExpansionPanel Text="Esempio 1 — colonna datetime / date / datetime2 (piu comune)" Dense>
                        <MudText Typo="Typo.caption" Style="font-family: monospace; white-space: pre-wrap; word-break: break-all; font-size: 0.75rem;">SELECT
    OP_INDEX                              AS Operatore,
    CONVERT(date, DATA_INDEX)             AS DataLavorazione,
    COUNT(*)                              AS Documenti,
    SUM(CONVERT(int, ISNULL(NUM_PAG,0))/2) AS Fogli,
    SUM(CONVERT(int, ISNULL(NUM_PAG,0))) AS Pagine
FROM dbo.TABELLA_PRODUZIONE
WHERE DATA_INDEX &gt;= @@startDate
  AND DATA_INDEX &lt;= @@endDate
  AND department = 'GENOVA'
GROUP BY OP_INDEX, CONVERT(date, DATA_INDEX)</MudText>
                    </MudExpansionPanel>
                    <MudExpansionPanel Text="Esempio 2 — colonna varchar 'yyyy-MM-dd' (fonte legacy)" Dense>
                        <MudText Typo="Typo.caption" Style="font-family: monospace; white-space: pre-wrap; word-break: break-all; font-size: 0.75rem;">SELECT
    OPERATORE                            AS Operatore,
    DATA_LAVORAZIONE                     AS DataLavorazione,
    COUNT(*)                             AS Documenti,
    SUM(CONVERT(int, ISNULL(NUM_PAG, 0))) / 2 AS Fogli AS Fogli,
    SUM(CONVERT(int, ISNULL(NUM_PAG, 0))) AS Pagine
FROM dbo.TABELLA_LEGACY
WHERE DATA_LAVORAZIONE &gt;= @@startDateStr
  AND DATA_LAVORAZIONE &lt;= @@endDateStr
  AND department = 'GENOVA'
GROUP BY OPERATORE, DATA_LAVORAZIONE</MudText>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudTextField @bind-Value="@_queryText"
                          Label="@(_editingIndex.HasValue ? $"Query SQL — modifica mapping #{_editingIndex.Value + 1}" : "Query SQL")"
                          Variant="Variant.Outlined"
                          Lines="10"
                          Style="font-family: monospace; font-size: 0.875rem;"
                          spellcheck="false"
                          Placeholder="SELECT ..." />
            <MudText Typo="Typo.caption" Class="mt-1" Style="word-break: break-word;">
                Colonne datetime: <code>@@startDate</code> / <code>@@endDate</code> &nbsp;|&nbsp;
                Colonne varchar:  <code>@@startDateStr</code> / <code>@@endDateStr</code> &nbsp;|&nbsp;
                SELECT: Operatore, DataLavorazione, Documenti, Fogli, Pagine
            </MudText>
        </MudItem>

        <MudItem xs="12">
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.VerifiedUser"
                       OnClick="ValidateQueryAsync"
                       FullWidth="@(_isMobile)"
                       Disabled="_validatingQuery || string.IsNullOrWhiteSpace(_queryText)">
                @if (_validatingQuery) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                Valida Query
            </MudButton>
        </MudItem>

        @if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            <MudItem xs="12">
                <MudAlert Severity="@_validationSeverity" Dense Elevation="1" Class="mb-2">
                    @_validationMessage
                </MudAlert>
            </MudItem>
        }
    }
    
    <MudItem xs="12">
        <MudStack Row Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="@(_editingIndex.HasValue ? Color.Warning : Color.Primary)"
                       FullWidth
                       Disabled="@(!CanAddMapping())"
                       OnClick="@AggiungiMapping">
                <MudIcon Icon="@(_editingIndex.HasValue ? Icons.Material.Filled.Save : Icons.Material.Filled.Add)" Class="mr-1" />
                @(_editingIndex.HasValue ? $"Salva modifica mapping #{_editingIndex.Value + 1}" : "Aggiungi Mapping")
            </MudButton>
            @if (_editingIndex.HasValue)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           OnClick="@AnnullaEdit">
                    Annulla
                </MudButton>
            }
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public ConfigurationWizardState State { get; set; } = default!;
    [Parameter] public ConfigurationWizardStateService StateService { get; set; } = default!;
    
    private int _selectedFaseId = 0;
    private string _selectedCron = "0 5 * * *";
    private int _giorniPrecedenti = 10;
    private string? _selectedHandlerCode;
    private List<string> _availableHandlers = new();
    private string? _queryText;
    private bool _validatingQuery = false;
    private string? _validationMessage;
    private MudBlazor.Severity _validationSeverity = MudBlazor.Severity.Info;
    private bool _queryValidated = false;
    private bool _isMobile => false;

    /// <summary>Indice del mapping in fase di modifica; null se si sta aggiungendo un nuovo mapping.</summary>
    private int? _editingIndex = null;
    /// <summary>IdFaseCentro del mapping in modifica; 0 se si sta aggiungendo un nuovo mapping.</summary>
    private int _editingIdFaseCentro = 0;

    private List<(string Value, string Label)> _presetCrons = new()
    {
        ("0 5 * * *", "Giornaliero 05:00"),
        ("0 2 * * *", "Giornaliero 02:00"),
        ("0 */4 * * *", "Ogni 4 ore"),
        ("0 * * * *", "Ogni ora"),
        ("0 0 1 * *", "Mensile (1° giorno)"),
        ("0 0 * * 0", "Settimanale (Domenica)"),
        ("0 0 * * 1", "Settimanale (Lunedì)")
    };
    
    private string? _descrizione
    {
        get => State.DescrizioneConfigurazione;
        set => StateService.UpdateState(s => s.WithDescrizione(value));
    }
    
    protected override void OnParametersSet()
    {
        if (State.FasiDisponibili.Any() && _selectedFaseId == 0)
        {
            _selectedFaseId = State.FasiDisponibili.First().IdFaseLavorazione;
        }

        if (_availableHandlers.Count == 0)
        {
            _availableHandlers = HandlerRegistry.GetAllCodes().Order().ToList();
        }

        if (State.TipoFonte == TipoFonteData.HandlerIntegrato && string.IsNullOrWhiteSpace(_selectedHandlerCode))
        {
            _selectedHandlerCode = State.HandlerClassName;
        }
    }
    
    private async Task ValidateQueryAsync()
    {
        if (string.IsNullOrWhiteSpace(_queryText))
        {
            _validationMessage = "Inserisci prima una query SQL";
            _validationSeverity = MudBlazor.Severity.Warning;
            return;
        }

        _validatingQuery = true;
        _validationMessage = null;
        _queryValidated = false;

        try
        {
            // 1. Sicurezza: injection, parametri data, SELECT-only
            var securityResult = SqlValidator.ValidateQuery(_queryText);
            if (!securityResult.IsValid)
            {
                _validationMessage = securityResult.Message;
                _validationSeverity = MudBlazor.Severity.Error;
                return;
            }

            // 2. Schema: colonne obbligatorie (Operatore, DataLavorazione, Documenti, Fogli, Pagine)
            var schemaResult = SqlValidator.ValidateColumnNames(_queryText);
            if (!schemaResult.IsValid)
            {
                _validationMessage = schemaResult.Message;
                _validationSeverity = MudBlazor.Severity.Error;
                return;
            }

            // Entrambe le validazioni superate
            _queryValidated = true;
            _validationMessage = "Query valida: sicurezza e schema colonne confermati.";
            _validationSeverity = MudBlazor.Severity.Success;
        }
        finally
        {
            _validatingQuery = false;
        }

        await Task.CompletedTask;
    }
    
    private bool CanAddMapping()
    {
        // Verifica base
        if (_selectedFaseId == 0 || !State.IdProcedura.HasValue || !State.IdCentro.HasValue)
            return false;
        
        // Se SQL, richiedi query validata
        if (State.TipoFonte == TipoFonteData.SQL)
        {
            return !string.IsNullOrWhiteSpace(_queryText) && _queryValidated;
        }
        
        return true;
    }
    
    private void AggiungiMapping()
    {
        if (!CanAddMapping())
            return;

        var mapping = new ConfigurazioneFaseCentro
        {
            // Preserva IdFaseCentro in modifica: se 0, UpdateAsync lo aggiunge a mappingsToRemove,
            // EF traccia l'entity come Deleted e la query salvata viene persa.
            IdFaseCentro           = _editingIndex.HasValue ? _editingIdFaseCentro : 0,
            IdProceduraLavorazione = State.IdProcedura!.Value,
            IdCentro               = State.IdCentro!.Value,
            IdFaseLavorazione      = _selectedFaseId,
            FlagAttiva             = true,
            TipoTask               = State.TipoFonte?.ToTaskString(),
            CronExpression         = _selectedCron,
            GiorniPrecedenti       = _giorniPrecedenti,
            TestoQueryTask         = State.TipoFonte == TipoFonteData.SQL ? _queryText : null,
            HandlerClassName       = State.TipoFonte == TipoFonteData.HandlerIntegrato ? State.HandlerClassName : null
        };

        if (_editingIndex.HasValue)
        {
            // Sostituzione del mapping esistente alla posizione corrente
            StateService.UpdateState(s => s.WithMappingUpdate(_editingIndex.Value, mapping));
            _editingIndex = null;
        }
        else
        {
            StateService.UpdateState(s => s.WithMapping(mapping));
        }

        ResetForm();
    }

    /// <summary>Carica i dati di un mapping esistente nel form per la modifica.</summary>
    private void CaricaMappingInForm(int index)
    {
        var mapping = State.Mappings[index];
        _editingIndex        = index;
        _editingIdFaseCentro = mapping.IdFaseCentro;
        _selectedFaseId      = mapping.IdFaseLavorazione;
        _selectedCron        = mapping.CronExpression ?? "0 5 * * *";
        _giorniPrecedenti    = mapping.GiorniPrecedenti ?? TaskConfigurationDefaults.DefaultGiorniPrecedenti;
        _queryText           = mapping.TestoQueryTask;
        _selectedHandlerCode = mapping.HandlerClassName;
        _validationMessage   = null;
        // La query era già validata al momento del salvataggio — considera valida
        _queryValidated      = !string.IsNullOrWhiteSpace(_queryText);
    }

    /// <summary>Annulla la modifica in corso e reimposta il form.</summary> 
    private void AnnullaEdit()
    {
        _editingIndex        = null;
        _editingIdFaseCentro = 0;
        ResetForm();
    }

    private void ResetForm()
    {
        _queryText           = State.TipoFonte == TipoFonteData.SQL ? string.Empty : null;
        _validationMessage   = null;
        _queryValidated      = false;
        _giorniPrecedenti    = 10;
        _editingIdFaseCentro = 0;

        // Seleziona la prossima fase disponibile
        var currentIndex = State.FasiDisponibili.FindIndex(f => f.IdFaseLavorazione == _selectedFaseId);
        if (currentIndex >= 0 && currentIndex < State.FasiDisponibili.Count - 1)
            _selectedFaseId = State.FasiDisponibili[currentIndex + 1].IdFaseLavorazione;
    }
    
    private void RimuoviMapping(int index)
    {
        StateService.UpdateState(s => s.WithoutMapping(index));
    }
    
    /// <summary>
    /// Converte cron expression in descrizione leggibile.
    /// </summary>
    private static string GetCronDescription(string? cron) => CronPresets.GetLabel(cron);
}
