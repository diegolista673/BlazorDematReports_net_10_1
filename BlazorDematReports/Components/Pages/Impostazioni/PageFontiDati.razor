@page "/fonti-dati"
@using BlazorDematReports.Core.Services.Interfaces.IDataService
@using Entities.Models.DbApplication
@using Entities.Enums

@inject NavigationManager Navigation
@attribute [Authorize(Roles = "ADMIN,SUPERVISOR")]
@implements IAsyncDisposable
@inherits BaseComponentPage<PageFontiDati>

@inject IServiceConfigurazioneFontiDati serviceConfigurazioneFontiDati
@inject IServiceTaskDaEseguire serviceTaskDaEseguire
 

<PageTitle >Configurazioni Fonti Dati</PageTitle>

<MudText Typo="Typo.h4" Class="titolo ml-4">Configurazioni Fonti Dati</MudText>
<MudText Typo="Typo.body2" Class="text-muted ml-4">Gestione centralizzata delle sorgenti dati per produzione</MudText>

<MudDivider Class="border-solid border-1 mud-border-primary "></MudDivider>

<MudContainer MaxWidth="MaxWidth.False">
    <MudGrid Class="mt-2 ">

        @*form*@
        <MudItem xs="12" sm="12" md="12" lg="12" xl="12" Class="d-flex justify-end gap-2">
            <AuthorizeView Roles="ADMIN">
                <Authorized>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.PauseCircle"
                               Disabled="@_bulkActionInProgress"
                               OnClick="@DisableAllTasksAsync">
                        Disabilita Tutti i Task
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.PlayCircle"
                               Disabled="@_bulkActionInProgress"
                               OnClick="@EnableAllTasksAsync">
                        Abilita Tutti i Task
                    </MudButton>
                </Authorized>
            </AuthorizeView>

            <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        StartIcon="@Icons.Material.Filled.Add"
                        Disabled="@_bulkActionInProgress"
                        OnClick="@(() => Navigation.NavigateTo("/configura-fonte-dati-wizard"))">
                Nuova Configurazione
            </MudButton>
        </MudItem>

        @*table*@
        <MudItem xs="12" sm="12" md="12" lg="12" xl="12">
            @if (!_configurazioni.Any())
            {
                <MudAlert Severity="Severity.Info" Class="my-4">
                    <MudText>Nessuna configurazione presente. Clicca su "Nuova Configurazione" per iniziare.</MudText>
                </MudAlert>
            }
            else
            {

                <MudDataGrid T="ConfigurazioneRiepilogoDto"
                             Items="@_configurazioni"
                             Filterable="true"
                             FilterMode="DataGridFilterMode.Simple"
                             SortMode="SortMode.Multiple"
                             ReadOnly="false" 
                             Striped="true"  
                             Dense=true 
                             Bordered=true 
                             Hover=true 
                             Breakpoint="Breakpoint.Sm"
                             Outlined=false 
                             Height="100%">
                    <Columns>
                        <PropertyColumn Property="x => x.CodiceConfigurazione" Title="Codice" />
                        <PropertyColumn Property="x => x.Descrizione ?? string.Empty" Title="Descrizione" />

                        <TemplateColumn Title="Tipo">
                            <CellTemplate>
                                <MudChip T="string"
                                         Color="@GetTipoColor(context.Item.TipoFonte)"
                                         Size="Size.Small">
                                    @context.Item.TipoFonte
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>

                        <TemplateColumn Title="Fasi Configurate" Sortable="false">
                            <CellTemplate>
                                @if (context.Item.FasiDettaglio.Any())
                                {
                                    <MudText Typo="Typo.caption">
                                        @string.Join(", ", context.Item.FasiDettaglio.Distinct())
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Class="text-muted">Nessuna fase</MudText>
                                }
                            </CellTemplate>
                        </TemplateColumn>

                        <TemplateColumn Title="Schedulazioni" Sortable="false">
                            <CellTemplate>
                                @if (context.Item.CronExpressions.Any())
                                {
                                    <div>
                                        @foreach (var cron in context.Item.CronExpressions.Distinct())
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="mr-1 mb-1">
                                                @GetCronDescription(cron)
                                            </MudChip>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Class="text-muted">-</MudText>
                                }
                            </CellTemplate>
                        </TemplateColumn>

                        <PropertyColumn Property="x => x.NumeroFasi" Title="N. Mapping" Filterable="false" />
                        <PropertyColumn Property="x => x.TaskAttivi" Title="Task Attivi" Filterable="false" />


                        <TemplateColumn Title="Azioni" StickyRight>
                            <CellTemplate>
                                <MudTooltip Text="Modifica configurazione">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick="@(() => ModificaConfig(context.Item.IdConfigurazione))" />
                                </MudTooltip>

                                <MudTooltip Text="Gestione task associati (abilita/disabilita/elimina)">
                                    <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                                   Color="Color.Info"
                                                   Size="Size.Small"
                                                   OnClick="@(() => GestisciTaskAsync(context.Item))" />
                                </MudTooltip>

                                <MudTooltip Text="Elimina definitivamente la configurazione">
                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="@(() => EliminaConfigDefinitivaAsync(context.Item))" />
                                </MudTooltip>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>

                    <PagerContent>
                        <MudDataGridPager T="ConfigurazioneRiepilogoDto" />
                    </PagerContent>
                </MudDataGrid>
            }
        </MudItem>


    </MudGrid>
</MudContainer>



@code {

    private bool _bulkActionInProgress = false;
    private List<ConfigurazioneRiepilogoDto> _configurazioni = new();

    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        await RunWithOverlay(async () =>
        {
            _configurazioni = await serviceConfigurazioneFontiDati.GetConfigurazioneFontiDatiDtoAsync();
        }, "Caricamento configurazioni...");
    }

    private async Task LoadConfigurazioniAsync()
    {
        _configurazioni = await serviceConfigurazioneFontiDati.GetConfigurazioneFontiDatiDtoAsync();
    }

    private async Task DisableAllTasksAsync()
    {
        var parameters = new DialogParameters
        {
            ["ContentText"] = "Sei sicuro di voler DISABILITARE tutti i task del sistema? Le esecuzioni verranno saltate finché non saranno riabilitati.",
            ["ButtonText"] = "Disabilita tutti",
            ["Color"] = Color.Warning
        };

        var dialog = await DialogService!.ShowAsync<DialogConfirm>("Conferma Disabilitazione", parameters);
        var result = await dialog.Result;
        if (result?.Canceled == true)
            return;

        _bulkActionInProgress = true;
        try
        {
            UiState?.SetMenuDisabled(true);
            UiState?.ShowOverlay("Disabilitazione task in corso...");

            var count = await serviceTaskDaEseguire.DisableAllTasksAsync();
            await LoadConfigurazioniAsync();
            UiState?.ShowSnackbar($"Disabilitati {count} task", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Errore disabilitazione task");
            UiState?.ShowSnackbar($"Errore disabilitazione: {ex.Message}", Severity.Error);
        }
        finally
        {
            _bulkActionInProgress = false;
            UiState?.HideOverlay();
            UiState?.SetMenuDisabled(false);
        }
    }

    private async Task EnableAllTasksAsync()
    {
        var parameters = new DialogParameters
        {
            ["ContentText"] = "Sei sicuro di voler ABILITARE tutti i task del sistema?",
            ["ButtonText"] = "Abilita tutti",
            ["Color"] = Color.Success
        };

        var dialog = await DialogService!.ShowAsync<DialogConfirm>("Conferma Abilitazione", parameters);
        var result = await dialog.Result;
        if (result?.Canceled == true)
            return;

        _bulkActionInProgress = true;
        try
        {
            UiState?.SetMenuDisabled(true);
            UiState?.ShowOverlay("Abilitazione task in corso...");

            var count = await serviceTaskDaEseguire.EnableAllTasksAsync();
            await LoadConfigurazioniAsync();
            UiState?.ShowSnackbar($"Abilitati {count} task", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Errore abilitazione task");
            UiState?.ShowSnackbar($"Errore abilitazione: {ex.Message}", Severity.Error);
        }
        finally
        {
            _bulkActionInProgress = false;
            UiState?.HideOverlay();
            UiState?.SetMenuDisabled(false);
        }
    }

    /// <summary>
    /// Converte cron expression in descrizione leggibile.
    /// </summary>
    private static string GetCronDescription(string cron) => CronPresets.GetLabel(cron);

    private void ModificaConfig(int id)
    {
        Navigation.NavigateTo($"/configura-fonte-dati-wizard/{id}");
    }

    private async Task EliminaConfigDefinitivaAsync(ConfigurazioneRiepilogoDto config)
    {
        var contentText = config.TaskAttivi > 0
            ? $"Sei sicuro di voler ELIMINARE DEFINITIVAMENTE la configurazione '{config.CodiceConfigurazione}'\n\n" +
              $"{config.TaskAttivi} task attivi verranno rimossi da Hangfire e dal database.\n\n" +
              "Questa operazione è IRREVERSIBILE."
            : $"Sei sicuro di voler ELIMINARE DEFINITIVAMENTE la configurazione '{config.CodiceConfigurazione}'\n\n" +
              "Questa operazione è IRREVERSIBILE.";

        var parameters = new DialogParameters
        {
            ["ContentText"] = contentText,
            ["ButtonText"] = "Elimina definitivamente",
            ["Color"] = Color.Error
        };

        var dialog = await DialogService!.ShowAsync<DialogConfirm>("Conferma Eliminazione Definitiva", parameters);
        var result = await dialog.Result;

        if (result?.Canceled == true)
            return;

        try
        {
            UiState?.SetMenuDisabled(true);
            UiState?.ShowOverlay("Eliminazione in corso...");

            await serviceConfigurazioneFontiDati.DeleteConfigurazioneFontiDatiAsync(config.IdConfigurazione);
            await LoadConfigurazioniAsync();
            UiState?.ShowSnackbar("Configurazione eliminata definitivamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Errore eliminazione configurazione {Id}", config.IdConfigurazione);
            UiState?.ShowSnackbar($"Errore eliminazione definitiva: {ex.Message}", Severity.Error);
        }
        finally
        {
            UiState?.HideOverlay();
            UiState?.SetMenuDisabled(false);
        }
    }

    private async Task GestisciTaskAsync(ConfigurazioneRiepilogoDto config)
    {
        var parameters = new DialogParameters
        {
            ["IdConfigurazione"] = config.IdConfigurazione,
            ["CodiceConfigurazione"] = config.CodiceConfigurazione
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService!.ShowAsync<DialogGestioneTask>("Gestione Task", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
            await LoadConfigurazioniAsync();
    }

    private Color GetTipoColor(string tipoFonte)
    {
        if (Enum.TryParse<TipoFonteData>(tipoFonte, out var tipo))
            return TipoFonteDataHelper.GetColor(tipo);
        return Color.Default;
    }

    public override async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        await base.DisposeAsync();
    }

}
