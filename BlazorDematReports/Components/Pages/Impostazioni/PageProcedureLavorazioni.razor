@page "/procedure-lavorazioni"
@using BlazorDematReports.Core.Services.Interfaces.IDataService

@attribute [Authorize(Roles = "ADMIN,RESPONSABILE,SUPERVISOR")]
@implements IAsyncDisposable
@inherits BaseComponentPage<PageProcedureLavorazioni,ProcedureLavorazioniDto,ProcedureLavorazioniDto>
@inject NavigationManager NavigationManager
@inject BlazorDematReports.Core.DataReading.Infrastructure.IProductionJobScheduler ProductionScheduler
@inject IServiceCentri serviceCentri
@inject IServiceProcedureClienti serviceProcedureClienti
@inject IServiceRepartiProduzione serviceRepartiProduzione
@inject IServiceFormatoDati serviceFormatoDati
@inject IServiceFasiLavorazioni serviceFasiLavorazioni
@inject IServiceProcedureLavorazioni serviceProcedureLavorazioni

<MudText Typo="Typo.h4" Class="titolo ml-4">Procedure Lavorazioni</MudText>
<MudDivider Class="border-solid border-1 mud-border-primary "></MudDivider>

<MudContainer MaxWidth="MaxWidth.False">
    <MudGrid Class="mt-2">

        <!-- FORM INSERIMENTO -->
        <MudItem xs="12" lg="4">
            <MudCard Style="height: 100%">
                <MudCardContent>

                    <MudCardContent Class="pa-0">
                        <div class="d-flex justify-space-between flex-grow-1">
                            <MudText Typo="Typo.h6">Nuova Lavorazione</MudText>
                        </div>
                    </MudCardContent>

                    <EditForm EditContext="@EditContext" OnValidSubmit="HandleValidSubmitAsync">
                        <PageProcedureLavorazioniProvider />
                        <MudFocusTrap Disabled="false" DefaultFocus="DefaultFocus.FirstChild">

                            <!-- Centro -->
                            <MudSelect @ref="RefCentro" 
                                       T=int? 
                                       Label="Select Centro" 
                                       Style="width:200px" 
                                       Class="mt-3" 
                                       Margin="Margin.Dense" 
                                       Required="true" 
                                       For="(()=>Model!.Idcentro)" 
                                       Clearable 
                                       AutoFocus="true"
                                       ValueChanged="OnValueChangedCentroAsync">
                                @if (ListCentri != null)
                                {
                                    @foreach (var centro in ListCentri)
                                    {
                                        <MudSelectItem T=int? Value="@centro.Idcentro">@centro.Centro</MudSelectItem>
                                    }
                                }
                            </MudSelect>

                            <!-- Procedura Cliente -->
                            <MudAutocomplete T="string" 
                                             Label="Procedura Cliente" 
                                             @bind-Value=Model!.ProceduraCliente 
                                             Margin="Margin.Dense" 
                                             SearchFunc="@((string arg, CancellationToken ct)=>SearchFromSelect(base.SelectProceduraCliente,arg))" 
                                             MaxItems=null
                                             Clearable=true
                                             ResetValueOnEmptyText="true"
                                             Dense=true
                                             SelectOnActivation="true"
                                             Required 
                                             For="(()=>Model!.ProceduraCliente)" />

                            <!-- Formato Dati -->
                            <MudAutocomplete T="string" 
                                             Label="Formato Dati" 
                                             @bind-Value=Model!.FormatoDatiProduzione 
                                             Margin="Margin.Dense" 
                                             SearchFunc="@((string arg, CancellationToken ct)=>SearchFromSelect(base.SelectFormato,arg))" 
                                             MaxItems=null
                                             Clearable=true
                                             Required="true"
                                             ResetValueOnEmptyText="true"
                                             Dense=true
                                             SelectOnActivation="true"
                                             For="(()=>Model!.FormatoDatiProduzione)" />

                            <!-- Reparto -->
                            <MudAutocomplete @ref=RefReparto 
                                             T="string" 
                                             Label="Reparto" 
                                             @bind-Value=Model!.Reparto 
                                             Margin="Margin.Dense" 
                                             SearchFunc="@((string arg, CancellationToken ct)=>SearchFromSelect(base.SelectReparto,arg))" 
                                             MaxItems=null
                                             Clearable=true
                                             Required="true"
                                             ResetValueOnEmptyText="true"
                                             Dense=true
                                             SelectOnActivation="true"
                                             For="(()=>Model!.Reparto)" />

                            <!-- Nome Procedura -->
                            <MudTextField @ref=RefNomeProcedura 
                                          T="string" 
                                          Label="Lavorazione" 
                                          Variant="Variant.Text" 
                                          Margin="Margin.Dense" 
                                          Immediate="true" 
                                          ValueChanged="ValueChangeLavorazione" 
                                          Adornment="Adornment.End" 
                                          AdornmentText="@Sigla" 
                                          Required 
                                          For="(()=>Model!.NomeProcedura)" 
                                          Clearable 
                                          Value="@Model!.NomeProcedura"
                                          Text="@Model!.NomeProcedura" />

                            <!-- Note -->
                            <MudTextField T="string" 
                                          Label="Note" 
                                          @bind-Value=Model.Note 
                                          Lines="2" 
                                          Margin="Margin.Dense" 
                                          Clearable />

                            <!-- Upload Logo -->
                            <div class="d-flex align-center mt-4">
                                <MudFileUpload T=IBrowserFile 
                                               MaximumFileCount="1" 
                                               Accept=".png, .jpg" 
                                               @bind-Files=Model.LogoFile>
                                    <ActivatorContent>
                                        <MudButton HtmlTag="label" 
                                                   Variant="Variant.Filled" 
                                                   Color="Color.Info" 
                                                   Size="Size.Medium"
                                                   StartIcon="@Icons.Material.Filled.CloudUpload" 
                                                   FullWidth>
                                            Logo
                                        </MudButton>
                                    </ActivatorContent>
                                </MudFileUpload>
                                @if (Model.LogoFile != null)
                                {
                                    <MudList T="string" Dense>
                                        <MudListItem Icon="@Icons.Material.Filled.AttachFile">
                                            @Model.LogoFile.Name <code>@Model.FileSizeMB?.ToString("F2") MB</code>
                                        </MudListItem>
                                    </MudList>
                                }
                            </div>

                            <!-- Bottoni di azione -->
                            <div class="justify-end mt-5 d-flex align-center">
                                <MudButton ButtonType="ButtonType.Submit"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           Disabled="@(!IsFormValid)">
                                    Salva
                                </MudButton>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Secondary"
                                           StartIcon="@Icons.Material.Filled.Refresh"
                                           Disabled="@(!IsFormValid)"
                                           OnClick="ResetForm"
                                           Class="ml-2">
                                    Reset
                                </MudButton>
                            </div>

                        </MudFocusTrap>
                    </EditForm>

                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- TABELLA LAVORAZIONI -->
        <MudItem xs="12" lg="8">
            <MudDataGrid T="ProcedureLavorazioniDto" 
                        Items="@ListProcedureLavorazioniDto" 
                        ReadOnly="true" 
                        Filterable="true" 
                        FilterMode="@FilterMode" 
                        FilterCaseSensitivity="@CaseSensitivity"
                        Bordered=true 
                        Hover=true 
                        Dense=true 
                        Outlined=true 
                        Height="100%" 
                        Class="table-procedure-lavorazioni" 
                        Breakpoint="Breakpoint.Sm"
                        Striped="true">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Lavorazioni</MudText>
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x=>x.IdproceduraLavorazione" Title="ID" Sortable="false" Filterable="false" HeaderStyle="width:50px" />
                    <PropertyColumn Property="x=>x.NomeProcedura" Title="Procedura" Sortable="true" Style="width:35%">
                        <CellTemplate>
                            <MudLink Href="@($"scheda-lavorazione/{context.Item.IdproceduraLavorazione}")">
                                <MudText Typo="Typo.body2">@context.Item.NomeProcedura!.ToUpper()</MudText>
                            </MudLink>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x=>x.FormatoDatiProduzione" Title="Formato dati" Sortable="false" Filterable="false" Style="width:10%" />
                    <PropertyColumn Property="x=>x.Reparto" Title="Reparto" Sortable="false" Filterable="false" Style="width:10%" />
                    <PropertyColumn Property="x=>x.Centro" Title="Centro" Sortable="false" Filterable="false" Style="width:10%" />

                    <TemplateColumn CellClass="d-flex justify-end" Filterable="false">
                        <CellTemplate>
                            <MudStack Row>
                                <MudTooltip Text="Edit">
                                    <MudIconButton Size="@Size.Small" 
                                                    Icon="@Icons.Material.Outlined.Edit"
                                                    OnClick="@(() => NavigateToEdit(context.Item.IdproceduraLavorazione!.Value))" />
                                </MudTooltip>
                                <MudDivider Vertical="true" FlexItem="true" />
                                <MudTooltip Text="Delete">
                                    <MudIconButton OnClick="@((e) => DeleteProceduraLavorazioneAsync((int)@context.Item.IdproceduraLavorazione!, @context.Item.NomeProcedura!))" 
                                                    Size="@Size.Small" 
                                                    Icon="@Icons.Material.Filled.Delete" 
                                                    aria-label="delete" 
                                                    Color="Color.Error">
                                        Delete Records
                                    </MudIconButton>
                                </MudTooltip>
                            </MudStack>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="ProcedureLavorazioniDto" />
                </PagerContent>
            </MudDataGrid>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {

    #region Fields & Properties
    /// <summary>
    /// Opzioni del dialog per la configurazione della larghezza massima.
    /// </summary>
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large };

    private readonly CancellationTokenSource _cts = new();
    
    /// <summary>
    /// Riferimento al componente MudSelect per la selezione del centro.
    /// </summary>
    MudSelect<int?>? RefCentro;
    
    /// <summary>
    /// Riferimento al componente MudAutocomplete per la selezione del reparto.
    /// </summary>
    MudAutocomplete<string>? RefReparto;
    
    /// <summary>
    /// Riferimento al componente MudTextField per l'inserimento del nome procedura.
    /// </summary>
    MudTextField<string>? RefNomeProcedura;

    /// <summary>
    /// Indica se l'aggiunta di una fase č disabilitata.
    /// </summary>
    bool IsDisableAddFase { get; set; } = true;
    
    /// <summary>
    /// Indica se il checkbox per il grafico č selezionato.
    /// </summary>
    bool CheckedGrafico { get; set; }
    
    /// <summary>
    /// Indica se una fase č stata selezionata.
    /// </summary>
    bool IsSelectedFase { get; set; }
    
    /// <summary>
    /// Titolo della pagina.
    /// </summary>
    string? TitlePage { get; set; }
    
    /// <summary>
    /// Sigla associata al centro selezionato.
    /// </summary>
    string? Sigla { get; set; }
    
    /// <summary>
    /// Nome della fase di lavorazione selezionata.
    /// </summary>
    string? FaseLavorazione { get; set; }

    /// <summary>
    /// Lista delle fasi di lavorazione da aggiungere.
    /// </summary>
    List<LavorazioniFasiDataReadingDto> ListLavorazioniFasiDaAggiungere = new();
    
    /// <summary>
    /// Lista delle fasi di lavorazione disponibili.
    /// </summary>
    List<FasiLavorazione>? ListFasiLavorazione;
    
    /// <summary>
    /// DTO per la gestione delle fasi di lavorazione con data reading.
    /// </summary>
    LavorazioniFasiDataReadingDto lavorazioniFasiDataReadingDto = new();
    
    /// <summary>
    /// Lista dei task precedenti per il confronto durante l'aggiornamento.
    /// </summary>
    List<TaskDaEseguireDto>? ListPrevious;

    /// <summary>
    /// Indica se il dialog di caricamento č visibile.
    /// </summary>
    bool IsVisibleDialog = false;

    /// <summary>
    /// Indica se č possibile aggiungere un task alla fase selezionata.
    /// </summary>
    bool CanAddTask => !string.IsNullOrEmpty(FaseLavorazione) && 
                       ListLavorazioniFasiDaAggiungere.Any(f => f.FaseLavorazione == FaseLavorazione);
    #endregion

    #region Lifecycle
    /// <summary>
    /// Metodo di inizializzazione del componente. Carica tutti i dati necessari per la pagina.
    /// </summary>
    /// <returns>Task asincrono.</returns>
    protected override async Task OnInitializedAsync()
    {
        await RunWithOverlay(async () =>
        {
            SetEditContext();
            TitlePage = "Procedure Lavorazioni";
            
            // Avvia tutte le chiamate asincrone in parallelo
            var centriTask = serviceCentri.GetCentriByUserAsync();
            var procedureClienteTask = serviceProcedureClienti.GetProcedureClienteAsync();
            var repartiTask = serviceRepartiProduzione.GetRepartiProduzioneAsync();
            var formatoDatiTask = serviceFormatoDati.GetFormatoDatiAsync();
            var fasiTask = serviceFasiLavorazioni.GetFasiLavorazioneAsync();
            var procedureLavorazioniTask = serviceProcedureLavorazioni.GetAllProcedureLavorazioniDtoByUserAsync();

            await Task.WhenAll(centriTask, procedureClienteTask, repartiTask, formatoDatiTask,
                              fasiTask,procedureLavorazioniTask).WaitAsync(_cts.Token);
            
            // Assegnazione risultati
            ListCentri = centriTask.Result;
            ListProcedureCliente = procedureClienteTask.Result;
            SetSelectProcedureClienti();
            
            ListReparti = repartiTask.Result;
            SetSelectReparto();
            
            ListFormatoDati = formatoDatiTask.Result;
            SetSelectFormato();
            
            ListFasiLavorazione = fasiTask.Result;
            // Popola l'elenco delle fasi per la selezione nella nuova procedura
            SetSelectFasi();
            
            ListProcedureLavorazioniDto = procedureLavorazioniTask.Result;
        }, "Caricamento dati...");
    }
    #endregion

    #region CRUD Operations
    /// <summary>
    /// Gestisce l'inserimento di una nuova procedura di lavorazione dopo la validazione del form.
    /// Esegue un aggiornamento cascata all'interno di SQL Server.
    /// </summary>
    /// <returns>Task asincrono.</returns>
    protected async Task HandleValidSubmitAsync()
    {
        try
        {
            if (!string.IsNullOrEmpty(Model!.NomeProcedura))
            {
                UiState?.SetMenuDisabled(true);
                UiState?.ShowOverlay("Inserimento in corso...");

                Model.NomeProcedura = (Model.NomeProcedura).ToUpper() + Sigla;
                Model.DataInserimento = DateTime.Now;
                Model.Idoperatore = ConfigUser!.IdUtente;

                if(ListProcedureCliente != null){
                    var proCliente = ListProcedureCliente.FirstOrDefault(x => x.ProceduraCliente == Model.ProceduraCliente);
                    if (proCliente != null)
                    {
                        Model.IdproceduraCliente = proCliente.IdproceduraCliente;
                    }
                    else
                    {
                        throw new InvalidOperationException($"Procedura cliente '{Model.ProceduraCliente}' non trovata");
                    }
                }

                if (ListReparti != null)
                {
                    var reparto = ListReparti.FirstOrDefault(x => x.Reparti == Model.Reparto);
                    if (reparto != null)
                    {
                        Model.Idreparti = reparto.IdReparti;
                    }
                    else
                    {
                        throw new InvalidOperationException($"Reparto '{Model.Reparto}' non trovato");
                    }
                }

                if (ListFormatoDati != null)
                {
                    var formatoDati = ListFormatoDati.FirstOrDefault(x => x.FormatoDatiProduzione == Model.FormatoDatiProduzione);
                    if (formatoDati != null)
                    {
                        Model.IdformatoDatiProduzione = formatoDati.IdformatoDati;
                    }
                    else
                    {
                        throw new InvalidOperationException($"Formato dati '{Model.FormatoDatiProduzione}' non trovato");
                    }
                }

                if (Model.LogoFile != null)
                {
                    var buffers = new byte[Model.LogoFile.Size];
                    await Model.LogoFile.OpenReadStream().ReadAsync(buffers);
                    Model!.LogoBase64 = (string.Format("data: {0};base64,{1}", Model.LogoFile.ContentType, Convert.ToBase64String(buffers)));
                }

                Model.LavorazioniFasiDataReadingsDto = ListLavorazioniFasiDaAggiungere;

                Model.IdproceduraLavorazione = await serviceProcedureLavorazioni.AddProceduraLavorazioneAsync(Model);

                // Prepara context info per i task
                PrepareTaskContext(Model, ListPrevious);
                
                // Sincronizza tutti i task con Hangfire
                await ProductionScheduler.SyncAllAsync();

                //reload table
                ListProcedureLavorazioniDto = await serviceProcedureLavorazioni.GetAllProcedureLavorazioniDtoByUserAsync();

                await ResetForm();

                UiState?.SetMenuDisabled(false);
                UiState?.HideOverlay();
                UiState?.ShowSnackbar("Nuova Procedura Lavorazione inserita", Severity.Success);

                base.ErrorMessage = "";
            }
        }
        catch (Exception ex)
        {
            await ResetForm();
            await HandleExceptionFormAsync(ex);
        }
    }

    /// <summary>
    /// Avvia la modifica di un elemento nella griglia.
    /// </summary>
    /// <param name="item">Elemento da modificare.</param>
    /// <returns>Task asincrono.</returns>
    protected override async Task StartedEditingItem(ProcedureLavorazioniDto item)
    {
        try
        {
            ProcedureLavorazioniDto? lavorazioniDto = await serviceProcedureLavorazioni
                .GetSingleProceduraLavorazioneDtoByIDAsync((int)item.IdproceduraLavorazione!);

            ValueBeforeEdit = Mapper!.Map<ProcedureLavorazioniDto>(lavorazioniDto);

            // ? COPIA LE RELAZIONI NELL'ITEM DEL DATAGRID
            item.LavorazioniFasiDataReadingsDto = lavorazioniDto.LavorazioniFasiDataReadingsDto;
            item.QueryProcedureLavorazioniDto = lavorazioniDto.QueryProcedureLavorazioniDto;

            if (lavorazioniDto.LavorazioniFasiDataReadingsDto != null)
            {
                ListPrevious = lavorazioniDto.LavorazioniFasiDataReadingsDto.ToList()
                    .SelectMany(x => x.TaskDaEseguireDto).ToList();
            }
        }
        catch (Exception ex)
        {
            await HandleExceptionFormAsync(ex, "Error on StartedEditingItem");
        }
    }

    /// <summary>
    /// Gestisce l'aggiornamento di una riga nella griglia dopo le modifiche.
    /// </summary>
    /// <param name="item">Elemento aggiornato.</param>
    /// <returns>Task asincrono.</returns>
    protected async Task OnUpdateRowAsync(ProcedureLavorazioniDto item)
    {
        try
        {
            if (!string.IsNullOrEmpty(item.NomeProcedura))
            {
                UiState?.SetMenuDisabled(true);
                UiState?.ShowOverlay("Update in corso...");

                IsVisibleDialog = true;

                //ricarica l'entitŕ completa
                var fullItem = await serviceProcedureLavorazioni
                    .GetSingleProceduraLavorazioneDtoByIDAsync((int)item.IdproceduraLavorazione!);

                if (fullItem != null)
                {
                    // Copia i valori modificati dall'UI
                    fullItem.NomeProcedura = item.NomeProcedura;
                    fullItem.FormatoDatiProduzione = item.FormatoDatiProduzione;
                    fullItem.Reparto = item.Reparto;
                    fullItem.Note = item.Note;
                    fullItem.LogoFile = item.LogoFile;

                    // Usa fullItem per il resto del processo
                    item = fullItem;
                }

                //aggiorno formato dati produzione
                if (!string.IsNullOrEmpty(item.FormatoDatiProduzione))
                {
                    var formato = await serviceFormatoDati.GetFormatoDatiByTextAsync(item.FormatoDatiProduzione);
                    if (formato != null)
                    {
                        item.IdformatoDatiProduzione = formato.IdformatoDati;
                    }
                }

                //aggiorno reparto
                if (!string.IsNullOrEmpty(item.Reparto))
                {
                    var rep = await serviceRepartiProduzione.GetRepartiProduzioneByTextAsync(item.Reparto);
                    if (rep != null)
                    {
                        item.Idreparti = rep.IdReparti;
                    }
                }

                //aggiorno logo
                if (item.LogoFile != null)
                {
                    var buffers = new byte[item.LogoFile.Size];
                    await item.LogoFile.OpenReadStream().ReadAsync(buffers);
                    item.LogoBase64 = (string.Format("data: {0};base64,{1}", item.LogoFile.ContentType, Convert.ToBase64String(buffers)));
                }
                                
                await serviceProcedureLavorazioni.UpdateProceduraLavorazioneAndFasiDataReadingASync(item);

                // Prepara context info per i task
                PrepareTaskContext(item, ListPrevious);
                
                // Sincronizza tutti i task con Hangfire
                await ProductionScheduler.SyncAllAsync();

                await ResetForm();

                ListLavorazioniFasiDaAggiungere!.Clear();

                //reload table
                ListProcedureLavorazioniDto = await serviceProcedureLavorazioni.GetAllProcedureLavorazioniDtoByUserAsync();

                UiState?.SetMenuDisabled(false);
                UiState?.HideOverlay();
                UiState?.ShowSnackbar("Update eseguito", Severity.Success);
                
                IsVisibleDialog = false;
            }
            else
            {
                await NotificationDialog!.ShowNotification("La Procedura Lavorazione non puň essere vuota", "OK", Color.Error, "Error");
                item.ProceduraCliente = ValueBeforeEdit!.ProceduraCliente;
            }
        }
        catch (Exception ex)
        {
            IsVisibleDialog = false;
            await HandleExceptionFormAsync(ex);
        }
    }
    #endregion

    #region Delete Operations
    /// <summary>
    /// Elimina una procedura di lavorazione con cancellazione cascata all'interno di SQL Server.
    /// </summary>
    /// <param name="idProceduraLavorazione">ID della procedura da eliminare.</param>
    /// <param name="lavorazione">Nome della lavorazione per la conferma.</param>
    /// <returns>Task asincrono.</returns>
    protected async Task DeleteProceduraLavorazioneAsync(int idProceduraLavorazione, string lavorazione)
    {
        var parameters = new DialogParameters();
        parameters.Add("ContentText", "Eliminare : " + lavorazione + " ?");
        parameters.Add("ButtonText", "Delete");
        parameters.Add("Color", Color.Error);

        var options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService!.ShowAsync<Dialog>("Elimina Record", parameters, options);
        var result = await dialog.Result;

        if (result != null)
        {
            if (!result.Canceled)
            {
                try
                {
                    var pl = (await serviceProcedureLavorazioni.FindByConditionAsync(x => x.IdproceduraLavorazione == idProceduraLavorazione)).FirstOrDefault();
                    if (pl != null)
                    {
                        UiState?.ShowOverlay("Eliminazione in corso...");
                        UiState?.SetMenuDisabled(true);

                        await serviceProcedureLavorazioni.DeleteProceduraLavorazioneAsync(pl.IdproceduraLavorazione);
                        
                        // Integrazione nuovo scheduler
                        await ProductionScheduler.SyncAllAsync();
                        
                        ListProcedureLavorazioniDto = await serviceProcedureLavorazioni.GetAllProcedureLavorazioniDtoByUserAsync();

                        UiState?.HideOverlay();
                        UiState?.SetMenuDisabled(false);
                        UiState?.ShowSnackbar("Procedura Lavorazione eliminata", Severity.Success);

                        base.ErrorMessage = "";
                    }
                }
                catch (Exception ex)
                {
                    await HandleExceptionFormAsync(ex);
                }
            }
        }
    }
    #endregion

    #region Scheduler Helpers
    /// <summary>
    /// Prepara il contesto per i task (informazioni procedura/fase).
    /// La registrazione effettiva in Hangfire avviene tramite ProductionScheduler.SyncAllAsync().
    /// </summary>
    /// <param name="procedureLavorazioniDto">Procedura di lavorazione con i task.</param>
    /// <param name="listTaskPrevious">Lista dei task precedenti per cleanup.</param>
    protected void PrepareTaskContext(ProcedureLavorazioniDto procedureLavorazioniDto, List<TaskDaEseguireDto>? listTaskPrevious)
    {
        if (procedureLavorazioniDto.LavorazioniFasiDataReadingsDto != null)
        {
            // Task presenti
            var ListTaskDaEseguireDto = procedureLavorazioniDto.LavorazioniFasiDataReadingsDto.ToList().SelectMany(x => x.TaskDaEseguireDto).ToList();
        
            // Task eliminati - rimuovi da Hangfire
            if (listTaskPrevious != null){
                var taskEliminati = listTaskPrevious.Except(ListTaskDaEseguireDto).ToList();

                if (taskEliminati != null)
                {
                    foreach (var task in taskEliminati)
                    {
                        RecurringJob.RemoveIfExists(task.IdTaskHangFire);
                    }
                }
            }

            // Aggiorna context info per tutti i task
            foreach (var taskDaEseguireDto in ListTaskDaEseguireDto)
            {
                if (taskDaEseguireDto != null)
                {
                    taskDaEseguireDto.Lavorazione = procedureLavorazioniDto.NomeProcedura!;
                    taskDaEseguireDto.IdProceduraLavorazione = (int)procedureLavorazioniDto.IdproceduraLavorazione!;
                }
            }
        }
    }
    #endregion

    #region Event Handlers
    /// <summary>
    /// Gestisce il cambio di valore del centro selezionato.
    /// </summary>
    /// <param name="idCentro">ID del centro selezionato.</param>
    /// <returns>Task asincrono.</returns>
    protected async Task OnValueChangedCentroAsync(int? idCentro)
    {
        try
        {
            Model!.Idcentro = idCentro;

            if (idCentro != null)
            {
                var centro = ListCentri?.FirstOrDefault(x => x.Idcentro == idCentro);
                if (centro != null)
                {
                    Model.Centro = centro.Centro;
                    Sigla = "_" + centro.Sigla;

                    ListProcedureCliente = await serviceProcedureClienti.GetProcedureClienteByCentroAsync((int)idCentro);
                    SetSelectProcedureClienti();
                }
                else
                {
                    Logger!.LogWarning("Centro con ID {IdCentro} non trovato", idCentro);
                }
            }
            else
            {
                await ResetForm();
            }
        }
        catch (Exception ex)
        {
            Logger!.LogError(ex.Message.ToString());

            var parameters1 = new DialogParameters();
            parameters1.Add("ContentText", ex.Message.ToString());
            parameters1.Add("ButtonText", "OK");
            parameters1.Add("Color", Color.Error);

            var options1 = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Medium };
            await DialogService!.ShowAsync<Dialog>("Error", parameters1, options1);
        }
    }

    /// <summary>
    /// Gestisce il cambio di valore della fase selezionata.
    /// </summary>
    /// <param name="faseLavorazione">Nome della fase di lavorazione selezionata.</param>
    protected void OnValueChangedFase(string faseLavorazione)
    {
        var fase = ListFasiLavorazione?.FirstOrDefault(x => x.FaseLavorazione == faseLavorazione);
        if (fase == null)
        {
            lavorazioniFasiDataReadingDto.FlagGraficoDocumenti = false;
            lavorazioniFasiDataReadingDto = new();
            FaseLavorazione = null;
            return;
        }

        FaseLavorazione = fase.FaseLavorazione;
        int idFase = fase.IdFaseLavorazione;
        lavorazioniFasiDataReadingDto.IdFaseLavorazione = idFase;
        IsSelectedFase = true;
        lavorazioniFasiDataReadingDto.TaskDaEseguireDto.Clear();
    }

    /// <summary>
    /// Gestisce il cambio di valore del nome della procedura di lavorazione.
    /// </summary>
    /// <param name="nomeProcedura">Nome della procedura di lavorazione.</param>
    protected void ValueChangeLavorazione(string nomeProcedura)
    {
        Model!.NomeProcedura = nomeProcedura;

        if (!string.IsNullOrEmpty(Model.NomeProcedura))
        {
            IsDisableAddFase = false;
        }
        else
        {
            ListLavorazioniFasiDaAggiungere!.Clear();
            IsDisableAddFase = true;
        }

        StateHasChanged();
    }

    /// <summary>
    /// Gestisce il cambio di stato del checkbox per il grafico documenti.
    /// </summary>
    /// <param name="arg">Valore del checkbox.</param>
    /// <param name="ProcedureLavorazioniDto">Procedura di lavorazione.</param>
    /// <param name="row">Riga della fase di lavorazione.</param>
    protected void OnCheckedChanged(bool arg, ProcedureLavorazioniDto ProcedureLavorazioniDto, LavorazioniFasiDataReadingDto row)
    {
        //una sola fase ammessa in grafico documenti
        foreach (var item in ProcedureLavorazioniDto.LavorazioniFasiDataReadingsDto!)
        {
            item.FlagGraficoDocumenti = false;
        }

        row.FlagGraficoDocumenti = arg;
    }
    #endregion

    #region Reset
    /// <summary>
    /// Resetta il form e i suoi controlli allo stato iniziale.
    /// </summary>
    /// <returns>Task asincrono.</returns>
    protected async Task ResetForm()
    {
        IsFormValid = false;
        IsDisableAddFase = true;
        base.ResetFormModel();

        ListLavorazioniFasiDaAggiungere.Clear();

        SelectProceduraCliente!.Clear();
        Sigla = "";

        if (RefCentro != null)
            await RefCentro.ClearAsync();
    }
    #endregion

    #region Navigation
    /// <summary>
    /// Naviga alla pagina di modifica della procedura di lavorazione.
    /// </summary>
    /// <param name="idProcedura">ID della procedura da modificare.</param>
    protected void NavigateToEdit(int idProcedura)
    {
        NavigationManager!.NavigateTo($"/procedure-lavorazioni/edit/{idProcedura}");
    }
    #endregion

    public ValueTask DisposeAsync()
    {
        _cts.Cancel();
        return ValueTask.CompletedTask;
    }
}

