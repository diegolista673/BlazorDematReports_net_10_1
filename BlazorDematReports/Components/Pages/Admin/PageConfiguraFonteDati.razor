@page "/admin/configura-fonte-dati"
@page "/admin/configura-fonte-dati/{IdConfigurazione:int}"
@inherits BaseComponentPage<PageConfiguraFonteDati>
@using Entities.Models.DbApplication
@using Microsoft.EntityFrameworkCore
@using LibraryLavorazioni.Shared.Discovery
@using BlazorDematReports.Services.Validation
@inject IDbContextFactory<DematReportsContext> DbFactory
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject SqlValidationService SqlValidator
@attribute [Authorize(Roles = "ADMIN,SUPERVISOR")]

<PageTitle>Configurazione Fonte Dati</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
        Configurazione Fonte Dati
    </MudText>

    <MudPaper Class="pa-4">
        <MudGrid>
            @* TIPO FONTE *@
            <MudItem xs="12">
                <MudText Typo="Typo.h6" Class="mb-3">1. Seleziona Tipo Fonte</MudText>
                <MudRadioGroup Value="@_config.TipoFonte" 
                               ValueChanged="@((string v) => OnTipoFonteChangedAsync(v))">
                    <MudRadio Value="@("SQL")" Color="Color.Primary">Query SQL - Query diretta a database</MudRadio>
                    <MudRadio Value="@("EmailCSV")" Color="Color.Secondary">Email CSV - Allegati da servizi email</MudRadio>
                    <MudRadio Value="@("HandlerIntegrato")" Color="Color.Tertiary">Handler C# - Logica complessa</MudRadio>
                    <MudRadio Value="@("Pipeline")" Color="Color.Info">Pipeline - Elaborazione multi-step</MudRadio>
                </MudRadioGroup>
            </MudItem>

            <MudItem xs="12"><MudDivider /></MudItem>

            @* DETTAGLI BASE *@
            <MudItem xs="12">
                <MudText Typo="Typo.h6" Class="mb-3">2. Seleziona Procedura di lavorazione</MudText>
            </MudItem>

            @* Solo Lavorazione *@
            <MudItem xs="12" >
                <MudAutocomplete T="string"
                                 Label="Lavorazione"
                                 SearchFunc="@((string arg, CancellationToken ct) => SearchFromSelect(base.SelectLavorazione, arg))"
                                 MaxItems="null"
                                 Clearable="true"
                                 ResetValueOnEmptyText="true"
                                 SelectOnActivation="true"
                                 Required="true"
                                 Value="@_selectedLavorazione"
                                 ValueChanged="@OnValueChangedLavorazioneAsync"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.Assignment" />

                @* Codice Univoco (calcolato dalla fase del mapping) *@
                <MudItem xs="12" >
                    <MudTextField @bind-Value="_config.CodiceConfigurazione"
                                  Label="Codice Univoco"
                                  Variant="Variant.Outlined"
                                  ReadOnly="true"
                                  Dense="true" />
                </MudItem>
            </MudItem>

            <MudItem xs="12"><MudDivider /></MudItem>

            @* CONFIGURAZIONE SPECIFICA *@
            <MudItem xs="12">
                <MudText Typo="Typo.h6" Class="mb-3">3. Configurazione Specifica</MudText>
            </MudItem>

            @if (_config.TipoFonte == "SQL")
            {
                <MudItem xs="12" md="6">
                    <MudSelect T="string" 
                               @bind-Value="_config.ConnectionStringName"
                               Label="Connection String"
                               Variant="Variant.Outlined"
                               Required="true">
                        @foreach (var cs in _connectionStrings)
                        {
                            <MudSelectItem Value="@cs">@cs</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                
                @* Linee guida Query SQL *@
                <MudItem xs="12">
                    <MudPaper Elevation="3" Class="pa-4 mb-3">
                        <MudText Typo="Typo.body2" Class="mb-2"><b>Linee guida per le query SQL:</b></MudText>
                        
                        <MudText Typo="Typo.body2" Class="mb-1">1. <b>Formato dei risultati:</b></MudText>
                        <ul style="margin-left: 20px;">
                            <li><MudText Typo="Typo.body2">Il risultato deve indicare il numero di documenti, fogli, pagine raggruppati per data di lavorazione e operatore.</MudText></li>
                            <li><MudText Typo="Typo.body2">L'intestazione deve corrispondere esattamente a: <b>Operatore, DataLavorazione, Documenti, Fogli, Pagine</b></MudText></li>
                        </ul>

                        <MudText Typo="Typo.body2" Class="mb-1 mt-2">2. <b>Identificazione univoca degli operatori:</b></MudText>
                        <ul style="margin-left: 20px;">
                            <li><MudText Typo="Typo.body2">Utilizzare una clausola WHERE con criteri specifici (es: department = 'genova')</MudText></li>
                            <li><MudText Typo="Typo.body2"><b>Attenzione:</b> Se non è possibile identificare operatori e centro, il sistema proverà a riconoscerli automaticamente. Se non riconosciuti verranno eliminati.</MudText></li>
                        </ul>

                        <MudText Typo="Typo.body2" Class="mb-1 mt-2">3. <b>Parametrizzazione delle date:</b></MudText>
                        <ul style="margin-left: 20px;">
                            <li><MudText Typo="Typo.body2">Sostituire le date con i parametri <code>@@StartDate</code> e <code>@@EndDate</code></MudText></li>
                        </ul>

                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.caption"><b>Esempio:</b></MudText>
                        <MudText Typo="Typo.caption" Style="font-family: monospace; white-space: pre-wrap;" Class="mt-1">
                            SELECT op_scan AS <b>Operatore</b>,
                                   CONVERT(DATE, data_scan) AS <b>DataLavorazione</b>,
                                   COUNT(*) AS <b>Documenti</b>,
                                   SUM(CONVERT(INT, num_pag))/2 AS <b>Fogli</b>,
                                   SUM(CONVERT(INT, num_pag)) AS <b>Pagine</b>
                            FROM z0072370_rdmkt_28aut_ge_uda_dettaglio
                            WHERE <b>department = 'genova'</b>
                              AND data_scan >= <b>@@StartDate</b>
                              AND data_scan &lt;= <b>@@EndDate</b>
                            GROUP BY op_scan, CONVERT(DATE, data_scan)
                        </MudText>
                    </MudPaper>
                </MudItem>

                @* testo della query *@
                <MudItem xs="12">
                    <MudTextField @bind-Value="_config.TestoQuery"
                                  Label="Query SQL"
                                  Variant="Variant.Outlined"
                                  Lines="15"
                                  Required="true"
                                  Style="font-family: monospace;" spellcheck="false" />
                    <MudText Typo="Typo.caption" Class="mt-1">
                        Parametri obbligatori: @@StartDate, @@EndDate | Colonne obbligatorie: Operatore, DataLavorazione, Documenti, Fogli, Pagine
                    </MudText>
                </MudItem>

                
                @* Pulsanti Test Connessione e Valida Query *@
                <MudItem xs="12" Class="d-flex gap-2 mt-2">
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Info"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Cable"
                               OnClick="TestConnectionAsync"
                               Disabled="_testingConnection || string.IsNullOrWhiteSpace(_config.ConnectionStringName)">
                        @if (_testingConnection) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                        Test Connessione
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.VerifiedUser"
                               OnClick="ValidateQueryAsync"
                               Disabled="_validatingQuery || string.IsNullOrWhiteSpace(_config.TestoQuery)">
                        @if (_validatingQuery) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                        Valida Query
                    </MudButton>
                </MudItem>
                
                @* Alert risultato validazione *@
                @if (!string.IsNullOrWhiteSpace(_validationMessage))
                {
                    <MudItem xs="12">
                        <MudAlert Severity="@_validationSeverity" Dense Elevation="1" Class="mb-2">
                            @_validationMessage
                        </MudAlert>
                    </MudItem>
                }
            }
            else if (_config.TipoFonte == "EmailCSV")
            {
                <MudItem xs="12" md="6">
                    <MudSelect T="string" 
                               @bind-Value="_config.MailServiceCode"
                               Label="Mail Service"
                               Variant="Variant.Outlined"
                               Required="true">
                        @foreach (var ms in _mailServices)
                        {
                            <MudSelectItem Value="@ms">@ms</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }
            else if (_config.TipoFonte == "HandlerIntegrato")
            {
                <MudItem xs="12" md="6">
                    <MudSelect T="string" 
                               @bind-Value="_config.HandlerClassName"
                               Label="Handler C#"
                               Variant="Variant.Outlined"
                               Required="true">
                        @foreach (var handler in _availableHandlers)
                        {
                            <MudSelectItem Value="@handler.ClassName">@handler.ClassName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }
            else if (_config.TipoFonte == "Pipeline")
            {
                <MudItem xs="12" md="6">
                    <MudSelect T="string" 
                               @bind-Value="_config.ConnectionStringName"
                               Label="Connection String Base"
                               Variant="Variant.Outlined">
                        @foreach (var cs in _connectionStrings)
                        {
                            <MudSelectItem Value="@cs">@cs</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info">Pipeline multi-step in sviluppo.</MudAlert>
                </MudItem>
            }

            <MudItem xs="12"><MudDivider /></MudItem>

            @* MAPPING FASI/CENTRI *@
            <MudItem xs="12">
                <MudText Typo="Typo.h6" Class="mb-3">4. Configurazione Mapping</MudText>
            </MudItem>

            @* Descrizione della configurazione *@
            <MudItem xs="12">
                <MudTextField @bind-Value="_config.DescrizioneConfigurazione"
                              Label="Descrizione Configurazione"
                              Variant="Variant.Outlined"
                              Lines="2"
                              HelperText="Descrizione globale per questa configurazione" />
            </MudItem>

            <MudItem xs="12"><MudDivider /></MudItem>

            @* Mapping Fasi/Centri Header *@
            <MudItem xs="12">
                <div class="d-flex justify-end mb-3">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="AggiungiMapping">
                        + Aggiungi Mapping
                    </MudButton>
                </div>
            </MudItem>

            @foreach (var (mapping, index) in _mappingFasi.Select((m, i) => (m, i)))
            {
                <MudItem xs="12">
                    <MudPaper Class="pa-3" Elevation="1">
                        <MudGrid>

                            <MudItem xs="12" md="3">
                                <MudSelect T="int" 
                                           @bind-Value="mapping.IdFaseLavorazione"
                                           Label="Fase"
                                           Variant="Variant.Outlined"
                                           Dense="true"
                                           Disabled="@(!_fasiPerProcedura.Any())"
                                           Required="true">
                                    @foreach (var f in _fasiPerProcedura)
                                    {
                                        <MudSelectItem Value="@f.IdFaseLavorazione">@f.FaseLavorazione</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" md="2">
                                <MudSelect T="string" 
                                           Value="@GetCronFromMapping(index)"
                                           ValueChanged="@(v => SetCronForMapping(index, v))"
                                           Label="Schedulazione"
                                           Variant="Variant.Outlined"
                                           Dense="true">
                                    <MudSelectItem Value="@("0 5 * * *")">Giornaliero 05:00</MudSelectItem>
                                    <MudSelectItem Value="@("0 2 * * *")">Giornaliero 02:00</MudSelectItem>
                                    <MudSelectItem Value="@("0 */4 * * *")">Ogni 4 ore</MudSelectItem>
                                    <MudSelectItem Value="@("0 * * * *")">Ogni ora</MudSelectItem>
                                    <MudSelectItem Value="@("0 0 1 * *")">Mensile (1° giorno)</MudSelectItem>
                                    <MudSelectItem Value="@("custom")">Personalizzato</MudSelectItem>
                                </MudSelect>
                            </MudItem>

@*                             @if (GetCronFromMapping(index) == "custom" || !IsPresetCron(GetCronFromMapping(index)))
                            {
                                <MudItem xs="12" md="2">
                                    <MudTextField Value="@GetCronFromMapping(index)"
                                                  ValueChanged="@((string v) => SetCronForMapping(index, v))"
                                                  Label="Cron Custom"
                                                  Variant="Variant.Outlined"
                                                  Dense="true"
                                                  Placeholder="0 5 * * *"
                                                  HelperText="Formato: min ora giorno mese giornosett" />
                                </MudItem>
                            } *@

                            <MudItem xs="12" md="1" Class="d-flex align-center">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Size="Size.Large"
                                               Color="Color.Error"
                                               OnClick="@(() => RimuoviMapping(mapping))" />
                            </MudItem>
                        </MudGrid>

                        @* Parametri JSON - riga separata *@
                        <MudGrid Class="mt-2">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="mapping.ParametriExtra"
                                              Label="Parametri JSON"
                                              Variant="Variant.Outlined"
                                              ReadOnly="true"
                                              Lines="2"
                                              Placeholder='{"dept": "VR"}' />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            }

            <MudItem xs="12"><MudDivider Class="my-4" /></MudItem>

            @* AZIONI *@
            <MudItem xs="12">
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               OnClick="SalvaConfigurazioneAsync"
                               Disabled="@_saving">
                        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                        Salva Configurazione
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               OnClick="@(() => Navigation.NavigateTo("/admin/fonti-dati"))">
                        Annulla
                    </MudButton>
                </div>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>

@code {


    [Parameter] public int? IdConfigurazione { get; set; }
    [SupplyParameterFromQuery(Name = "idProcedura")]

    public int? IdProceduraPrecompilata { get; set; }
    private string? _selectedLavorazione;
    private int _selectedIdProcedura = 0;
    private bool _initializing = true;
    private bool _isEdit => IdConfigurazione.HasValue;
    private bool _saving = false;
    private bool _testingConnection = false;
    private bool _validatingQuery = false;
    private string? _validationMessage;
    private int _selectedFaseId = 0;

    private int _selectedCentroId = 0;

    private Severity _validationSeverity = Severity.Info;
    private ConfigurazioneFontiDati _config = new() { FlagAttiva = true, TipoFonte = "SQL" };

    private List<ConfigurazioneFaseCentro> _mappingFasi = new();
    private List<string> _connectionStrings = new();
    private List<string> _mailServices = new() { "HERA16", "ADER4" };
    private IReadOnlyList<HandlerInfo> _availableHandlers = new List<HandlerInfo>();
    private List<ProcedureLavorazioni> _procedure = new();
    private List<FasiLavorazione> _fasi = new();
    private List<FasiLavorazione> _fasiPerProcedura = new();
    private List<CentriLavorazione> _centri = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _initializing = true;
            UiState?.ShowOverlay("Caricamento lavorazioni...");

            // Carica liste per autocomplete
            ListProcedureLavorazioni = await ServiceWrapper!.ServiceProcedureLavorazioni.GetTableProcedureLavorazioniByUserAsync();
            SetSelectLavorazione();

        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error initializing PageSchedaLavorazione");
            UiState?.ShowSnackbar($"Errore durante l'inizializzazione: {ex.Message}", Severity.Error);
        }
        finally
        {
            _initializing = false;
            UiState?.HideOverlay();
        }


        _connectionStrings = Configuration.GetSection("ConnectionStrings")
            .GetChildren()
            .Select(c => c.Key)                 
            .Where(key => !key.StartsWith("_")) 
            .ToList();

        _availableHandlers = HandlerDiscoveryService.AvailableHandlers;

        // Usa i service wrapper invece di query dirette
        _fasi = await ServiceWrapper!.ServiceFasiLavorazioni.GetFasiLavorazioneAsync();
        _centri = await ServiceWrapper!.ServiceCentri.GetCentriByUserAsync();

        // Carica le procedure già disponibili dalla base
        _procedure = ListProcedureLavorazioni ?? new List<ProcedureLavorazioni>();

        // Per ConfigurazioneFontiDati usiamo il context direttamente (non c'è ancora un service wrapper)
        await using var context = await DbFactory.CreateDbContextAsync();

        if (_isEdit)
        {
            var config = await context.ConfigurazioneFontiDatis
                .Include(c => c.ConfigurazioneFaseCentros)
                .FirstOrDefaultAsync(c => c.IdConfigurazione == IdConfigurazione);

            if (config != null)
            {
                _config = config;
                _mappingFasi = config.ConfigurazioneFaseCentros.Where(fc => fc.FlagAttiva).ToList();
            }
        }
        else if (IdProceduraPrecompilata.HasValue)
        {
            // Pre-aggiungi mapping per la procedura specificata
            _mappingFasi.Add(new ConfigurazioneFaseCentro 
            { 
                IdProceduraLavorazione = IdProceduraPrecompilata.Value,
                FlagAttiva = true 
            });

            Snackbar.Add($"Mapping pre-compilato per la procedura selezionata", Severity.Info);
        }
    }


    private async Task OnValueChangedLavorazioneAsync(string? lavorazione)
    {
        _selectedLavorazione = lavorazione;

        if (string.IsNullOrEmpty(lavorazione))
        {
            ClearCurrentConfig();
            return;
        }

        try
        {
            UiState?.ShowOverlay("Caricamento lavorazione...");

            var procedura = ListProcedureLavorazioni?.FirstOrDefault(x => x.NomeProcedura == lavorazione);

            if (procedura?.IdproceduraLavorazione != null && procedura.IdproceduraLavorazione > 0)
            {
                // Traccia l'ID della procedura selezionata
                _selectedIdProcedura = procedura.IdproceduraLavorazione;

                // Estrai il centro dalla procedura
                _selectedCentroId = procedura.Idcentro;

                _config.CodiceConfigurazione = $"Config{_selectedIdProcedura:D4}";
                _config.DescrizioneConfigurazione = $"Configurazione_{lavorazione}";

                // Carica fasi associate a questa procedura utilizzando la tabella di mapping LavorazioniFasiDataReadings
                await using var _ctx = await DbFactory.CreateDbContextAsync();

                // Carica le fasi collegate tramite join
                _fasiPerProcedura = await _ctx.LavorazioniFasiDataReadings
                    .Where(l => l.IdProceduraLavorazione == procedura.IdproceduraLavorazione)
                    .Select(l => l.IdFaseLavorazioneNavigation)
                    .OrderBy(f => f.FaseLavorazione)
                    .ToListAsync();

                await InvokeAsync(StateHasChanged);
            }
            else
            {
                ClearCurrentConfig();
                UiState?.ShowSnackbar("Lavorazione non trovata", Severity.Warning);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error loading procedure: {ProcedureName}", lavorazione);
            UiState?.ShowSnackbar($"Errore nel caricamento: {ex.Message}", Severity.Error);
            ClearCurrentConfig();
        }
        finally
        {
            UiState?.HideOverlay();
        }
    }


    private void ClearCurrentConfig()
    {
        _config = new ConfigurazioneFontiDati { FlagAttiva = true, TipoFonte = "SQL" };
        _selectedLavorazione = null;
        _selectedIdProcedura = 0;
        _fasiPerProcedura.Clear();
        _selectedFaseId = 0;
        _selectedCentroId = 0;
        _mappingFasi.Clear();
        _config.DescrizioneConfigurazione = null;

        // Pulisci i campi di configurazione specifici del tipo fonte
        _config.ConnectionStringName = null;
        _config.TestoQuery = null;
        _config.MailServiceCode = null;
        _config.HandlerClassName = null;

        // Pulisci i messaggi di validazione
        _validationMessage = null;
        _validationSeverity = Severity.Info;
    }



    private async Task OnTipoFonteChangedAsync(string newTipoFonte)
    {

        ClearCurrentConfig();
        _config.TipoFonte = newTipoFonte;

        // Pulisci solo i campi specifici del tipo fonte
        _config.ConnectionStringName = null;
        _config.TestoQuery = null;
        _config.MailServiceCode = null;
        _config.HandlerClassName = null;
        _validationMessage = null;
        _validationSeverity = Severity.Info;

        await InvokeAsync(StateHasChanged);
    }





    private void AggiungiMapping()
    {
        // Verifica che procedura e centro siano stati selezionati
        if (_selectedIdProcedura == 0 || _selectedCentroId == 0)
        {
            Snackbar.Add("Seleziona prima una lavorazione", Severity.Warning);
            return;
        }

        _mappingFasi.Add(new ConfigurazioneFaseCentro 
        { 
            IdProceduraLavorazione = _selectedIdProcedura,
            IdCentro = _selectedCentroId,
            FlagAttiva = true 
        });
    }


    private void RimuoviMapping(ConfigurazioneFaseCentro mapping)
    {
        _mappingFasi.Remove(mapping);
    }


    /// <summary>
    /// Estrae il cron dai ParametriExtra JSON del mapping.
    /// Se non presente, restituisce il default "0 5 * * *".
    /// </summary>
    private string GetCronFromMapping(int index)
    {
        if (index >= _mappingFasi.Count) return "0 5 * * *";

        var mapping = _mappingFasi[index];
        if (string.IsNullOrWhiteSpace(mapping.ParametriExtra))
            return "0 5 * * *";

        try
        {
            var json = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(mapping.ParametriExtra);
            if (json != null && json.TryGetValue("cron", out var cronValue))
            {
                return cronValue?.ToString() ?? "0 5 * * *";
            }
        }
        catch
        {
            // JSON malformato o chiave 'cron' non presente
        }

        return "0 5 * * *";
    }

    /// <summary>
    /// Imposta il cron nei ParametriExtra JSON del mapping, preservando altri parametri.
    /// </summary>
    private void SetCronForMapping(int index, string? cronValue)
    {
        if (index >= _mappingFasi.Count) return;
        if (string.IsNullOrWhiteSpace(cronValue)) cronValue = "0 5 * * *";

        var mapping = _mappingFasi[index];
        Dictionary<string, object> json;

        // Leggi JSON esistente o crea nuovo
        if (!string.IsNullOrWhiteSpace(mapping.ParametriExtra))
        {
            try
            {
                json = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(mapping.ParametriExtra)
                    ?? new Dictionary<string, object>();
            }
            catch
            {
                json = new Dictionary<string, object>();
            }
        }
        else
        {
            json = new Dictionary<string, object>();
        }

        // Aggiorna/aggiungi cron
        json["cron"] = cronValue;

        // Serializza e salva
        mapping.ParametriExtra = System.Text.Json.JsonSerializer.Serialize(json);
    }

    /// <summary>
    /// Verifica se il cron è uno dei preset disponibili.
    /// </summary>
    private bool IsPresetCron(string cron)
    {
        var presets = new[] { "0 5 * * *", "0 2 * * *", "0 */4 * * *", "0 * * * *", "0 0 1 * *", "custom" };
        return presets.Contains(cron);
    }

    private async Task SalvaConfigurazioneAsync()
    {
        if (string.IsNullOrWhiteSpace(_config.TipoFonte) ||
            !_mappingFasi.Any())
        {
            Snackbar.Add("Compila i campi obbligatori e aggiungi almeno un mapping", Severity.Warning);
            return;
        }

        // Validazione: nessun task duplicato (stessa fase + stesso cron)
        var duplicati = _mappingFasi
            .GroupBy(m => new { m.IdFaseLavorazione, Cron = GetCronFromMapping(_mappingFasi.IndexOf(m)) })
            .Where(g => g.Count() > 1)
            .ToList();

        if (duplicati.Any())
        {
            Snackbar.Add("Non è possibile avere mapping con la stessa fase e lo stesso cron", Severity.Error);
            return;
        }

        // Validazione SQL obbligatoria prima del salvataggio
        if (_config.TipoFonte == "SQL" && !string.IsNullOrWhiteSpace(_config.TestoQuery))
        {
            var queryValidation = SqlValidator.ValidateQuery(_config.TestoQuery);
            if (!queryValidation.IsValid)
            {
                Snackbar.Add(queryValidation.Message, Severity.Error);
                _validationMessage = queryValidation.Message;
                _validationSeverity = Severity.Error;
                return; // Blocca salvataggio se SQL injection rilevato
            }

            // Mostra warning ma NON bloccare
            if (queryValidation.Severity == ValidationSeverity.Warning)
            {
                _validationMessage = queryValidation.Message;
                _validationSeverity = Severity.Warning;
            }
        }

        _saving = true;
        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();

            if (_isEdit)
            {
                _config.ModificatoIl = DateTime.Now;
                _config.ModificatoDa = ConfigUser?.Utente ?? string.Empty;
                
                context.ConfigurazioneFontiDatis.Update(_config);

                var oldMappings = await context.ConfigurazioneFaseCentros
                    .Where(fc => fc.IdConfigurazione == _config.IdConfigurazione)
                    .ToListAsync();
                context.ConfigurazioneFaseCentros.RemoveRange(oldMappings);
            }
            else
            {
                _config.CreatoIl = DateTime.Now;
                _config.CreatoDa = ConfigUser?.Utente ?? string.Empty;
                
                context.ConfigurazioneFontiDatis.Add(_config);
            }
            
            await context.SaveChangesAsync();
            
            foreach (var mapping in _mappingFasi)
            {
                mapping.IdConfigurazione = _config.IdConfigurazione;
                mapping.FlagAttiva = true;
                context.ConfigurazioneFaseCentros.Add(mapping);
            }
            
            await context.SaveChangesAsync();
            
            Snackbar.Add("Configurazione salvata!", Severity.Success);
            Navigation.NavigateTo("/admin/fonti-dati");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
    
    
    /// <summary>
    /// Testa connessione al database selezionato.
    /// </summary>
    private async Task TestConnectionAsync()
    {
        if (string.IsNullOrWhiteSpace(_config.ConnectionStringName))
        {
            Snackbar.Add("Seleziona prima una connection string", Severity.Warning);
            return;
        }

        _testingConnection = true;
        _validationMessage = null;
        
        try
        {
            var result = await SqlValidator.TestConnectionAsync(_config.ConnectionStringName);
            
            _validationMessage = result.Message;
            _validationSeverity = result.Severity switch
            {
                ValidationSeverity.Success => Severity.Success,
                ValidationSeverity.Warning => Severity.Warning,
                _ => Severity.Error
            };
            
            Snackbar.Add(result.Message, _validationSeverity);
        }
        finally
        {
            _testingConnection = false;
        }
    }

    /// <summary>
    /// Valida query SQL contro SQL injection e pattern pericolosi.
    /// </summary>
    private async Task ValidateQueryAsync()
    {
        if (string.IsNullOrWhiteSpace(_config.TestoQuery))
        {
            Snackbar.Add("Inserisci prima una query SQL", Severity.Warning);
            return;
        }

        _validatingQuery = true;
        _validationMessage = null;
        
        try
        {
            var result = SqlValidator.ValidateQuery(_config.TestoQuery);
            
            _validationMessage = result.Message;
            _validationSeverity = result.Severity switch
            {
                ValidationSeverity.Success => Severity.Success,
                ValidationSeverity.Warning => Severity.Warning,
                _ => Severity.Error
            };
            
            Snackbar.Add(result.Message, _validationSeverity);
        }
        finally
        {
            _validatingQuery = false;
        }
        
        await Task.CompletedTask; // Per evitare warning async
    }
}

