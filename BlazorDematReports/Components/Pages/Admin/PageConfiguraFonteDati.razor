@page "/admin/configura-fonte-dati"
@page "/admin/configura-fonte-dati/{IdConfigurazione:int}"
@inherits BaseComponentPage<PageConfiguraFonteDati>
@using Entities.Models.DbApplication
@using Microsoft.EntityFrameworkCore
@using LibraryLavorazioni.Shared.Discovery
@using BlazorDematReports.Services.Validation
@using BlazorDematReports.Services.DataService
@using BlazorDematReports.Components.Pages.Admin.Components
@inject IDbContextFactory<DematReportsContext> DbFactory
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject SqlValidationService SqlValidator
@inject ICronSchedulingService CronService
@inject IConfigurazioneDataReaderService DataReaderService
@attribute [Authorize(Roles = "ADMIN,SUPERVISOR")]

<PageTitle>Configurazione Fonte Dati</PageTitle>


<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
        Configurazione Fonte Dati
    </MudText>

    <MudPaper Class="pa-4">
        <MudGrid>
            <MudItem xs="12"><MudDivider /></MudItem>

            @* Tipo Fonte *@
            <TipoFonteSelector TipoFonte="@_config.TipoFonte" 
                              TipoFonteChanged="@OnTipoFonteChangedAsync" />

            <MudItem xs="12"><MudDivider /></MudItem>

            @* Procedura Selector *@
            <ProceduraSelector SelectedLavorazione="@_selectedLavorazione"
                               SelectedLavorazioneChanged="@OnValueChangedLavorazioneAsync"
                               CodiceConfigurazione="@_config.CodiceConfigurazione"
                               SearchFunc="@((string arg) => SearchFromSelect(base.SelectLavorazione, arg))" />

            @* Avviso: Nessuna fase disponibile *@
            @if (_selectedIdProcedura > 0 && !_fasiPerProcedura.Any())
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                        <MudText><strong>Nessuna fase disponibile per questa procedura.</strong></MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">
                            Per configurare una fonte dati, è necessario aggiungere almeno una fase di lavorazione.
                        </MudText>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   Class="mt-2"
                                   OnClick='@(() => Navigation.NavigateTo($"/procedure-lavorazioni/edit/{_selectedIdProcedura}"))'>
                            Vai a Modifica Procedura Lavorazione
                        </MudButton>
                    </MudAlert>
                </MudItem>
            }

            <MudItem xs="12"><MudDivider /></MudItem>

            @* Configurazione Specifica *@
            <ConfigurazioneSpecifica TipoFonte="@_config.TipoFonte"
                                    ConnectionStringName="@_config.ConnectionStringName"
                                    ConnectionStringNameChanged="@((string? v) => { _config.ConnectionStringName = v; InvokeAsync(StateHasChanged); })"
                                    TestoQuery="@_config.TestoQuery"
                                    TestoQueryChanged="@((string? v) => { _config.TestoQuery = v; InvokeAsync(StateHasChanged); })"
                                    MailServiceCode="@_config.MailServiceCode"
                                    MailServiceCodeChanged="@((string? v) => { _config.MailServiceCode = v; InvokeAsync(StateHasChanged); })"
                                    HandlerClassName="@_config.HandlerClassName"
                                    HandlerClassNameChanged="@((string? v) => { _config.HandlerClassName = v; InvokeAsync(StateHasChanged); })"
                                    ConnectionStrings="@_connectionStrings"
                                    MailServices="@_mailServices"
                                    AvailableHandlers="@_availableHandlers"
                                    TestingConnection="@_testingConnection"
                                    ValidatingQuery="@_validatingQuery"
                                    ValidationMessage="@_validationMessage"
                                    ValidationSeverity="@_validationSeverity"
                                    OnTestConnection="@(async () => await TestConnectionAsync())"
                                    OnValidateQuery="@(async () => await ValidateQueryAsync())" />

            <MudItem xs="12"><MudDivider /></MudItem>



            @* Mapping Configurazione *@
            <MappingConfigurazione Mappings="@_mappingFasi"
                                  Fasi="@_fasiPerProcedura"
                                  PresetCrons="@_presetCrons"
                                  DescrizioneConfigurazione="@_config.DescrizioneConfigurazione"
                                  DescrizioneConfigurazioneChanged="@((string? v) => { _config.DescrizioneConfigurazione = v; InvokeAsync(StateHasChanged); })"
                                  DisabledState='@((_config.TipoFonte == "SQL" && (!_queryValidated || !_connectionTestPassed)) || !_fasiPerProcedura.Any())'
                                  CanAddMapping='@(_selectedIdProcedura > 0 && _selectedCentroId > 0 && _fasiPerProcedura.Any() && !(_config.TipoFonte == "SQL" && (!_queryValidated || !_connectionTestPassed)))'
                                  OnAggiungiMapping="@AggiungiMappingAsync"
                                  OnRimuoviMapping="@RimuoviMappingAsync"
                                  GetCronValue="@GetCronFromMapping"
                                  OnCronChanged="@OnCronChangedAsync"  
                                  GiorniPrecedenti="@(_config.GiorniPrecedenti ?? 1)"
                                  GiorniPrecedentiChanged="@(v => { _config.GiorniPrecedenti = v; InvokeAsync(StateHasChanged); })" />

            <MudItem xs="12"><MudDivider Class="my-4" /></MudItem>

            @* AZIONI *@
            <MudItem xs="12">
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               OnClick="HandleValidSubmitAsync"
                               Disabled='@(_saving || (_config.TipoFonte == "SQL" && (!_queryValidated || !_connectionTestPassed)) || !_fasiPerProcedura.Any())'>
                        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                        Salva Configurazione
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               OnClick='@(() => Navigation.NavigateTo("/admin/fonti-dati"))'>
                        Annulla
                    </MudButton>
                </div>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public int? IdConfigurazione { get; set; }
    [SupplyParameterFromQuery(Name = "idProcedura")]
    public int? IdProceduraPrecompilata { get; set; }

    // State
    private string? _selectedLavorazione;
    private int _selectedIdProcedura = 0;
    private int _selectedCentroId = 0;
    private bool _initializing = true;
    private bool _isEdit => IdConfigurazione.HasValue;
    private bool _saving = false;
    private bool _testingConnection = false;
    private bool _validatingQuery = false;
    private string? _validationMessage;
    private bool _queryValidated = false;
    private bool _connectionTestPassed = false;

    // Config
    private ConfigurazioneFontiDati _config = new() { FlagAttiva = true, TipoFonte = "SQL" };

    // Lists
    private List<ConfigurazioneFaseCentro> _mappingFasi = new();
    private List<string> _connectionStrings = new();
    private List<string> _mailServices = new() { "HERA16", "ADER4" };
    private IReadOnlyList<HandlerInfo> _availableHandlers = new List<HandlerInfo>();
    private List<FasiLavorazione> _fasiPerProcedura = new();
    private List<(string Value, string Label)> _presetCrons = new();

    // UI
    private Severity _validationSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _initializing = true;
            UiState?.ShowOverlay("Caricamento lavorazioni...");

            // Inizializza ConfigUser prima di usarlo
            await ConfigUser!.InitializeAsync();

            // Carica liste per autocomplete
            ListProcedureLavorazioni = await ServiceWrapper!.ServiceProcedureLavorazioni.GetTableProcedureLavorazioniByUserAsync();
            SetSelectLavorazione();

            // Carica connection strings
            var conStrings = DataReaderService.GetConnectionStrings(Configuration);
            _connectionStrings.AddRange(conStrings);

            // Carica handler disponibili
            _availableHandlers = HandlerDiscoveryService.AvailableHandlers;

            // Carica preset CRON
            _presetCrons = CronService.GetPresetCrons();

            // Usa i service wrapper
            var fasi = await ServiceWrapper!.ServiceFasiLavorazioni.GetFasiLavorazioneAsync();
            var centri = await ServiceWrapper!.ServiceCentri.GetCentriByUserAsync();

            // Carica edit data se necessario
            if (_isEdit)
            {
                var config = await DataReaderService.GetConfigurazioneFontiDatiAsync(IdConfigurazione.Value);
                if (config != null)
                {
                    _config = config;
                    _mappingFasi = config.ConfigurazioneFaseCentros.Where(fc => fc.FlagAttiva).ToList();
                }
            }
            else if (IdProceduraPrecompilata.HasValue)
            {
                _mappingFasi.Add(new ConfigurazioneFaseCentro
                {
                    IdProceduraLavorazione = IdProceduraPrecompilata.Value,
                    FlagAttiva = true
                });
                Snackbar.Add("Mapping pre-compilato per la procedura selezionata", Severity.Info);
            }

            // Imposta lavorazione selezionata per edit
            if (_isEdit && _mappingFasi.Any())
            {
                var idProc = _mappingFasi.First().IdProceduraLavorazione;
                var proc = ListProcedureLavorazioni?.FirstOrDefault(p => p.IdproceduraLavorazione == idProc);
                if (proc != null)
                {
                    _selectedLavorazione = proc.NomeProcedura;
                    _selectedIdProcedura = proc.IdproceduraLavorazione;
                    _selectedCentroId = proc.Idcentro;
                    _fasiPerProcedura = await DataReaderService.GetFasiByProceduraAsync(proc.IdproceduraLavorazione);
                }
            }

            // Aggiorna il UI
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error initializing PageConfiguraFonteDati");
            UiState?.ShowSnackbar($"Errore durante l'inizializzazione: {ex.Message}", Severity.Error);
        }
        finally
        {
            _initializing = false;
            UiState?.HideOverlay();
        }
    }

    private async Task OnValueChangedLavorazioneAsync(string? lavorazione)
    {
        _selectedLavorazione = lavorazione;

        if (string.IsNullOrEmpty(lavorazione))
        {
            ClearCurrentConfig();
            return;
        }

        try
        {
            UiState?.ShowOverlay("Caricamento lavorazione...");

            var procedura = ListProcedureLavorazioni?.FirstOrDefault(x => x.NomeProcedura == lavorazione);

            if (procedura?.IdproceduraLavorazione != null && procedura.IdproceduraLavorazione > 0)
            {
                _selectedIdProcedura = procedura.IdproceduraLavorazione;
                _selectedCentroId = procedura.Idcentro;

                _config.CodiceConfigurazione = $"Config{_selectedIdProcedura:D4}";
                _config.DescrizioneConfigurazione = $"Config_{lavorazione}";

                // Carica fasi
                _fasiPerProcedura = await DataReaderService.GetFasiByProceduraAsync(procedura.IdproceduraLavorazione);

                await InvokeAsync(StateHasChanged);
            }
            else
            {
                ClearCurrentConfig();
                UiState?.ShowSnackbar("Lavorazione non trovata", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error loading procedure: {ProcedureName}", lavorazione);
            UiState?.ShowSnackbar($"Errore nel caricamento: {ex.Message}", Severity.Error);
            ClearCurrentConfig();
        }
        finally
        {
            UiState?.HideOverlay();
        }
    }

    private void ClearCurrentConfig()
    {
        _config = new ConfigurazioneFontiDati { FlagAttiva = true, TipoFonte = "SQL" };
        _selectedLavorazione = null;
        _selectedIdProcedura = 0;
        _fasiPerProcedura.Clear();
        _selectedCentroId = 0;
        _mappingFasi.Clear();
        _config.DescrizioneConfigurazione = null;

        _config.ConnectionStringName = null;
        _config.TestoQuery = null;
        _config.MailServiceCode = null;
        _config.HandlerClassName = null;

        _validationMessage = null;
        _validationSeverity = Severity.Info;
        _connectionTestPassed = false;
        _queryValidated = false;
    }

    private async Task OnTipoFonteChangedAsync(string newTipoFonte)
    {
        ClearCurrentConfig();
        _config.TipoFonte = newTipoFonte;
        await InvokeAsync(StateHasChanged);
    }

    private async Task AggiungiMappingAsync()
    {
        if (_selectedIdProcedura == 0 || _selectedCentroId == 0)
        {
            Snackbar.Add("Seleziona prima una lavorazione", Severity.Warning);
            return;
        }

        if (!_fasiPerProcedura.Any())
        {
            Snackbar.Add("Nessuna fase disponibile per questa procedura", Severity.Warning);
            return;
        }

        var newMapping = new ConfigurazioneFaseCentro
        {
            IdProceduraLavorazione = _selectedIdProcedura,
            IdCentro = _selectedCentroId,
            IdFaseLavorazione = _fasiPerProcedura.First().IdFaseLavorazione,
            FlagAttiva = true
        };

        _mappingFasi.Add(newMapping);

        // Imposta cron di default (primo della lista o default "0 5 * * *")
        var defaultCron = _presetCrons.Any() ? _presetCrons.First().Value : "0 5 * * *";
        var newIndex = _mappingFasi.Count - 1;
        SetCronForMapping(newIndex, defaultCron);

        await InvokeAsync(StateHasChanged);
    }

    private async Task RimuoviMappingAsync(int index)
    {
        if (index >= 0 && index < _mappingFasi.Count)
        {
            _mappingFasi.RemoveAt(index);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RimuoviMapping(ConfigurazioneFaseCentro mapping)
    {
        var idx = _mappingFasi.IndexOf(mapping);
        if (idx >= 0)
        {
            _mappingFasi.RemoveAt(idx);
        }
    }

    private string GetCronFromMapping(int index)
    {
        if (index >= _mappingFasi.Count) return "0 5 * * *";
        return CronService.GetCronFromMapping(_mappingFasi[index]);
    }

    private void SetCronForMapping(int index, string? cronValue)
    {
        if (index >= _mappingFasi.Count || string.IsNullOrWhiteSpace(cronValue)) return;
        CronService.SetCronForMapping(_mappingFasi[index], cronValue);
    }

    private async Task OnCronChangedAsync((int Index, string CronValue) param)
    {
        SetCronForMapping(param.Index, param.CronValue);
        await InvokeAsync(StateHasChanged);
    }

    private async Task TestConnectionAsync()
    {
        if (string.IsNullOrWhiteSpace(_config.ConnectionStringName))
        {
            Snackbar.Add("Seleziona prima una connection string", Severity.Warning);
            return;
        }

        _testingConnection = true;
        _validationMessage = null;
        _connectionTestPassed = false;

        try
        {
            var result = await SqlValidator.TestConnectionAsync(_config.ConnectionStringName);

            _validationMessage = result.Message;
            _validationSeverity = result.Severity switch
            {
                ValidationSeverity.Success => Severity.Success,
                ValidationSeverity.Warning => Severity.Warning,
                _ => Severity.Error
            };

            // Imposta flag solo se test è riuscito
            _connectionTestPassed = result.IsValid;

            if (!_connectionTestPassed)
            {
                Snackbar.Add("Test connessione fallito. Correggi la configurazione prima di procedere.", Severity.Error);
            }
            else
            {
                Snackbar.Add(result.Message, _validationSeverity);
            }
            
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _testingConnection = false;
        }
    }

    private async Task ValidateQueryAsync()
    {
        if (string.IsNullOrWhiteSpace(_config.TestoQuery))
        {
            Snackbar.Add("Inserisci prima una query SQL", Severity.Warning);
            return;
        }

        _validatingQuery = true;
        _validationMessage = null;

        try
        {
            var result = SqlValidator.ValidateQuery(_config.TestoQuery);
            _validationMessage = result.Message;
            _validationSeverity = result.Severity switch
            {
                ValidationSeverity.Success => Severity.Success,
                ValidationSeverity.Warning => Severity.Warning,
                _ => Severity.Error
            };
            _queryValidated = result.IsValid;
            Snackbar.Add(result.Message, _validationSeverity);
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _validatingQuery = false;
        }
    }

    protected async Task HandleValidSubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_config.TipoFonte) || !_mappingFasi.Any())
        {
            Snackbar.Add("Compila i campi obbligatori e aggiungi almeno un mapping", Severity.Warning);
            return;
        }

        if (!_fasiPerProcedura.Any())
        {
            Snackbar.Add("Nessuna fase disponibile. Aggiungi fasi alla procedura tramite Edit Procedura Lavorazione.", Severity.Error);
            return;
        }

        if (_config.TipoFonte == "SQL")
        {
            if (string.IsNullOrWhiteSpace(_config.TestoQuery))
            {
                Snackbar.Add("Inserisci la query SQL", Severity.Warning);
                return;
            }

            if (!_queryValidated)
            {
                Snackbar.Add("Valida la query SQL prima di salvare.", Severity.Error);
                return;
            }

            if (!_connectionTestPassed)
            {
                Snackbar.Add("Esegui e supera il test di connessione prima di salvare.", Severity.Error);
                return;
            }
        }

        if (_config.TipoFonte == "EmailCSV" && string.IsNullOrWhiteSpace(_config.MailServiceCode))
        {
            Snackbar.Add("Seleziona un Mail Service", Severity.Warning);
            return;
        }

        if (_config.TipoFonte == "HandlerIntegrato" && string.IsNullOrWhiteSpace(_config.HandlerClassName))
        {
            Snackbar.Add("Seleziona un Handler C#", Severity.Warning);
            return;
        }

        var duplicati = _mappingFasi
            .GroupBy(m => new { m.IdFaseLavorazione, Cron = GetCronFromMapping(_mappingFasi.IndexOf(m)) })
            .Where(g => g.Count() > 1)
            .ToList();

        if (duplicati.Any())
        {
            Snackbar.Add("Non è possibile avere mapping con la stessa fase e lo stesso cron", Severity.Error);
            return;
        }

        _saving = true;

        try
        {
            UiState?.SetMenuDisabled(true);
            UiState?.ShowOverlay("Inserimento in corso...");

            if (_isEdit)
            {
                _config.ModificatoIl = DateTime.Now;
                _config.ModificatoDa = ConfigUser?.Utente ?? string.Empty;
                await ServiceWrapper!.ServiceConfigurazioneFontiDati.UpdateConfigurazioneFontiDatiAsync(_config, _mappingFasi, ConfigUser!.Utente);
            }
            else
            {
                await ServiceWrapper!.ServiceConfigurazioneFontiDati.AddConfigurazioneFontiDatiAsync(_config, _mappingFasi, ConfigUser!.Utente);
            }

            UiState?.SetMenuDisabled(false);
            UiState?.HideOverlay();
            UiState?.ShowSnackbar("Configurazione salvata!", Severity.Success);
            Navigation.NavigateTo("/admin/fonti-dati");
        }
        catch (Exception ex)
        {
            await HandleExceptionFormAsync(ex);
        }
        finally
        {
            _saving = false;
        }
    }
}

