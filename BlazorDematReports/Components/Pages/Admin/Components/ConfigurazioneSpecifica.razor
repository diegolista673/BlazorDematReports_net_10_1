@using Entities.Models.DbApplication
@using MudBlazor
@using LibraryLavorazioni.Shared.Discovery

<MudItem xs="12">
    <MudText Typo="Typo.h6" Class="mb-3">3. Configurazione Specifica</MudText>
</MudItem>

@if (TipoFonte == "SQL")
{
    <MudItem xs="12" md="6">
        <MudSelect T="string" 
                   Value="@ConnectionStringName"
                   ValueChanged="OnConnectionStringNameChanged"
                   Label="Connection String"
                   Variant="Variant.Outlined"
                   Required="true">
            @foreach (var cs in ConnectionStrings)
            {
                <MudSelectItem Value="@cs">@cs</MudSelectItem>
            }
        </MudSelect>
    </MudItem>


    <MudItem xs="12" Class="d-flex gap-2 mt-1">
        <MudButton Variant="Variant.Outlined" 
                   Color="Color.Info"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Cable"
                   OnClick="OnTestConnection"
                   Disabled='@(TestingConnection || string.IsNullOrWhiteSpace(ConnectionStringName))'>
            @if (TestingConnection) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
            Test Connessione
        </MudButton>
    </MudItem>

    @if (!string.IsNullOrWhiteSpace(ValidationMessage))
    {
        <MudItem xs="12">
            <MudAlert Severity="@ValidationSeverity" Dense Elevation="1" Class="mb-2">
                @ValidationMessage
            </MudAlert>
        </MudItem>
    }
}
else if (TipoFonte == "EmailCSV")
{
    <MudItem xs="12" md="6">
        <MudSelect T="string" 
                   @bind-Value="MailServiceCode"
                   Label="Mail Service"
                   Variant="Variant.Outlined"
                   Required="true">
            @foreach (var ms in MailServices)
            {
                <MudSelectItem Value="@ms">@ms</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
}
else if (TipoFonte == "HandlerIntegrato")
{
    <MudItem xs="12" md="6">
        <MudSelect T="string" 
                   @bind-Value="HandlerClassName"
                   Label="Handler C#"
                   Variant="Variant.Outlined"
                   Required="true">
            @foreach (var handler in AvailableHandlers)
            {
                <MudSelectItem Value="@handler.ClassName">@handler.ClassName</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
}
else if (TipoFonte == "Pipeline")
{
    <MudItem xs="12" md="6">
        <MudSelect T="string" 
                   @bind-Value="ConnectionStringName"
                   Label="Connection String Base"
                   Variant="Variant.Outlined">
            @foreach (var cs in ConnectionStrings)
            {
                <MudSelectItem Value="@cs">@cs</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12">
        <MudAlert Severity="Severity.Info">Pipeline multi-step in sviluppo.</MudAlert>
    </MudItem>
}



@code {
    [Parameter]
    public string? TipoFonte { get; set; }

    [Parameter]
    public string? ConnectionStringName { get; set; }

    [Parameter]
    public EventCallback<string?> ConnectionStringNameChanged { get; set; }

    [Parameter]
    public string? MailServiceCode { get; set; }

    [Parameter]
    public EventCallback<string?> MailServiceCodeChanged { get; set; }

    [Parameter]
    public string? HandlerClassName { get; set; }

    [Parameter]
    public EventCallback<string?> HandlerClassNameChanged { get; set; }

    [Parameter]
    public List<string> ConnectionStrings { get; set; } = new();

    [Parameter]
    public List<string> MailServices { get; set; } = new();

    [Parameter]
    public IReadOnlyList<HandlerInfo> AvailableHandlers { get; set; } = new List<HandlerInfo>();

    [Parameter]
    public bool TestingConnection { get; set; }

    [Parameter]
    public string? ValidationMessage { get; set; }

    [Parameter]
    public Severity ValidationSeverity { get; set; } = Severity.Info;

    [Parameter]
    public EventCallback OnTestConnection { get; set; }

    private async Task OnConnectionStringNameChanged(string? value)
    {
        await ConnectionStringNameChanged.InvokeAsync(value);
    }
}


