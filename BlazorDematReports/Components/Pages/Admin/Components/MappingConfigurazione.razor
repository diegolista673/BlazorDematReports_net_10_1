@using Entities.Models.DbApplication
@using MudBlazor
@using BlazorDematReports.Services.Validation
@using ValidationResult = BlazorDematReports.Services.Validation.ValidationResult

<MudItem xs="12">
    <MudText Typo="Typo.h6" Class="mb-3">4. Configurazione Mapping</MudText>
</MudItem>

<MudItem xs="12">
    <MudTextField @bind-value="DescrizioneConfigurazione"
                  Label="Descrizione Configurazione"
                  Variant="Variant.Outlined"
                  Lines="2"
                  HelperText="Descrizione globale per questa configurazione"
                  Disabled="@DisabledState" />
</MudItem>

<MudItem xs="12"><MudDivider /></MudItem>



<MudItem xs="12">
    <MudPaper Elevation="3" Class="pa-4 mb-3">
        <MudText Typo="Typo.body2" Class="mb-2"><b>Linee guida per le query SQL:</b></MudText>

        <MudText Typo="Typo.body2" Class="mb-1">1. <b>Formato dei risultati:</b></MudText>
        <ul style="margin-left: 20px;">
            <li><MudText Typo="Typo.body2">Il risultato deve indicare il numero di documenti, fogli, pagine raggruppati per data di lavorazione e operatore.</MudText></li>
            <li><MudText Typo="Typo.body2">L'intestazione deve corrispondere esattamente a: <b>Operatore, DataLavorazione, Documenti, Fogli, Pagine</b></MudText></li>
        </ul>

        <MudText Typo="Typo.body2" Class="mb-1 mt-2">2. <b>Identificazione univoca degli operatori:</b></MudText>
        <ul style="margin-left: 20px;">
            <li><MudText Typo="Typo.body2">Utilizzare una clausola WHERE con criteri specifici (es: department = 'genova')</MudText></li>
            <li><MudText Typo="Typo.body2"><b>Attenzione:</b> Se non č possibile identificare operatori e centro, il sistema proverŕ a riconoscerli automaticamente. Se non riconosciuti verranno eliminati.</MudText></li>
        </ul>

        <MudText Typo="Typo.body2" Class="mb-1 mt-2">3. <b>Parametrizzazione delle date:</b></MudText>
        <ul style="margin-left: 20px;">
            <li><MudText Typo="Typo.body2">Sostituire le date con i parametri <code>@@StartDate</code> e <code>@@EndDate</code></MudText></li>
        </ul>

        <MudDivider Class="my-2" />
        <MudText Typo="Typo.caption"><b>Esempio:</b></MudText>
        <MudText Typo="Typo.caption" Style="font-family: monospace; white-space: pre-wrap;" Class="mt-1">
            SELECT op_scan AS <b>Operatore</b>,
            CONVERT(DATE, data_scan) AS <b>DataLavorazione</b>,
            COUNT(*) AS <b>Documenti</b>,
            SUM(CONVERT(INT, num_pag))/2 AS <b>Fogli</b>,
            SUM(CONVERT(INT, num_pag)) AS <b>Pagine</b>
            FROM z0072370_rdmkt_28aut_ge_uda_dettaglio
            WHERE <b>department = 'genova'</b>
            AND data_scan >= <b>@@StartDate</b>
            AND data_scan &lt;= <b>@@EndDate</b>
            GROUP BY op_scan, CONVERT(DATE, data_scan)
        </MudText>
    </MudPaper>
</MudItem>

<MudItem xs="12">
    <div class="d-flex justify-end mb-3">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   OnClick="OnAggiungiMapping"
                   Disabled="@(CanAddMapping == false)">
            + Aggiungi Mapping
        </MudButton>
    </div>
</MudItem>

@if (Mappings != null && Mappings.Count > 0)
{
    @for (var index = 0; index < Mappings.Count; index++)
    {
        var mapping = Mappings[index];
        var currentIndex = index;

        <MudItem xs="12">
            <MudPaper Class="pa-3" Elevation="2">
                <MudGrid>
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Task" Size="Size.Small" Class="mr-1" />
                            Task #@(index + 1)
                        </MudText>
                    </MudItem>
                    
                    <MudItem xs="12" md="3">
                        <MudSelect T="int"
                                   @bind-value="mapping.IdFaseLavorazione"
                                   Label="Fase"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Disabled="@DisabledState"
                                   Required="true">
                                @foreach (var f in Fasi)
                                {
                                    <MudSelectItem Value="@f.IdFaseLavorazione">@f.FaseLavorazione</MudSelectItem>
                                }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="string"
                                   Value="@GetCronValue(currentIndex)"
                                   ValueChanged="@(async (string v) => await OnCronChanged.InvokeAsync((currentIndex, v)))"
                                   Label="Schedulazione"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Disabled="@DisabledState">
                            @foreach (var (cronValue, cronLabel) in PresetCrons)
                            {
                                <MudSelectItem Value="@cronValue">@cronLabel</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int?"
                                         Label="Giorni Precedenti"
                                         Min="1"
                                         Max="365"
                                         @bind-value="mapping.GiorniPrecedenti"
                                         Variant="Variant.Outlined"
                                         Dense="true"
                                         Required="true"
                                         Disabled="@DisabledState"accesskey="" />
                    </MudItem>
                    <MudItem xs="12" md="3" Class="d-flex align-center justify-end">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Large"
                                       Color="Color.Error"
                                       OnClick="@(async () => await OnRimuoviMapping.InvokeAsync(currentIndex))"
                                       title="Rimuovi mapping" />
                    </MudItem>
                </MudGrid>
                
                @* Query SQL per task SQL *@
                @if (mapping.TipoTask == "SQL")
                {
                    <MudGrid Class="mt-1">
                        
                        <MudItem xs="12">
                            <MudTextField @bind-value="mapping.TestoQueryTask"
                                          Label="Query SQL"
                                          Variant="Variant.Outlined"
                                          Lines="12"
                                          Required="true"
                                          Style="font-family: 'Courier New', monospace; font-size: 0.9em;"
                                          spellcheck="false"
                                          Disabled="@DisabledState" />
                            <MudText Typo="Typo.caption" Class="mt-1">
                                Parametri: <code>@@StartDate</code>, <code>@@EndDate</code> | 
                                Colonne: <code>Operatore, DataLavorazione, Documenti, Fogli, Pagine</code>
                            </MudText>
                        </MudItem>
                        
                        <MudItem xs="12" Class="d-flex gap-2">
                            <MudButton Variant="Variant.Outlined" 
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.VerifiedUser"
                                       OnClick="@(async () => await ValidateQueryAsync(mapping, currentIndex))"
                                       Disabled='@(DisabledState || string.IsNullOrWhiteSpace(mapping.TestoQueryTask) || _validatingQueries.Contains(currentIndex))'>
                                @if (_validatingQueries.Contains(currentIndex)) 
                                { 
                                    <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> 
                                }
                                Valida Query
                            </MudButton>
                            
                            @if (_validationResults.ContainsKey(currentIndex))
                            {
                                var result = _validationResults[currentIndex];
                                <MudChip T="string" 
                                         Size="Size.Small" 
                                         Color="@(result.IsValid ? Color.Success : Color.Error)"
                                         Icon="@(result.IsValid ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Error)">
                                    @result.Message
                                </MudChip>
                            }
                        </MudItem>
                    </MudGrid>
                }
                
                @* Info Read-Only per altri tipi *@
                <MudGrid Class="mt-2">
                    <MudItem xs="12" md="6">
                        <MudTextField Value="@mapping.CronExpression"
                                      Label="CRON Expression"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      ReadOnly="true"
                                      Disabled="@DisabledState" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField Value="@mapping.TipoTask"
                                      Label="Tipo Task"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      ReadOnly="true"
                                      Disabled="@DisabledState" />
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    }
}
else
{
    <MudItem xs="12">
        <MudAlert Severity="Severity.Info">Nessun mapping aggiunto. Clicca il pulsante per aggiungere un mapping.</MudAlert>
    </MudItem>
}

@code {
    [Parameter]
    public List<ConfigurazioneFaseCentro> Mappings { get; set; } = new();

    [Parameter]
    public List<FasiLavorazione> Fasi { get; set; } = new();

    [Parameter]
    public List<(string Value, string Label)> PresetCrons { get; set; } = new();

    [Parameter]
    public string? DescrizioneConfigurazione { get; set; }

    [Parameter]
    public EventCallback<string?> DescrizioneConfigurazioneChanged { get; set; }

    [Parameter]
    public bool DisabledState { get; set; }

    [Parameter]
    public bool? CanAddMapping { get; set; }

    [Parameter]
    public EventCallback OnAggiungiMapping { get; set; }

    [Parameter]
    public EventCallback<int> OnRimuoviMapping { get; set; }

    [Parameter]
    public Func<int, string> GetCronValue { get; set; } = default!;

    [Parameter]
    public EventCallback<(int Index, string CronValue)> OnCronChanged { get; set; }

    [Parameter]
    public int GiorniPrecedenti { get; set; } = 1;

    [Parameter]
    public EventCallback<int> GiorniPrecedentiChanged { get; set; }
    
    [Parameter]
    public SqlValidationService? SqlValidator { get; set; }

    // State per validazione query
    private HashSet<int> _validatingQueries = new();
    private Dictionary<int, ValidationResult> _validationResults = new();

    private async Task ValidateQueryAsync(ConfigurazioneFaseCentro mapping, int index)
    {
        if (SqlValidator == null || string.IsNullOrWhiteSpace(mapping.TestoQueryTask))
            return;

        _validatingQueries.Add(index);
        await InvokeAsync(StateHasChanged);

        try
        {
            // 1. Validazione sicurezza (SQL injection, parametri, keyword vietate)
            var securityResult = SqlValidator.ValidateQuery(mapping.TestoQueryTask);
            
            if (!securityResult.IsValid)
            {
                // Se fallisce la validazione di sicurezza, fermiamoci qui
                _validationResults[index] = securityResult;
                await InvokeAsync(StateHasChanged);
                return;
            }
            
            // 2. Validazione sintassi T-SQL (parser Microsoft + controllo FROM)
            var syntaxResult = SqlValidator.ValidateSqlSyntax(mapping.TestoQueryTask);
            
            if (!syntaxResult.IsValid)
            {
                // Se la sintassi č errata, mostra l'errore di sintassi
                _validationResults[index] = syntaxResult;
                await InvokeAsync(StateHasChanged);
                return;
            }
            
            // 3. Validazione colonne obbligatorie (Operatore, DataLavorazione, Documenti, Fogli, Pagine)
            var columnsResult = SqlValidator.ValidateColumnNames(mapping.TestoQueryTask);
            
            if (!columnsResult.IsValid)
            {
                // Colonne obbligatorie mancanti
                _validationResults[index] = columnsResult;
                await InvokeAsync(StateHasChanged);
                return;
            }
            
            // 4. Tutte le validazioni sono passate
            _validationResults[index] = ValidationResult.Success(
                "? Query valida: sicurezza, sintassi e colonne verificate");
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _validatingQueries.Remove(index);
            await InvokeAsync(StateHasChanged);
        }
    }

    public bool AreAllQueriesValid()
    {
        // Controlla che tutte le query SQL siano validate
        for (int i = 0; i < Mappings.Count; i++)
        {
            var mapping = Mappings[i];
            if (mapping.TipoTask == "SQL")
            {
                // Se č SQL e non č stata validata o la validazione č fallita
                if (!_validationResults.ContainsKey(i) || !_validationResults[i].IsValid)
                {
                    return false;
                }
            }
        }
        return true;
    }
    
    public void ClearValidations()
    {
        _validationResults.Clear();
    }
}

