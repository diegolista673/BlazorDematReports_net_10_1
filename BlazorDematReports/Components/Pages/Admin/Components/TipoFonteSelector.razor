@using Entities.Models.DbApplication
@using MudBlazor

<MudItem xs="12">
    <MudText Typo="Typo.h6" Class="mb-3">1. Seleziona Tipo Fonte</MudText>
    <MudRadioGroup Value="@TipoFonte" 
                   ValueChanged="@((string v) => TipoFonteChanged.InvokeAsync(v))">
        <MudRadio Value="@("SQL")" Color="Color.Primary">Query SQL - Query diretta a database</MudRadio>
        <MudRadio Value="@("EmailCSV")" Color="Color.Secondary">Email CSV - Allegati da servizi email</MudRadio>
        <MudRadio Value="@("HandlerIntegrato")" Color="Color.Tertiary">Handler C# - Logica complessa</MudRadio>
        <MudRadio Value="@("Pipeline")" Color="Color.Info">Pipeline - Elaborazione multi-step</MudRadio>
    </MudRadioGroup>
</MudItem>

@code {
    [Parameter]
    public string? TipoFonte { get; set; }

    [Parameter]
    public EventCallback<string> TipoFonteChanged { get; set; }
}
