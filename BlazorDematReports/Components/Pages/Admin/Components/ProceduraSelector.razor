@using Entities.Models.DbApplication
@using MudBlazor
@using BlazorDematReports.Services.DataService

<MudItem xs="12">
    <MudText Typo="Typo.h6" Class="mb-3">2. Seleziona Procedura di lavorazione</MudText>
</MudItem>

<MudItem xs="12">
    <MudAutocomplete T="string"
                     Label="Lavorazione"
                     SearchFunc="@((string arg, CancellationToken ct) => SearchFunc.Invoke(arg))"
                     MaxItems="null"
                     Clearable="true"
                     ResetValueOnEmptyText="true"
                     SelectOnActivation="true"
                     Required="true"
                     Value="@SelectedLavorazione"
                     ValueChanged="@OnLavorazioneChanged"
                     Variant="Variant.Outlined"
                     Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.Assignment" />

    <MudItem xs="12">
        <MudTextField @bind-Value="CodiceConfigurazione"
                      Label="Codice Univoco"
                      Variant="Variant.Outlined"
                      ReadOnly="true"
                      Dense="true" />
    </MudItem>
</MudItem>

@code {
    [Parameter]
    public string? SelectedLavorazione { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedLavorazioneChanged { get; set; }

    [Parameter]
    public string? CodiceConfigurazione { get; set; }

    [Parameter]
    public EventCallback<string?> CodiceConfigurazioneŁChanged { get; set; }

    [Parameter]
    public Func<string, Task<IEnumerable<string>>> SearchFunc { get; set; } = default!;

    private async Task OnLavorazioneChanged(string? lavorazione)
    {
        SelectedLavorazione = lavorazione;
        await SelectedLavorazioneChanged.InvokeAsync(lavorazione);
    }
}
