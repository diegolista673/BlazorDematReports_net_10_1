    /// <summary>
    /// Eliminazione a cascata settata nel DB all'interno della proprietà FK_TipologieTotaliProduzione_ProduzioneOperatori
    /// della relazione di chiave esterna (specifica Insert/Update -> regola di eliminazione -> sovrapponi)
    /// </summary>
    /// <param name="idProduzione">ID del record di produzione da eliminare.</param>
    /// <param name="lavorazione">Nome della lavorazione (usato nel messaggio di conferma).</param>
    /// <param name="IdOperatore">ID operatore associato al record.</param>
    /// <param name="dataLavorazione">Data lavorazione associata al record.</param>
    /// <returns></returns>
    protected async Task DeleteRecordAsync(int idProduzione, string lavorazione, int IdOperatore, DateTime dataLavorazione)
    {
        await RunWithOverlay(async () =>
        {
            var parameters = new DialogParameters();
            parameters.Add("ContentText", "Eliminare : " + lavorazione + " ?");
            parameters.Add("ButtonText", "Delete");
            parameters.Add("Color", Color.Error);

            var options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Medium };
            var dialog = await DialogService!.ShowAsync<Dialog>("Elimina Record", parameters, options);
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                Model!.IdOperatore = IdOperatore;

                await serviceProduzioneOperatori.DeleteProduzioneOperatoriAsync(idProduzione);
                await GetListProduzioneOperatoriAsync();

                Model!.IdOperatore = null;

                base.ErrorMessage = "";

                UiState?.ShowSnackbar("Lavorazione eliminata", Severity.Success);
            }
        }, "Eliminazione in corso...");
    }


    protected async Task OnUpdateRow(ProduzioneOperatoriDto produzioneOperatoriDto)
    {
        try
        {
            if (produzioneOperatoriDto.TempoLavOreCent >= 0)
            {
                await serviceProduzioneOperatori.UpdateProduzioneOperatoriAsync(produzioneOperatoriDto);
                UiState?.ShowSnackbar("Update eseguito", Severity.Success);
            }
            else
            {
                produzioneOperatoriDto.TempoLavOreCent = ValueBeforeEdit!.TempoLavOreCent;
                await NotificationDialog!.ShowNotification("Il campo Ore non può essere a 0", "OK", Color.Error, "Error");
            }
        }
        catch (Exception ex)
        {
            Logger!.LogError(ex.Message.ToString());
            await NotificationDialog!.ShowNotification(ex.Message.ToString(), "OK", Color.Error, "Error");
        }
    }

    protected void ValidateForm()
    {

        // Verifica che il Model esista
        if (Model == null)
        {
            IsFormValid = false;
            return;
        }

        // 1. Controllo campi obbligatori
        bool campiObbligatoriCompilati =
            Model.DataLavorazione != null &&
            !string.IsNullOrWhiteSpace(Model.Operatore) &&
            Model.IdOperatore.HasValue &&
            !string.IsNullOrWhiteSpace(Model.Lavorazione) &&
            Model.IdProceduraLavorazione.HasValue &&
            !string.IsNullOrWhiteSpace(Model.Fase) &&
            Model.IdFaseLavorazione.HasValue;

        // 2. Controllo che almeno un campo numerico sia > 0
        bool almenoUnCampoNumerico =
            Model.Ore > 0 ||
            Model.Minuti > 0 ;

        // 3. Imposta lo stato del pulsante
        IsFormValid = campiObbligatoriCompilati && almenoUnCampoNumerico;


        StateHasChanged();
    }

    public override async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _cts.Dispose();
        await base.DisposeAsync();
    }

