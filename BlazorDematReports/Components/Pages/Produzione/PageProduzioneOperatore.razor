    protected void OnValueChangedReparto(string reparto)
    {
        Model!.Reparto = reparto;

        if (reparto != null)
        {
            if (!string.IsNullOrEmpty(reparto))
            {
                Model.IdReparti = ListReparti != null ? ListReparti!.FirstOrDefault(x => x.Reparti == reparto)?.IdReparti : throw new ArgumentNullException("Mandatory parameter ListReparti", nameof(ListReparti));

                if (Model.IdReparti == null)
                {
                    Model.Reparto = null;
                    Model.IdReparti = null;
                }
            }
            else
            {
                Model.IdReparti = null;
            }
        }
        else
        {
            Model.IdReparti = null;
        }


    }

