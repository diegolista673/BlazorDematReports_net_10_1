        ValidateForm();
    }

    protected void OnMinutiChanged(int minuti)
    {
        Model!.Minuti = minuti;
        CalcolaOreCents();
        ValidateForm();
    }

    protected void CalcolaOreCents()
    {
        int minuti = 0;
        if (Model!.Minuti == 0)
        {
            minuti = 0;
        }
        if (Model!.Minuti >= 1 && Model!.Minuti <= 15)
        {
            minuti = 15;
        }
        else if (Model!.Minuti >= 16 && Model!.Minuti <= 30)
        {
            minuti = 30;
        }
        else if (Model!.Minuti >= 31 && Model!.Minuti <= 45)
        {
            minuti = 45;
        }
        else if (Model!.Minuti >= 45 && Model!.Minuti <= 59)
        {
            minuti = 60;
        }


        Model!.TempoLavOreCent = (double)((Model!.Ore * 60) + minuti) / 60; ;
    }


