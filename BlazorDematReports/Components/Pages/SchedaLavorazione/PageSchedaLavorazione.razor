@page "/scheda-lavorazione"
@page "/scheda-lavorazione/{IdproceduraLavorazione:int}"
@using BlazorDematReports.Core.Services.ProcedureEdit
@inject BlazorDematReports.Core.Services.Interfaces.IDataService.IServiceProcedureLavorazioni ServiceProcedureLavorazioni

@attribute [Authorize(Roles = "OWNER, ADMIN, SUPERVISOR,CAPOTURNO")]
@inherits BaseComponentPage<PageSchedaLavorazione,ProcedureLavorazioniDto,ProcedureLavorazioniDto>
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject ProcedureEditStateService StateService

<MudText Typo="Typo.h4" Class="titolo ml-4">Scheda Lavorazione</MudText>

<MudDivider Class="border-solid border-1 mud-border-primary"></MudDivider>

@if (_initializing)
{
    <div class="d-flex justify-center align-center pa-8">
        <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
    </div>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">
        @* Card per selezione lavorazione *@
        <MudCard Outlined="true" Elevation="2" Class="mb-4">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" />
                    Seleziona Lavorazione
                </MudText>
                
                <MudAutocomplete T="string"
                                 Label="Lavorazione"
                                 SearchFunc="@((string arg, CancellationToken ct) => SearchFromSelect(base.SelectLavorazione, arg))"
                                 MaxItems="null"
                                 Clearable="true"
                                 ResetValueOnEmptyText="true"
                                 SelectOnActivation="true"
                                 Required="true"
                                 Value="@_selectedLavorazione"
                                 ValueChanged="@OnValueChangedLavorazioneAsync"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.Assignment"
                                 HelperText="Cerca e seleziona una lavorazione per visualizzare il riepilogo completo"/>
            </MudCardContent>
        </MudCard>

        @if (_currentModel != null && !string.IsNullOrEmpty(_selectedLavorazione))
        {
            @* Logo *@
            <ProcedureHeaderCard LogoBase64="@_currentModel.LogoBase64" />
            
            @* Informazioni Procedura *@
            <ProcedureInfoGrid Model="@_currentModel"/>
            
            @* KPI Cards *@
            <ProcedureKpiCards Model="@_currentModel" />
        }
        else if (string.IsNullOrEmpty(_selectedLavorazione))
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                Seleziona una lavorazione dal menu a tendina per visualizzare il riepilogo completo
            </MudAlert>
        }
    </MudContainer>

    @* Container per gli Expansion Panels *@
    @if (!_isLoading && _currentModel != null)
    {
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">

            @* CONTENUTO: Expansion Panels *@
            <MudExpansionPanels Elevation="3" Class="mb-4">
               
               
                @* Fasi di Lavorazione (Dettaglio Completo) *@
                <MudExpansionPanel Text="Fasi di Lavorazione - Dettaglio Completo"  Expanded="false">
                    <TitleContent>
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.ListAlt" />
                            <MudText>Fasi di Lavorazione - Dettaglio Completo</MudText>
                            <MudChip T="int" Size="Size.Small" Color="Color.Info">
                                @(_currentModel?.LavorazioniFasiDataReadingsDto?.Count(f => f.IdFaseLavorazione != 0) ?? 0)
                            </MudChip>
                        </div>
                    </TitleContent>

                    <ChildContent>
                        <ProcedurePhasesViewer Model="@_currentModel" OnModelChanged="@HandleModelChangedAsync" EditMode="false" />
                    </ChildContent>
                </MudExpansionPanel>

                @* Task Configurati Expansion Panel *@
                <MudExpansionPanel Text="Task Configurati" Expanded="false">
                    <TitleContent>
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Task" />
                            <MudText>Task Configurati</MudText>
                            @{
                                var allTasksCount = _currentModel.LavorazioniFasiDataReadingsDto?
                                    .SelectMany(f => f.TaskDaEseguireDto ?? Enumerable.Empty<TaskDaEseguireDto>())
                                    .ToList();
                                var enabledCount = allTasksCount?.Count(t => t.Enabled) ?? 0;
                                var disabledCount = allTasksCount?.Count(t => !t.Enabled) ?? 0;
                                var totalCount = allTasksCount?.Count ?? 0;
                            }
                            <MudChip T="int" Size="Size.Small" Color="Color.Info">
                                @totalCount
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">
                                @enabledCount Attivi
                            </MudChip>
                            @if (disabledCount > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">
                                    @disabledCount Disabilitati
                                </MudChip>
                            }
                        </div>
                    </TitleContent>
                    <ChildContent>
                        @{
                            var allTasks = _currentModel.LavorazioniFasiDataReadingsDto?
                                .Where(f => f.TaskDaEseguireDto?.Any() == true)
                                .SelectMany(f => f.TaskDaEseguireDto.Select(t => new { Fase = f, Task = t }))
                                .ToList();
                            
                            var disabledTasks = allTasks?.Where(t => !t.Task.Enabled).ToList();
                        }
                        
                        @if (disabledTasks?.Any() == true)
                        {
                            <MudAlert Severity="Severity.Warning" Class="ma-2 mb-3">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                                <strong>Attenzione:</strong> @disabledTasks.Count task disabilitati non verranno eseguiti automaticamente.
                                Gestisci lo stato dei task dalla pagina <MudLink Href="/fonti-dati" Typo="Typo.body2">Configurazioni Fonti Dati</MudLink>.
                            </MudAlert>
                        }
                        
                        @if (allTasks?.Any() == true)
                        {
                            <MudGrid Spacing="2" Class="pa-2">
                                @foreach (var item in allTasks)
                                {
                                    <MudItem xs="12" sm="6" md="4" lg="3">
                                        <MudCard Elevation="1" Style="height:100%;">
                                            <MudCardHeader>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">@item.Fase.FaseLavorazione</MudText>
                                                    <MudText Typo="Typo.h6">@item.Task.TaskName</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <div class="d-flex flex-column gap-1">
                                                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(item.Task.Stato)">
                                                            @(item.Task.Stato ?? "CONFIGURED")
                                                        </MudChip>
                                                        <MudChip T="string" 
                                                                 Size="Size.Small" 
                                                                 Color="@(item.Task.Enabled ? Color.Success : Color.Default)"
                                                                 Variant="@(item.Task.Enabled ? Variant.Filled : Variant.Outlined)">
                                                            @(item.Task.Enabled ? "Attivo" : "Disabilitato")
                                                        </MudChip>
                                                    </div>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                            <MudCardContent>
                                                <MudText Typo="Typo.body2" Class="mb-2">@item.Task.Descrizione</MudText>
                                                <MudDivider Class="my-2" />
                                                <div class="d-flex flex-column gap-1">
                                                    @if (item.Task.IdConfigurazioneDatabase.HasValue)
                                                    {
                                                        <div class="d-flex align-center">
                                                            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="mr-1" Color="Color.Primary" />
                                                            <MudText Typo="Typo.caption">Configurazione: ID @item.Task.IdConfigurazioneDatabase</MudText>
                                                        </div>
                                                    }
                                                    @if (item.Task.TimeTask.HasValue)
                                                    {
                                                        <div class="d-flex align-center">
                                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                                            <MudText Typo="Typo.caption">Orario: @item.Task.TimeTask.Value.ToString(@"hh\:mm")</MudText>
                                                        </div>
                                                    }
                                                    <div class="d-flex align-center">
                                                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-1" />
                                                        <MudText Typo="Typo.caption">Giorni precedenti: @item.Task.GiorniPrecedenti</MudText>
                                                    </div>
                                                </div>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Class="ma-2">Nessun task configurato</MudAlert>
                        }
                    </ChildContent>
                </MudExpansionPanel>
                
                 
                
            </MudExpansionPanels>
        </MudContainer>
    }
}


@code {
    [Parameter] public int? IdproceduraLavorazione { get; set; }
    
    private string? _selectedLavorazione;
    private ProcedureLavorazioniDto? _currentModel;
    private bool _isLoading = false;
    private bool _initializing = true;
    private int? _lastLoadedId;


    protected override async Task OnInitializedAsync()
    {
        try
        {
            _initializing = true;
            UiState?.ShowOverlay("Caricamento lavorazioni...");
            
            // Carica liste per autocomplete
            ListProcedureLavorazioni = await ServiceProcedureLavorazioni.GetTableProcedureLavorazioniByUserAsync();
            SetSelectLavorazione();
            
            // Se c'è un ID nel parametro, carica quella procedura
            if (IdproceduraLavorazione.HasValue)
            {
                await LoadProceduraByIdAsync(IdproceduraLavorazione.Value);
            }
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error initializing PageSchedaLavorazione");
            UiState?.ShowSnackbar($"Errore durante l'inizializzazione: {ex.Message}", Severity.Error);
        }
        finally
        {
            _initializing = false;
            UiState?.HideOverlay();
        }
    }
    
    protected override async Task OnParametersSetAsync()
    {
        // Evita reload se stiamo già caricando o se è lo stesso ID
        if (_isLoading || _initializing) return;
        
        // Gestisce il cambio di parametro quando si naviga con un ID diverso
        if (IdproceduraLavorazione.HasValue && IdproceduraLavorazione != _lastLoadedId)
        {
            await LoadProceduraByIdAsync(IdproceduraLavorazione.Value);
        }
        else if (!IdproceduraLavorazione.HasValue && _lastLoadedId.HasValue)
        {
            // Parametro rimosso, reset dello stato
            ClearCurrentModel();
        }
    }
    
    private async Task LoadProceduraByIdAsync(int id)
    {
        if (_isLoading) return;
        
        try
        {
            _isLoading = true;
            _lastLoadedId = id;
            UiState?.ShowOverlay("Caricamento scheda lavorazione...");
            
            var loadedModel = await ServiceProcedureLavorazioni.GetSingleProceduraLavorazioneDtoByIDAsync(id);
            
            if (loadedModel != null)
            {
                _currentModel = loadedModel;
                _selectedLavorazione = loadedModel.NomeProcedura;
                
                Logger?.LogInformation("Loaded procedure {ProcedureId}: {ProcedureName}", id, loadedModel.NomeProcedura);
            }
            else
            {
                UiState?.ShowSnackbar($"Lavorazione con ID {id} non trovata", Severity.Warning);
                ClearCurrentModel();
            }
            
            // Forza il refresh dell'UI
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error loading procedure {ProcedureId}", id);
            UiState?.ShowSnackbar($"Errore nel caricamento: {ex.Message}", Severity.Error);
            ClearCurrentModel();
        }
        finally
        {
            _isLoading = false;
            UiState?.HideOverlay();
        }
    }

    private async Task HandleModelChangedAsync()
    {
        StateService.DetectChanges();
        await InvokeAsync(StateHasChanged);
    }
    
    private async Task OnValueChangedLavorazioneAsync(string? lavorazione)
    {
        _selectedLavorazione = lavorazione;
        
        if (string.IsNullOrEmpty(lavorazione))
        {
            ClearCurrentModel();
            NavManager.NavigateTo("/scheda-lavorazione", replace: true);
            return;
        }
        
        if (_isLoading) return;
        
        try
        {
            UiState?.ShowOverlay("Caricamento lavorazione...");
            
            var procedura = ListProcedureLavorazioni?.FirstOrDefault(x => x.NomeProcedura == lavorazione);
            
            if (procedura?.IdproceduraLavorazione != null && procedura.IdproceduraLavorazione > 0)
            {
                var loadedModel = await ServiceProcedureLavorazioni.GetSingleProceduraLavorazioneDtoByIDAsync(procedura.IdproceduraLavorazione);
                
                if (loadedModel != null)
                {
                    _currentModel = loadedModel;
                    _lastLoadedId = procedura.IdproceduraLavorazione;
                    NavManager.NavigateTo($"/scheda-lavorazione/{procedura.IdproceduraLavorazione}", replace: true);

                }
            }
            else
            {
                ClearCurrentModel();
                UiState?.ShowSnackbar("Lavorazione non trovata", Severity.Warning);
            }
            
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error loading procedure: {ProcedureName}", lavorazione);
            UiState?.ShowSnackbar($"Errore nel caricamento: {ex.Message}", Severity.Error);
            ClearCurrentModel();
        }
        finally
        {
            UiState?.HideOverlay();
        }
    }
    
    private void ClearCurrentModel()
    {
        _currentModel = null;
        _selectedLavorazione = null;
        _lastLoadedId = null;
    }
    

    
    private Color GetStatusColor(string? stato, bool? attivaFlag = null)
    {
        if (attivaFlag.HasValue)
            return attivaFlag.Value ? Color.Success : Color.Error;
        return stato?.ToUpper() switch
        {
            "COMPLETED" => Color.Success,
            "CONFIGURED" => Color.Info,
            "ERROR" => Color.Error,
            _ => Color.Default
        };
    }
    
    private string GetPhaseIcon(LavorazioniFasiDataReadingDto fase)
    {
        return fase.FlagDataReading 
            ? Icons.Material.Filled.CheckCircle 
            : Icons.Material.Filled.Timeline;
    }
    
    private async Task CopyToClipboardAsync(string text)
    {
        try
        {
            // Usa la funzione JavaScript con fallback multipli
            var result = await JSRuntime.InvokeAsync<ClipboardResult>("clipboardHelper.copyText", text);
            
            if (result.Success)
            {
                Logger?.LogInformation("Query copiata usando metodo: {Method}", result.Method);
                UiState?.ShowSnackbar("Query copiata nella clipboard!", Severity.Success);
            }
            else
            {
                Logger?.LogWarning("Errore copia clipboard: {Error}", result.Error);
                UiState?.ShowSnackbar($"Impossibile copiare: {result.Error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Errore durante la copia nella clipboard");
            UiState?.ShowSnackbar($"Errore: {ex.Message}", Severity.Error);
        }
    }

    }

