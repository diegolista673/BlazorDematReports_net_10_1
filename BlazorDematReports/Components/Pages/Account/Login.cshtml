@page 
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model BlazorDematReports.Components.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = "_Layout";
}

<style>
    /* Reset per eliminare barre di scorrimento */
    html, body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        height: 100%;
    }

    /* Sfondo bianco con gradiente MudBlazor Primary */
    body {
        color: darkblue;
        background: linear-gradient(135deg, #ffffff 0%, #e8edf3 30%, #d2e2f2 70%, #594ae2 100%);
        background-attachment: fixed;
        height: 100vh;
    }

    /* Stili per la sezione di login */
    .login-section {
        background: linear-gradient(135deg, #ffffff 0%, #f5f7fa 50%, #e8edf3 100%);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
    }

    h5 {
        color: red;
    }

    /* Logo aziendale scalabile */
    .company-logo {
        width: 100%;
        max-width: 120px;
        height: auto;
        margin: 0 auto 1rem auto;
        display: block;
        transition: transform 0.3s ease;
        border-radius: 8px;
        box-shadow: 0 4px 12px rgba(89, 74, 226, 0.1);
    }

    .company-logo:hover {
        transform: scale(1.05);
    }

    /* Container logo */
    .logo-container {
        text-align: center;
        margin-bottom: 1rem;
        padding: 0.5rem;
    }

    .divider:after,
    .divider:before {
        content: "";
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, #e8edf3, #594ae2, #e8edf3);
    }

    /* Card con effetto glassmorphism senza bordo scuro */
    .login-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        box-shadow: 0 8px 32px 0 rgba(89, 74, 226, 0.1);
        border: none;
        padding: 2rem;
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
    }

    /* Stili per i form controls */
    .form-control {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(89, 74, 226, 0.3);
        border-radius: 8px;
    }

    .form-control:focus {
        background: rgba(255, 255, 255, 1);
        border-color: #594ae2;
        box-shadow: 0 0 0 0.2rem rgba(89, 74, 226, 0.25);
    }

    /* Bottone con gradiente MudBlazor Primary centrato */
    .btn-primary {
        background: linear-gradient(45deg, #594ae2, #7b6ef6);
        border: none;
        border-radius: 25px;
        transition: all 0.3s ease;
        width: 100%;
        max-width: 200px;
        margin: 0 auto;
        display: block;
    }

    .btn-primary:hover {
        background: linear-gradient(45deg, #4a3dd4, #6960f2);
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(89, 74, 226, 0.4);
    }

    /* Stili per le label */
    .form-label {
        color: #594ae2;
        font-weight: 500;
    }

    /* Titolo con gradiente MudBlazor Primary */
    .title-gradient {
        background: linear-gradient(45deg, #594ae2, #7b6ef6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Container di login ottimizzato */
    .login-container {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        overflow: hidden;
    }

    /* Badge ambiente */
    .environment-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 5px 12px;
        border-radius: 15px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .environment-badge.development {
        background: linear-gradient(45deg, #ff9800, #ffb74d);
        color: #000;
    }

    .environment-badge.production {
        background: linear-gradient(45deg, #4caf50, #81c784);
        color: #fff;
    }

    .environment-badge.default {
        background: linear-gradient(45deg, #9e9e9e, #bdbdbd);
        color: #fff;
    }

    /* Info box per ambiente di test */
    .test-info-box {
        background: rgba(255, 152, 0, 0.1);
        border: 1px solid rgba(255, 152, 0, 0.3);
        border-radius: 8px;
        padding: 10px;
        margin-bottom: 15px;
        font-size: 12px;
        color: #e65100;
    }

    /* Responsive design */
    @@media (max-width: 768px) {
        .login-card {
            padding: 1.5rem;
            margin: 1rem;
        }
        
        .btn-primary {
            width: 100%;
        }

        .company-logo {
            max-width: 100px;
            margin-bottom: 0.75rem;
        }
    }

    @@media (max-width: 576px) {
        .login-card {
            padding: 1rem;
            margin: 0.5rem;
        }

        .company-logo {
            max-width: 80px;
            margin-bottom: 0.5rem;
        }

        .title-gradient {
            font-size: 1.5rem !important;
        }
    }

    /* Nasconde eventuali scrollbar su mobile */
    @@media (max-height: 600px) {
        .login-section {
            align-items: flex-start;
            padding-top: 2rem;
        }

        .company-logo {
            max-width: 70px;
            margin-bottom: 0.5rem;
        }
    }

    /* Per schermi molto grandi */
    @@media (min-width: 1200px) {
        .company-logo {
            max-width: 140px;
            margin-bottom: 1.5rem;
        }
    }
</style>

<section class="login-section">
    <!-- Badge Ambiente -->
    @if (Model.ShowEnvironmentBadge)
    {
        <span class="environment-badge @Model.EnvironmentName.ToLower()">
            @Model.EnvironmentName
        </span>
    }

    <div class="container-fluid">
        <div class="row justify-content-center align-items-center h-100">
            <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-4 col-xxl-3">
                <div class="login-card">
                    <!-- Logo aziendale -->
                    @*<div class="logo-container">
                        <img src="~/images/charts" alt="Company Logo" class="company-logo" />
                    </div>*@

                    <form class="form-group" method="post">
                        <div class="divider d-flex align-items-center my-4" id="title">
                            <h1><p class="text-center fw-bold mx-3 mb-0 title-gradient" style="font-family: Arial">DEMAT Reports</p></h1>
                        </div>

                        <!-- Info box per ambiente Development -->
                        @if (Model.IsDevelopment)
                        {
                            <div class="test-info-box">
                                <strong>🔧 Ambiente di Test</strong><br />
                                Login semplificato attivo. Non è richiesta autenticazione Active Directory.
                            </div>
                        }

                        <!-- username input -->
                        <div class="form-outline mb-4">
                            <label class="form-label" for="UserName">Username</label>
                            <input asp-for="UserName" style="font-family: Arial" class="form-control form-control-lg" placeholder="Username" oninput="this.value = this.value.toLowerCase()" autofocus />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>

                        <!-- Password input -->
                        <div class="form-outline mb-3">
                            <label class="form-label" for="password">Password</label>
                            <input asp-for="Password" style="font-family: Arial" class="form-control form-control-lg" placeholder="Enter password" type="Password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="text-center mt-4 pt-2">
                            <input type="submit" class="btn btn-primary btn-lg" value="Sign In" />
                        </div>
                    </form>
                </div>

                <div class="form-group text-center mt-3">
                    <p><h5>@Model.Message</h5></p>
                </div>
            </div>
        </div>
    </div>
</section>

