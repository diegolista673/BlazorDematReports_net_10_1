</MudNavMenu>


@code
{

    bool _expand = false;
    private bool IsMenuDisabled;

    void ExpandToggle()
    {
        _expand = !_expand;
    }

    protected override void OnInitialized()
    {
        UiState.OnMenuDisabledChanged += HandleMenuDisabledChanged;
        IsMenuDisabled = false; 
        base.OnInitialized();
    }

    private void HandleMenuDisabledChanged(bool disabled)
    {
        InvokeAsync(() =>
        {
            IsMenuDisabled = disabled;
            StateHasChanged();
        });
    }
}

