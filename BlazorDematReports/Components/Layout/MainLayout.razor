@using BlazorDematReports.Services
@inherits LayoutComponentBase
@inject NavigationManager navigationManager;
@inject IJSRuntime js;
@inject UiStateService UiState
@inject ISnackbar Snackbar

<MudThemeProvider Theme="_currentTheme" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true"
MaxWidth="MaxWidth.ExtraSmall"
CloseButton="true"
Position="DialogPosition.Center"
CloseOnEscapeKey="true" />
<MudSnackbarProvider />

<style>
        /* sfondo grigio chiaro */
        .main-content-bg {
            background-color: #F9FAFB;
            min-height: 100vh;
        }

    .mud-drawer {
        border-right: 1px solid #E0E4E8 !important;
    }
</style>

<PageTitle>DematReports</PageTitle>

<MudLayout >
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">Demat Reports</MudText>
        <MudSpacer />
        <LoginDisplay></LoginDisplay>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="@DrawerVariant.Mini" MiniWidth="80px" Class="sidebar-moderna" OpenMiniOnHover="true">
        <MyNavMenu></MyNavMenu>
    </MudDrawer>


    <MudMainContent Class="main-content-bg">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 ">

            <CascadingValue Value="this" >
                @Body
            </CascadingValue>

        <div style="height: 120px; width: 100%; visibility: hidden;">&nbsp;</div>

        </MudContainer>
    </MudMainContent>

    @* Footer Fisso *@
    <MudAppBar Bottom="true" Fixed="true" Elevation="1" Dense="true" Class="justify-center" Style="text-align: right;top: auto; bottom: 0; height:25px">
        <MudText Inline="true" Align="Align.Right" Style="font-size:small; text-align:end ">@FooterText</MudText>
    </MudAppBar>


    <MudScrollToTop Style="height:80px;overflow: auto;">
        <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowUpward" />
    </MudScrollToTop>



    <MudOverlay Visible="@IsOverlayVisible" LightBackground="true">
        <div class="d-flex justify-space-around ">
            <MudText Typo="Typo.h4">@OverlayMessage</MudText>
            <MudProgressCircular Size="Size.Large" Indeterminate="true" />
        </div>
    </MudOverlay>

    <MudOverlay Visible="@IsVisibleEditing" LightBackground="true">
        <div class="d-flex justify-space-around ">
            <MudText Typo="Typo.h4">@TextEditOverlay</MudText>
            <MudProgressCircular Size="Size.Large" Indeterminate="true" />
        </div>
    </MudOverlay>
</MudLayout>


@code
{

    [CascadingParameter] public Task<AuthenticationState>? AuthenticationState { get; set; }

    bool _drawerOpen = true;
    private string FooterText = "";
    private bool IsOverlayVisible;
    private string? OverlayMessage;
    private bool IsMenuDisabled;
    private bool IsVisibleEditing;
    private string? TextEditOverlay;

    protected override void OnInitialized()
    {
        UiState.OnOverlayChanged += HandleOverlayChanged;
        UiState.OnMenuDisabledChanged += HandleMenuDisabledChanged;
        UiState.OnSnackbarRequested += HandleSnackbarRequested;
        UiState.OnEditOverlayChanged += HandleEditOverlayChanged;
    }

    private MudTheme _currentTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#0D47A1",          
            Secondary = Colors.Red.Accent4,        
            AppbarBackground = "#0D47A1", 
            Surface = "#FFFFFF",          
            ActionDefault = "#546E7A"   ,
            Background = "#F4F7F9"         // Sfondo pagina chiaro (per contrasto)
        }

    };


    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await js.InitializeInactivityTimer(DotNetObjectReference.Create(this));
        }

    }

    /// <summary>
    /// Handles the overlay visibility and message updates.
    /// </summary>
    /// <param name="visible"></param>
    /// <param name="message"></param>
    private void HandleOverlayChanged(bool visible, string? message)
    {
        InvokeAsync(() =>
        {
            IsOverlayVisible = visible;
            OverlayMessage = message;
            StateHasChanged();
        });

    }


    /// <summary>
    /// Handles the menu disabled state changes.
    /// </summary>
    /// <param name="disabled"></param>
    private void HandleMenuDisabledChanged(bool disabled)
    {
        InvokeAsync(() =>
        {
            IsMenuDisabled = disabled;
            StateHasChanged();
        });
    }



    /// <summary>
    /// Handles the snackbar requests to display messages to the user.
    /// </summary>
    /// <param name="message"></param>
    /// <param name="severity"></param>
    private void HandleSnackbarRequested(string message, Severity severity)
    {
        Snackbar!.Clear();
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomCenter;
        Snackbar.Add(message, severity);
    }

    /// <summary>
    /// Handles the edit overlay visibility and message updates.
    /// </summary>
    /// <param name="visible"></param>
    /// <param name="message"></param>
    private void HandleEditOverlayChanged(bool visible, string? message)
    {
        InvokeAsync(() =>
        {
            IsVisibleEditing = visible;
            TextEditOverlay = message;
            StateHasChanged();
        });
    }

    [JSInvokable]
    public async Task Logout()
    {
        var authState = await AuthenticationState!;
        if (authState.User.Identity!.IsAuthenticated)
        {

            navigationManager.NavigateTo("/Account/logout?", true);
        }
    }

    // You could also have a public property that can be set from other components
    public string DynamicFooterText
    {
        get => FooterText;
        set
        {
            FooterText = value;
            StateHasChanged(); // Important to re-render the layout
        }
    }

    public void UpdateFooter()
    {
        DynamicFooterText = "I dati presentati sono a scopo indicativo e potrebbero non essere completi";
    }

    public void ResetFooter()
    {
        DynamicFooterText = "";
    }

    public void Dispose()
    {
        UiState.OnOverlayChanged -= HandleOverlayChanged;
        UiState.OnMenuDisabledChanged -= HandleMenuDisabledChanged;
        UiState.OnSnackbarRequested -= HandleSnackbarRequested;
        UiState.OnEditOverlayChanged -= HandleEditOverlayChanged;
    }

}}