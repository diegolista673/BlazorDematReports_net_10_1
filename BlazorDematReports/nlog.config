<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/internal/nlog-internal.log">

  <!-- Enable ASP.NET Core layout renderers -->
  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <!-- Targets per scrivere i log -->
  <targets>
    <!-- Log principale dell'applicazione -->
    <target xsi:type="File" 
            name="allfile" 
            fileName="${basedir}/logs/blazor-demat-${shortdate}.log"
            layout="${longdate} | ${uppercase:${level:padding=5}} | ${logger:shortName=true} | ${message}${onexception:inner=${newline}${exception:format=ToString}}"
            archiveFileName="${basedir}/logs/archives/blazor-demat-${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            archiveAboveSize="52428800"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- Log specifici per errori SQL e database -->
    <target xsi:type="File" 
            name="sql-errors" 
            fileName="${basedir}/logs/errors/sql/sql-errors-${shortdate}.log"
            layout="${longdate} | ${uppercase:${level:padding=5}} | ${logger:shortName=true} | ${callsite:className=true:methodName=true} | ${message}${onexception:inner=${newline}${exception:format=ToString}}"
            archiveFileName="${basedir}/logs/archives/errors/sql/sql-errors-${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="60"
            concurrentWrites="true"
            encoding="utf-8" />

    <!-- Log per errori di validazione e business logic -->
    <target xsi:type="File" 
            name="validation-errors" 
            fileName="${basedir}/logs/errors/validation/validation-errors-${shortdate}.log"
            layout="${longdate} | ${uppercase:${level:padding=5}} | ${logger:shortName=true} | ${callsite:className=true:methodName=true} | ${message}${onexception:inner=${newline}${exception:format=ToString}}"
            archiveFileName="${basedir}/logs/archives/errors/validation/validation-errors-${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="60"
            concurrentWrites="true"
            encoding="utf-8" />

    <!-- Log per errori di background tasks (Hangfire) -->
    <target xsi:type="File" 
            name="background-task-errors" 
            fileName="${basedir}/logs/errors/background-tasks/bg-task-errors-${shortdate}.log"
            layout="${longdate} | ${uppercase:${level:padding=5}} | ${logger:shortName=true} | ${callsite:className=true:methodName=true} | ${message}${onexception:inner=${newline}${exception:format=ToString}}"
            archiveFileName="${basedir}/logs/archives/errors/background-tasks/bg-task-errors-${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="60"
            concurrentWrites="true"
            encoding="utf-8" />

    <!-- Log per errori critici dell'applicazione -->
    <target xsi:type="File" 
            name="critical-errors" 
            fileName="${basedir}/logs/errors/critical/critical-errors-${shortdate}.log"
            layout="${longdate} | ${uppercase:${level:padding=5}} | ${logger:shortName=true} | ${callsite:className=true:methodName=true:skipFrames=1} | ${message}${onexception:inner=${newline}${exception:format=ToString}}"
            archiveFileName="${basedir}/logs/archives/errors/critical/critical-errors-${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="90"
            concurrentWrites="true"
            encoding="utf-8" />

    <!-- Log per Hangfire -->
    <target xsi:type="File" 
            name="hangfire-log" 
            fileName="${basedir}/logs/hangfire/hangfire-${shortdate}.log"
            layout="${longdate} | ${uppercase:${level:padding=5}} | ${logger:shortName=true} | ${message}${onexception:inner=${newline}${exception:format=ToString}}"
            archiveFileName="${basedir}/logs/archives/hangfire/hangfire-${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true"
            encoding="utf-8" />

    <!-- Target unificato per tutte le query SQL con formato pulito -->
    <target xsi:type="File" 
            name="sql-queries" 
            fileName="${basedir}/logs/database/sql-queries-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true:padding=5} | ${logger:shortName=true:padding=15} | ${message}"
            archiveFileName="${basedir}/logs/archives/database/sql-queries-${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="7"
            archiveAboveSize="104857600"
            concurrentWrites="true"
            encoding="utf-8" />

    <!-- Log per DataReading e connessioni esterne: max 20MB/file, 14 giorni archivio -->
    <target xsi:type="File" 
            name="data-reading-log" 
            fileName="${basedir}/logs/data-reading/data-reading-${shortdate}.log"
            layout="${longdate} | ${uppercase:${level:padding=5}} | ${logger:shortName=true} | ${message}${onexception:inner=${newline}${exception:format=ToString}}"
            archiveFileName="${basedir}/logs/archives/data-reading/data-reading-${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="14"
            archiveAboveSize="20971520"
            concurrentWrites="true"
            encoding="utf-8" />



    <!-- Console semplice per produzione -->
    <target xsi:type="Console" 
            name="console"
            layout="${time} | ${uppercase:${level:padding=5}} | ${logger:shortName=true} | ${message}" />
  </targets>



  <!-- Regole di routing dei log -->
  <rules>
    <!-- ==================== QUERY SQL LOGGING UNIFICATO ==================== -->
    
    <!-- Log delle query SQL del QueryLoggingHelper: Warn in produzione/collaudo.
         In Development attivare via EnableQueryExecutionLog in appsettings.Development.json -->
    <logger name="SqlQueries" minlevel="Warn" writeTo="sql-queries" final="true" />

    <!-- Log delle query SQL di DataReading -->
    <logger name="DataReading.SqlQueries" minlevel="Warn" writeTo="sql-queries" final="true" />

    <!-- Log delle query SQL di LibraryLavorazioni -->
    <logger name="LibraryLavorazioni.SqlQueries" minlevel="Warn" writeTo="sql-queries" final="true" />
    
    <!-- ==================== CLASSI DI LAVORAZIONE - DATA READING ==================== -->
    
    <!-- PRIORITÀ ALTA: classi di lavorazione in data-reading — solo Warn+ per ridurre volume bulk CSV -->
    <logger name="LibraryLavorazioni.Lavorazioni.*" minlevel="Warn" writeTo="data-reading-log" final="true" />
    
    <!-- ==================== ENTITY FRAMEWORK QUERIES ==================== -->
    
    <!-- Entity Framework: solo Warn — evita log di ogni INSERT/SELECT durante operazioni bulk CSV -->
    <logger name="Microsoft.EntityFrameworkCore.Database.Command" minlevel="Warn" writeTo="sql-queries" final="true" />
    
    <!-- ==================== ERRORI SPECIFICI PER CATEGORIA ==================== -->
    
    <!-- Errori SQL specifici (SqlException, timeout, connessioni) -->
    <logger name="*" minlevel="Error" writeTo="sql-errors">
      <filters>
        <when condition="contains('${exception:format=ShortType}', 'SqlException') or 
                        contains('${exception:format=ShortType}', 'SqlTimeoutException') or 
                        contains('${exception:format=ShortType}', 'DbUpdateException') or
                        (contains('${exception:format=ShortType}', 'InvalidOperationException') and contains('${message}', 'database'))" action="Log" />
        <when condition="true" action="Ignore" />
      </filters>
    </logger>

    <!-- Errori di validazione e business logic -->
    <logger name="*" minlevel="Error" writeTo="validation-errors">
      <filters>
        <when condition="contains('${exception:format=ShortType}', 'ArgumentException') or 
                        contains('${exception:format=ShortType}', 'ValidationException') or 
                        contains('${exception:format=ShortType}', 'FormatException') or
                        contains('${exception:format=ShortType}', 'AutoMapperConfigurationException') or
                        contains('${exception:format=ShortType}', 'ArgumentNullException') or
                        contains('${exception:format=ShortType}', 'SearchDateException') or
                        contains('${message}', 'validazione') or
                        contains('${message}', 'validation')" action="Log" />
        <when condition="true" action="Ignore" />
      </filters>
    </logger>

    <!-- Errori dei background task -->
    <logger name="Hangfire.*" minlevel="Error" writeTo="background-task-errors" />
    <logger name="*BackgroundTask*" minlevel="Error" writeTo="background-task-errors" />
    <logger name="*DelayedJobScheduler*" minlevel="Error" writeTo="background-task-errors" />
    <logger name="*BackgroundExecution*" minlevel="Error" writeTo="background-task-errors" />
    <logger name="*Task*" minlevel="Error" writeTo="background-task-errors">
      <filters>
        <when condition="contains('${logger}', 'Task') or contains('${message}', 'background') or contains('${message}', 'job') or contains('${message}', 'DelayedJobScheduler')" action="Log" />
        <when condition="true" action="Ignore" />
      </filters>
    </logger>

    <!-- Errori critici (Fatal e eccezioni non gestite) -->
    <logger name="*" minlevel="Fatal" writeTo="critical-errors" />
    
    <!-- ==================== LOGGING APPLICATIVO SPECIFICO ==================== -->
    
    <!-- DataReading: solo file dedicato, no duplicazione su allfile, solo Warn+ -->
    <logger name="DataReading.*" minlevel="Warn" writeTo="data-reading-log" final="true" />
    <logger name="*LettoreDati*" minlevel="Warn" writeTo="data-reading-log" final="true" />
    
    <!-- Background tasks Hangfire -->
    <logger name="Hangfire.*" minlevel="Info" writeTo="hangfire-log" />
    
    <!-- ==================== RIDUZIONE RUMORE FRAMEWORK ==================== -->
    
    <!-- Microsoft framework logging ridotto -->
    <logger name="Microsoft.Extensions.Hosting.*" minlevel="Info" writeTo="allfile" final="true" />
    <logger name="Microsoft.Hosting.Lifetime*" minlevel="Info" writeTo="allfile" final="true" />
    <logger name="Microsoft.AspNetCore.Hosting.*" minlevel="Warn" writeTo="allfile" final="true" />
    <logger name="Microsoft.AspNetCore.Mvc.*" minlevel="Warn" writeTo="allfile" final="true" />
    <logger name="Microsoft.AspNetCore.Routing.*" minlevel="Warn" writeTo="allfile" final="true" />
    <logger name="Microsoft.EntityFrameworkCore.Infrastructure" minlevel="Warn" writeTo="allfile" final="true" />
    <logger name="Microsoft.EntityFrameworkCore.Model*" minlevel="Warn" writeTo="allfile" final="true" />
    <logger name="Microsoft.*" minlevel="Warn" writeTo="allfile" final="true" />
    <logger name="System.*" minlevel="Warn" writeTo="allfile" final="true" />
    
    <!-- ==================== LOGGING PRINCIPALE APPLICAZIONE ==================== -->
    
    <!-- Namespace specifici del progetto (DOPO le regole specifiche per evitare conflitti) -->
    <logger name="BlazorDematReports.*" minlevel="Debug" writeTo="allfile" />

    <!-- Manteniamo solo le altre parti di LibraryLavorazioni che non sono Lavorazioni -->
    <logger name="BlazorDematReports.Core.Utility.*" minlevel="Debug" writeTo="allfile" />
    <logger name="LibraryLavorazioni.Helpers.*" minlevel="Debug" writeTo="allfile" />
    <logger name="LibraryLavorazioni.Jobs.*" minlevel="Debug" writeTo="allfile" />
    <logger name="LibraryLavorazioni.LavorazioniViaMail.*" minlevel="Debug" writeTo="allfile" />
    <logger name="ClassLibraryLavorazioni.*" minlevel="Debug" writeTo="allfile" />
    
    <!-- Catch-all per tutto il resto -->
    <logger name="*" minlevel="Info" writeTo="allfile" />
  </rules>
</nlog>